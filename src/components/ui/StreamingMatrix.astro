---
interface StreamingEntry {
  service: string;
  support: "verified" | "partial" | "unsupported" | "unknown";
  verifiedAt?: string;
  notes?: string;
  regionsTested?: string[];
}

interface Props {
  items: StreamingEntry[];
  serviceNames: Record<string, string>;
  class?: string;
}

import Icon from "./Icon.astro";
import { cx } from "@/lib/utils/string";

const { items, serviceNames, class: className } = Astro.props;

const statusConfig = {
  verified: { icon: "check", color: "text-success", bg: "bg-success/10", label: "Verified" },
  partial: { icon: "alert-triangle", color: "text-warning", bg: "bg-warning/10", label: "Partial" },
  unsupported: { icon: "x", color: "text-danger", bg: "bg-danger/10", label: "Unsupported" },
  unknown: { icon: "help-circle", color: "text-muted-foreground", bg: "bg-surface-sunken", label: "Unknown" },
};
---

<div class={cx("grid gap-4", className)} style="grid-template-columns: repeat(auto-fill, minmax(240px, 1fr))">
  {items.map((s) => {
    const cfg = statusConfig[s.support] ?? statusConfig.unknown;
    const name = serviceNames[s.service] ?? s.service;
    return (
      <div class="group flex items-center gap-4 rounded-2xl border border-border bg-surface p-5 transition-all duration-200 hover:border-primary/30 hover:shadow-md">
        <div class={cx("flex h-10 w-10 shrink-0 items-center justify-center rounded-full", cfg.bg, cfg.color)}>
          <Icon name={cfg.icon} size={18} />
        </div>
        <div class="min-w-0">
          <div class="text-base font-bold text-foreground">{name}</div>
          <div class={cx("text-xs font-bold uppercase tracking-widest mt-0.5", cfg.color)}>{cfg.label}</div>
          {s.regionsTested && s.regionsTested.length > 0 && (
            <div class="mt-1.5 text-[10px] font-medium text-muted-foreground uppercase tracking-wider">{s.regionsTested.join(" · ")}</div>
          )}
        </div>
      </div>
    );
  })}
</div>

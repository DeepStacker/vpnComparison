---
/**
 * Table — responsive data table with a sticky header option.
 * @prop columns - column definitions ({ key, label, align, sticky }).
 * @prop rows - row records keyed by column.key.
 * @prop caption - accessible table caption.
 * @prop zebra - alternating row backgrounds.
 * @prop firstColumnSticky - keep the first column visible on horizontal scroll.
 */
import Icon from "./Icon.astro";
import { cx } from "@/lib/utils/string";

interface Column {
  key: string;
  label: string;
  align?: "left" | "center" | "right";
  sticky?: boolean;
}

interface Props {
  columns: Column[];
  rows: Record<string, string | number | boolean | null | undefined>[];
  caption?: string;
  zebra?: boolean;
  firstColumnSticky?: boolean;
  class?: string;
}

const { columns, rows, caption, zebra = true, firstColumnSticky = false, class: className } =
  Astro.props;

const alignClass: Record<string, string> = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
};


---

<div class={cx("w-full overflow-x-auto rounded-xl border border-border bg-surface shadow-sm", className)}>
  <table class="w-full border-collapse text-sm text-left">
    {
      caption && <caption class="sr-only">{caption}</caption>
    }
    <thead>
      <tr class="border-b border-border bg-surface-raised/50">
        {
          columns.map((col, i) => (
            <th
              scope="col"
              class={cx(
                "whitespace-nowrap px-4 py-3.5 font-bold text-foreground uppercase tracking-wider text-[10px]",
                alignClass[col.align ?? "left"],
                (col.sticky || (firstColumnSticky && i === 0)) &&
                  "sticky left-0 z-raised bg-surface-raised/95 backdrop-blur-sm",
              )}
            >
              {col.label}
            </th>
          ))
        }
      </tr>
    </thead>
    <tbody class="divide-y divide-border">
      {
        rows.map((row) => (
          <tr class={cx("hover:bg-surface-raised transition-colors duration-150", zebra && "even:bg-surface-raised/30")}>
            {columns.map((col, i) => (
              <td
                class={cx(
                  "px-4 py-3.5 text-foreground/80",
                  alignClass[col.align ?? "left"],
                  (col.sticky || (firstColumnSticky && i === 0)) &&
                    "sticky left-0 bg-surface/95 dark:bg-surface/95 backdrop-blur-sm",
                )}
              >
                {
                  typeof row[col.key] === "boolean"
                    ? row[col.key]
                      ? <Icon name="check" size={16} class="text-success inline-block" />
                      : <Icon name="minus" size={16} class="text-muted-foreground inline-block" />
                    : String(row[col.key] ?? "")
                }
              </td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

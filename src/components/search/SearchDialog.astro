---
/**
 * SearchDialog — full-screen modal search overlay with Fuse.js fuzzy search.
 *
 * Provides a Cmd+K / Ctrl+K keyboard shortcut and a global
 * `window.openSearchDialog()` function for programmatic opening.
 * Included once in BaseLayout so it's available on every page.
 */
import Icon from "@/components/ui/Icon.astro";
---

<div
  id="search-dialog"
  role="dialog"
  aria-modal="true"
  aria-label="Search the site"
  class="fixed inset-0 z-[2000] hidden items-start justify-center pt-[15vh]"
>
  <!-- Backdrop -->
  <div
    id="search-dialog-backdrop"
    class="absolute inset-0 bg-foreground/20 backdrop-blur-md"
  ></div>

  <!-- Dialog panel -->
  <div
    class="relative w-full max-w-2xl mx-4 rounded-2xl bg-surface border border-border shadow-2xl overflow-hidden animate-in fade-in zoom-in-95 duration-200"
  >
    <!-- Search input -->
    <div class="relative border-b border-border/50">
      <Icon
        name="search"
        size={22}
        class="pointer-events-none absolute left-5 top-1/2 -translate-y-1/2 text-muted-foreground/60"
      />
      <input
        type="search"
        id="search-dialog-input"
        placeholder="Search reviews, guides, comparisons…"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
        role="combobox"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-controls="search-dialog-results"
        aria-activedescendant=""
        class="w-full bg-transparent py-5 pl-14 pr-14 text-lg font-bold text-foreground placeholder:text-muted-foreground/50 transition-all focus-visible:outline-none"
      />
      <button
        id="search-dialog-clear"
        type="button"
        aria-label="Clear search"
        class="absolute right-5 top-1/2 hidden -translate-y-1/2 items-center justify-center text-muted-foreground/60 hover:text-foreground transition-colors"
        tabindex="-1"
      >
        <Icon name="x" size={22} />
      </button>
      <div
        id="search-dialog-spinner"
        class="absolute right-5 top-1/2 hidden -translate-y-1/2"
      >
        <span class="inline-block h-5 w-5 animate-spin rounded-full border-2 border-border border-t-primary" />
      </div>
    </div>

    <!-- Results area -->
    <div
      id="search-dialog-results"
      role="listbox"
      aria-label="Search results"
      class="max-h-[40vh] overflow-y-auto"
    >
      <!-- Recent searches -->
      <div id="search-dialog-recent" class="hidden">
        <div class="px-5 py-3 text-[10px] font-black uppercase tracking-[0.2em] text-muted-foreground/50 border-b border-border/30 bg-surface-sunken/30">
          Recent searches
        </div>
        <div id="search-dialog-recent-list" class="divide-y divide-border/30"></div>
      </div>

      <!-- Results -->
      <div id="search-dialog-results-inner" class="hidden">
        <!-- Populated by JS -->
      </div>

      <!-- Empty state -->
      <div id="search-dialog-empty" class="hidden">
        <div class="flex flex-col items-center justify-center px-8 py-16 text-center">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-surface-sunken border border-border mb-4">
            <Icon name="search-x" size={24} class="text-muted-foreground/60" />
          </div>
          <p class="text-lg font-bold text-foreground" id="search-dialog-empty-title">No results found</p>
          <p class="mt-1 text-sm text-muted-foreground">
            Try a different search term or browse our categories.
          </p>
        </div>
      </div>

      <!-- Error state -->
      <div id="search-dialog-error" class="hidden">
        <div class="flex flex-col items-center justify-center px-8 py-16 text-center">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-danger/10 text-danger border border-danger/20 mb-4">
            <Icon name="alert-circle" size={24} />
          </div>
          <p class="text-lg font-bold text-foreground">Something went wrong</p>
          <p class="mt-1 text-sm text-muted-foreground">
            Search is temporarily unavailable. Please try again later.
          </p>
        </div>
      </div>

      <!-- Footer hint -->
      <div id="search-dialog-footer" class="hidden border-t border-border/30 px-5 py-3">
        <div class="flex items-center gap-6 text-xs text-muted-foreground/60">
          <span class="flex items-center gap-2">
            <kbd class="inline-flex items-center justify-center rounded-md border border-border bg-surface-sunken px-1.5 py-0.5 text-[10px] font-black min-w-[20px]">↑</kbd>
            <kbd class="inline-flex items-center justify-center rounded-md border border-border bg-surface-sunken px-1.5 py-0.5 text-[10px] font-black min-w-[20px]">↓</kbd>
            <span>Navigate</span>
          </span>
          <span class="flex items-center gap-2">
            <kbd class="inline-flex items-center justify-center rounded-md border border-border bg-surface-sunken px-1.5 py-0.5 text-[10px] font-black">⏎</kbd>
            <span>Open</span>
          </span>
          <span class="flex items-center gap-2">
            <kbd class="inline-flex items-center justify-center rounded-md border border-border bg-surface-sunken px-1.5 py-0.5 text-[10px] font-black">Esc</kbd>
            <span>Close</span>
          </span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import Fuse from "fuse.js";

  interface SearchEntry {
    id: string;
    title: string;
    summary: string;
    url: string;
    type: string;
    content: string;
  }

  interface FuseResult {
    item: SearchEntry;
    refIndex: number;
    score?: number;
  }

  const TYPE_LABELS: Record<string, string> = {
    review: "Reviews",
    guide: "Guides",
    "best-list": "Best Lists",
    comparison: "Comparisons",
    faq: "FAQs",
    provider: "Providers",
    country: "Countries",
    feature: "Features",
    protocol: "Protocols",
    platform: "Platforms",
    streaming: "Streaming",
    tool: "Tools",
  };

  const TYPE_ORDER: Record<string, number> = {
    review: 0,
    guide: 1,
    "best-list": 2,
    comparison: 3,
    faq: 4,
    provider: 5,
    country: 6,
    feature: 7,
    protocol: 8,
    platform: 9,
    streaming: 10,
    tool: 11,
  };

  const DEBOUNCE_MS = 300;
  const MIN_QUERY = 2;
  const MAX_RESULTS = 20;
  const RECENT_KEY = "nh-recent-searches";
  const MAX_RECENT = 5;

  /* ---------- DOM refs ---------- */
  const dialog = document.getElementById("search-dialog")!;
  const backdrop = document.getElementById("search-dialog-backdrop")!;
  const input = document.getElementById("search-dialog-input") as HTMLInputElement | null;
  const resultsInner = document.getElementById("search-dialog-results-inner")!;
  const recentOuter = document.getElementById("search-dialog-recent")!;
  const recentList = document.getElementById("search-dialog-recent-list")!;
  const emptyEl = document.getElementById("search-dialog-empty")!;
  const emptyTitle = document.getElementById("search-dialog-empty-title")!;
  const errorEl = document.getElementById("search-dialog-error")!;
  const footerEl = document.getElementById("search-dialog-footer")!;
  const clearBtn = document.getElementById("search-dialog-clear") as HTMLButtonElement | null;
  const spinner = document.getElementById("search-dialog-spinner")!;

  /* ---------- State ---------- */
  let fuse: Fuse<SearchEntry> | null = null;
  let fuseReady = false;
  let currentResults: FuseResult[] = [];
  let activeIndex = -1;
  let debounceTimer: ReturnType<typeof setTimeout> | null = null;
  let isOpen = false;

  /* ---------- Helpers ---------- */
  function createHighlightedElement(
    text: string,
    query: string,
    tag: "span" | "div" = "span",
    className = "",
  ): HTMLElement {
    const el = document.createElement(tag);
    if (className) el.className = className;
    if (!query || query.length < MIN_QUERY) {
      el.textContent = text;
      return el;
    }
    const pattern = query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    const regex = new RegExp(`(${pattern})`, "gi");
    let lastIndex = 0;
    let match: RegExpExecArray | null;
    while ((match = regex.exec(text)) !== null) {
      if (match.index > lastIndex) {
        el.appendChild(
          document.createTextNode(text.slice(lastIndex, match.index)),
        );
      }
      const mark = document.createElement("mark");
      mark.className = "bg-primary/20 text-foreground rounded-sm px-0.5";
      mark.textContent = match[1]!;
      el.appendChild(mark);
      lastIndex = regex.lastIndex;
    }
    if (lastIndex < text.length) {
      el.appendChild(document.createTextNode(text.slice(lastIndex)));
    }
    return el;
  }

  function getRecentSearches(): string[] {
    try {
      const raw = localStorage.getItem(RECENT_KEY);
      if (!raw) return [];
      const parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed.slice(0, MAX_RECENT) : [];
    } catch {
      return [];
    }
  }

  function saveRecentSearch(query: string): void {
    const recent = getRecentSearches().filter((s) => s !== query);
    recent.unshift(query);
    localStorage.setItem(RECENT_KEY, JSON.stringify(recent.slice(0, MAX_RECENT)));
  }

  /* ---------- UI state ---------- */
  function hideAll(): void {
    resultsInner.classList.add("hidden");
    recentOuter.classList.add("hidden");
    emptyEl.classList.add("hidden");
    errorEl.classList.add("hidden");
    footerEl.classList.add("hidden");
  }

  function showFooter(): void {
    footerEl.classList.remove("hidden");
  }

  function showLoading(): void {
    spinner.classList.remove("hidden");
    clearBtn?.classList.add("hidden");
  }

  function hideLoading(): void {
    spinner.classList.add("hidden");
  }

  function showClearButton(): void {
    if (input?.value.trim()) {
      clearBtn?.classList.remove("hidden");
    } else {
      clearBtn?.classList.add("hidden");
    }
  }

  function showError(message?: string): void {
    hideAll();
    hideLoading();
    const msgEl = errorEl.querySelector("p:last-child")!;
    msgEl.textContent = message ?? "Search is temporarily unavailable.";
    errorEl.classList.remove("hidden");
    showFooter();
    input?.setAttribute("aria-expanded", "true");
  }

  function showEmpty(query: string): void {
    hideAll();
    hideLoading();
    if (query.length < MIN_QUERY) {
      emptyTitle.textContent = "Enter a search term to begin";
    } else {
      emptyTitle.textContent = "No results found";
    }
    emptyEl.classList.remove("hidden");
    showFooter();
    input?.setAttribute("aria-expanded", "true");
  }

  function showRecent(): void {
    hideAll();
    hideLoading();
    const recents = getRecentSearches();
    if (recents.length === 0) {
      showEmpty("");
      return;
    }
    recentList.textContent = "";
    for (let i = 0; i < recents.length; i++) {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.role = "option";
      btn.tabIndex = -1;
      btn.dataset.recent = String(i);
      btn.dataset.query = recents[i];
      btn.className =
        "flex w-full cursor-pointer items-center gap-4 px-5 py-3.5 text-left text-sm font-bold text-foreground transition-all hover:bg-primary/5 hover:text-primary focus-visible:outline-none focus-visible:bg-primary/5";
      const svgNs = "http://www.w3.org/2000/svg";
      const svg = document.createElementNS(svgNs, "svg");
      svg.setAttribute("width", "18");
      svg.setAttribute("height", "18");
      svg.setAttribute("viewBox", "0 0 24 24");
      svg.setAttribute("fill", "none");
      svg.setAttribute("stroke", "currentColor");
      svg.setAttribute("stroke-width", "2.5");
      svg.setAttribute("stroke-linecap", "round");
      svg.setAttribute("stroke-linejoin", "round");
      svg.classList.add("shrink-0", "text-muted-foreground/60");
      const circle = document.createElementNS(svgNs, "circle");
      circle.setAttribute("cx", "12");
      circle.setAttribute("cy", "12");
      circle.setAttribute("r", "10");
      svg.appendChild(circle);
      const polyline = document.createElementNS(svgNs, "polyline");
      polyline.setAttribute("points", "12 6 12 12 16 14");
      svg.appendChild(polyline);
      btn.appendChild(svg);
      const span = document.createElement("span");
      span.textContent = recents[i] ?? "";
      btn.appendChild(span);
      recentList.appendChild(btn);
    }
    recentOuter.classList.remove("hidden");
    showFooter();
    input?.setAttribute("aria-expanded", "true");
  }

  /* ---------- Render results ---------- */
  function renderResults(query: string): void {
    hideAll();
    hideLoading();

    if (!currentResults.length) {
      showEmpty(query);
      return;
    }

    const grouped: Record<string, FuseResult[]> = {};
    for (const r of currentResults) {
      const t = r.item.type;
      if (!grouped[t]) grouped[t] = [];
      grouped[t].push(r);
    }

    const sortedTypes = Object.keys(grouped).sort(
      (a, b) => (TYPE_ORDER[a] ?? 99) - (TYPE_ORDER[b] ?? 99),
    );

    resultsInner.textContent = "";
    let optionIndex = 0;

    for (const type of sortedTypes) {
      const items = grouped[type]!;
      const label = TYPE_LABELS[type] ?? type;

      const header = document.createElement("div");
      header.className =
        "sticky top-0 z-10 px-5 py-2 text-[10px] font-black uppercase tracking-[0.2em] text-muted-foreground/50 bg-surface border-b border-border/30";
      header.textContent = label;
      resultsInner.appendChild(header);

      for (const r of items) {
        const link = document.createElement("a");
        link.href = r.item.url;
        link.role = "option";
        link.id = `search-dialog-option-${optionIndex}`;
        link.setAttribute("aria-selected", "false");
        link.className =
          "flex flex-col gap-0.5 px-5 py-3.5 text-left border-l-4 border-transparent transition-all hover:border-primary hover:bg-primary/5 focus-visible:outline-none focus-visible:bg-primary/5";
        link.appendChild(
          createHighlightedElement(
            r.item.title,
            query,
            "span",
            "text-base font-bold text-foreground",
          ),
        );
        if (r.item.summary) {
          link.appendChild(
            createHighlightedElement(
              r.item.summary,
              query,
              "span",
              "line-clamp-1 text-sm text-muted-foreground leading-relaxed",
            ),
          );
        }
        resultsInner.appendChild(link);
        optionIndex++;
      }
    }

    resultsInner.classList.remove("hidden");
    showFooter();
    input?.setAttribute("aria-expanded", "true");

    activeIndex = -1;
    input?.setAttribute("aria-activedescendant", "");
  }

  /* ---------- Keyboard navigation ---------- */
  function navigateIndex(direction: 1 | -1): void {
    if (!isOpen) return;
    const options = resultsInner.querySelectorAll<HTMLElement>("[role='option']");
    if (!options.length) return;

    if (activeIndex >= 0) {
      options[activeIndex]?.removeAttribute("aria-selected");
      options[activeIndex]?.classList.remove("bg-primary/5", "border-primary");
      options[activeIndex]?.classList.add("border-transparent");
    }

    activeIndex = Math.min(Math.max(activeIndex + direction, 0), options.length - 1);

    options[activeIndex]?.setAttribute("aria-selected", "true");
    options[activeIndex]?.classList.remove("border-transparent");
    options[activeIndex]?.classList.add("bg-primary/5", "border-primary");
    options[activeIndex]?.scrollIntoView({ block: "nearest" });

    const id = options[activeIndex]?.id ?? "";
    input?.setAttribute("aria-activedescendant", id);
  }

  function selectActive(): void {
    if (!isOpen || activeIndex < 0) return;
    const options = resultsInner.querySelectorAll<HTMLElement>("[role='option']");
    const active = options[activeIndex] as HTMLAnchorElement | null;
    if (active?.href) {
      saveRecentSearch(input?.value.trim() ?? "");
      closeDialog();
      window.location.href = active.href;
    }
  }

  /* ---------- Event handlers ---------- */
  function handleInput(): void {
    const query = input?.value.trim() ?? "";
    showClearButton();

    if (debounceTimer) clearTimeout(debounceTimer);

    if (query.length < MIN_QUERY) {
      hideLoading();
      if (input === document.activeElement) {
        showRecent();
      }
      return;
    }

    showLoading();
    debounceTimer = setTimeout(() => {
      performSearch(query);
    }, DEBOUNCE_MS);
  }

  function performSearch(query: string): void {
    if (!fuse) {
      if (!fuseReady) {
        showLoading();
      } else {
        showError("Search library not loaded.");
      }
      return;
    }

    currentResults = fuse.search(query).slice(0, MAX_RESULTS) as FuseResult[];
    renderResults(query);
  }

  function handleKeydown(e: KeyboardEvent): void {
    if (e.key === "ArrowDown") {
      e.preventDefault();
      navigateIndex(1);
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      navigateIndex(-1);
    } else if (e.key === "Enter") {
      e.preventDefault();
      if (activeIndex >= 0) {
        selectActive();
      } else if (currentResults.length === 1) {
        saveRecentSearch(input?.value.trim() ?? "");
        closeDialog();
        window.location.href = currentResults[0]!.item.url;
      } else if (currentResults.length > 1) {
        // Navigate to search page with all results
        saveRecentSearch(input?.value.trim() ?? "");
        closeDialog();
        window.location.href = `/search/?q=${encodeURIComponent(input?.value.trim() ?? "")}`;
      }
    } else if (e.key === "Escape") {
      e.preventDefault();
      closeDialog();
    }
  }

  function handleClear(): void {
    if (input) {
      input.value = "";
      handleInput();
    }
  }

  function handleRecentClick(e: Event): void {
    const target = e.target as HTMLElement;
    const btn = target.closest<HTMLButtonElement>("[data-query]");
    if (!btn) return;
    const query = btn.dataset.query ?? "";
    if (input) {
      input.value = query;
      handleInput();
      performSearch(query);
    }
  }

  /* ---------- Dialog open/close ---------- */
  function openDialog(): void {
    if (isOpen) return;
    isOpen = true;
    dialog.classList.remove("hidden");
    dialog.classList.add("flex");
    activeIndex = -1;
    currentResults = [];
    hideAll();
    hideLoading();

    // Prevent body scroll
    document.body.style.overflow = "hidden";

    // Focus input after animation
    requestAnimationFrame(() => {
      input?.focus();
      input?.select();
      // Show recent searches
      showRecent();
    });
  }

  function closeDialog(): void {
    if (!isOpen) return;
    isOpen = false;
    dialog.classList.add("hidden");
    dialog.classList.remove("flex");
    document.body.style.overflow = "";
    input?.blur();
    if (debounceTimer) clearTimeout(debounceTimer);
    // Clear input
    if (input) {
      input.value = "";
    }
    hideAll();
    hideLoading();
    clearBtn?.classList.add("hidden");
    activeIndex = -1;
  }

  // Expose globally
  (window as any).openSearchDialog = openDialog;

  /* ---------- Init ---------- */
  async function init(): Promise<void> {
    // Fetch search index
    try {
      const res = await fetch("/search-index.json");
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data: SearchEntry[] = await res.json();
      fuse = new Fuse(data, {
        keys: [
          { name: "title", weight: 2 },
          { name: "summary", weight: 1.5 },
          { name: "content", weight: 1 },
        ],
        threshold: 0.4,
        minMatchCharLength: 2,
        includeScore: true,
      });
      fuseReady = true;
      hideLoading();
    } catch {
      fuseReady = true;
      showError("Search index not available. Please try again later.");
    }

    // Event listeners
    input?.addEventListener("input", handleInput);
    input?.addEventListener("keydown", handleKeydown);
    clearBtn?.addEventListener("click", handleClear);
    recentList.addEventListener("click", handleRecentClick);

    // Close on backdrop click
    backdrop.addEventListener("click", closeDialog);

    // Keyboard shortcut (Cmd+K / Ctrl+K)
    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        openDialog();
      }
    });

    // Close on resize to mobile breakpoint
    let resizeTimer: ReturnType<typeof setTimeout> | null = null;
    window.addEventListener("resize", () => {
      if (resizeTimer) clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        if (isOpen && window.innerWidth < 768) {
          closeDialog();
        }
      }, 200);
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    void init();
  });
</script>

---
import { getCollection } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Grid from "@/components/ui/Grid.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import { formatDate } from "@/lib/utils/date";
import type { Breadcrumb } from "@/types/site";

const allGuides = await getCollection("guides");
const allAuthors = await getCollection("authors");
const authorMap = new Map(allAuthors.map((a) => [a.id, a.data.name]));

const difficultyTone: Record<string, string> = {
  beginner: "success",
  intermediate: "primary",
  advanced: "warning",
};

const seo = normalizeSeoMeta({
  title: buildTitle("VPN Guides — Learn How VPNs Work"),
  description: "Comprehensive VPN guides covering privacy, security, setup, protocols, and how to choose the right VPN for your needs.",
  canonical: canonicalUrl("/guides/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "VPN Guides", href: "/guides/" },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section background>
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <Heading level={1}>VPN Guides</Heading>
        <Text tone="muted" size="lg" class="mt-3 max-w-prose mx-auto">
          Learn how VPNs work, how to choose one, and how to set it up. Our guides cover everything from beginner basics to advanced privacy techniques.
        </Text>
      </div>
    </Container>
  </Section>

  <Section>
    <Container>
      {allGuides.length === 0 && (
        <div class="flex flex-col items-center justify-center rounded-lg border border-dashed border-border bg-surface-sunken/40 px-6 py-12 text-center">
          <Text tone="muted">No guides published yet.</Text>
        </div>
      )}
      <Grid cols={1} colsMd={2} colsLg={3} gap={6}>
        {allGuides.map((g) => {
          const authorName = authorMap.get(g.data.author.id);
          return (
            <Card variant="raised" padding="md">
              <Heading level={2} size="xl">{g.data.title}</Heading>
              <Text size="sm" tone="muted" class="mt-2">{g.data.summary}</Text>
              <div class="mt-3 flex flex-wrap items-center gap-2">
                <Badge tone={difficultyTone[g.data.difficulty] as any} size="sm">
                  {g.data.difficulty.charAt(0).toUpperCase() + g.data.difficulty.slice(1)}
                </Badge>
                <Badge tone="neutral" size="sm">{g.data.category}</Badge>
              </div>
              <div class="mt-3 flex flex-wrap gap-3 text-xs text-muted-foreground">
                {authorName && <span>By {authorName}</span>}
                <span>{formatDate(g.data.publishedAt)}</span>
              </div>
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/guides/${g.id}/`}>Read Guide</Button>
              </div>
            </Card>
          );
        })}
      </Grid>
    </Container>
  </Section>
</SeoLayout>

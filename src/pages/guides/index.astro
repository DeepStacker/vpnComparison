---
import { getCollection } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Grid from "@/components/ui/Grid.astro";
import Icon from "@/components/ui/Icon.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import { formatDate } from "@/lib/utils/date";
import type { Breadcrumb } from "@/types/site";

const allGuides = await getCollection("guides");
const allAuthors = await getCollection("authors");
const authorMap = new Map(allAuthors.map((a) => [a.id, a.data.name]));

const difficultyTone: Record<string, string> = {
  beginner: "success",
  intermediate: "primary",
  advanced: "warning",
};

const seo = normalizeSeoMeta({
  title: buildTitle("VPN Guides — Learn How VPNs Work"),
  description: "Comprehensive VPN guides covering privacy, security, setup, protocols, and how to choose the right VPN for your needs.",
  canonical: canonicalUrl("/guides/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "VPN Guides", href: "/guides/" },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section class="relative overflow-hidden pb-20 pt-24 md:pb-28 md:pt-32">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent"></div>
      <div class="absolute left-1/2 top-0 h-[500px] w-[1000px] -translate-x-1/2 bg-primary/5 blur-[120px]"></div>
    </div>
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <Badge tone="primary" class="mb-6">Knowledge Base</Badge>
        <Heading level={1} class="text-4xl font-black tracking-tight md:text-6xl">
          VPN <span class="text-primary">Guides</span>
        </Heading>
        <Text size="xl" tone="muted" class="mt-6 max-w-2xl mx-auto leading-relaxed">
          Learn how VPNs work, how to choose one, and how to set it up. Our guides cover everything from beginner basics to advanced privacy techniques.
        </Text>
      </div>
    </Container>
  </Section>

  <Section class="pb-32">
    <Container>
      {allGuides.length === 0 ? (
        <div class="flex flex-col items-center justify-center rounded-3xl border-2 border-dashed border-border bg-surface-sunken/30 px-8 py-20 text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-surface border border-border shadow-sm mb-6">
            <Icon name="book-open" size={32} class="text-muted-foreground" />
          </div>
          <p class="text-xl font-bold text-foreground">No guides published yet</p>
          <p class="mt-2 text-muted-foreground">Check back soon for our latest privacy and security guides.</p>
        </div>
      ) : (
        <Grid cols={1} colsMd={2} colsLg={3} gap={8}>
          {allGuides.map((g) => {
            const authorName = authorMap.get(g.data.author.id);
            return (
              <Card variant="raised" padding="none" class="group overflow-hidden flex flex-col h-full">
                <div class="p-8 flex flex-col flex-grow">
                  <div class="flex items-center gap-2 mb-6">
                    <Badge tone={difficultyTone[g.data.difficulty] as any} size="sm">
                      {g.data.difficulty.charAt(0).toUpperCase() + g.data.difficulty.slice(1)}
                    </Badge>
                    <Badge tone="neutral" size="sm">{g.data.category}</Badge>
                  </div>
                  
                  <Heading level={2} class="text-2xl font-bold group-hover:text-primary transition-colors">
                    {g.data.title}
                  </Heading>
                  
                  <Text size="base" tone="muted" class="mt-4 line-clamp-3 leading-relaxed">
                    {g.data.summary}
                  </Text>
                  
                  <div class="mt-auto pt-8 flex items-center justify-between">
                    <div class="flex flex-col gap-1">
                      {authorName && <span class="text-xs font-bold text-foreground uppercase tracking-wider">{authorName}</span>}
                      <span class="text-xs text-muted-foreground">{formatDate(g.data.publishedAt)}</span>
                    </div>
                    <Button variant="glass" size="sm" href={`/guides/${g.id}/`} class="rounded-xl">
                      Read Guide
                    </Button>
                  </div>
                </div>
              </Card>
            );
          })}
        </Grid>
      )}
    </Container>
  </Section>
</SeoLayout>

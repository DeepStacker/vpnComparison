---
interface VpnAuditProvider {
  id: string; slug: string; name: string;
  jurisdiction: string; loggingPolicy: string;
  audits: Array<{ auditor: string; independent: boolean }>;
  killSwitch: boolean; multiHop: boolean; splitTunneling: boolean;
  features: string[]; protocols: string[];
}

interface VpnAuditReview {
  providerId: string;
  scores: { privacy: number; security: number; overall: number };
  verdict: { headline: string; summary: string; recommendation: string };
}

interface Props {
  providers: VpnAuditProvider[];
  reviews: VpnAuditReview[];
}

const { providers, reviews } = Astro.props;
---

<div id="vpn-audit-root" class="grid gap-8 lg:grid-cols-5">
  <div class="lg:col-span-2 rounded-2xl border border-border bg-surface p-6 shadow-sm">
    <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Audit setup</p>
    <h2 class="mt-2 text-xl font-black tracking-tight">Pick a provider</h2>
    <p class="mt-2 text-sm text-muted-foreground leading-relaxed">We’ll score the provider against 12 enterprise privacy controls.</p>

    <div class="mt-6">
      <label for="audit-provider" class="block text-xs font-bold uppercase tracking-widest text-muted-foreground">Provider</label>
      <select id="audit-provider" class="mt-2 w-full rounded-xl border border-border bg-surface-sunken/40 px-4 py-2.5 text-sm font-bold text-foreground focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/20">
        {providers.map((p) => `<option value="${p.id}">${p.name}</option>`)}
      </select>
    </div>

    <div class="mt-5">
      <label for="audit-context" class="block text-xs font-bold uppercase tracking-widest text-muted-foreground">Use case</label>
      <select id="audit-context" class="mt-2 w-full rounded-xl border border-border bg-surface-sunken/40 px-4 py-2.5 text-sm font-bold text-foreground focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/20">
        <option value="personal">Personal use</option>
        <option value="journalist">Journalism & research</option>
        <option value="business">Business & remote work</option>
        <option value="travel">Travel & public Wi-Fi</option>
      </select>
    </div>

    <button id="audit-run" type="button" class="mt-6 w-full rounded-xl bg-primary px-6 py-3 text-sm font-black uppercase tracking-widest text-primary-foreground transition-all duration-200 hover:brightness-110 shadow-lg">Run audit</button>

    <div class="mt-6 rounded-xl border border-border bg-surface-sunken/40 p-4 text-xs text-muted-foreground leading-relaxed">
      The audit combines structured provider data with a public-controls model. Use the action plan to negotiate stronger terms or escalate concerns.
    </div>
  </div>

  <div class="lg:col-span-3 space-y-6" id="audit-results">
    <div class="rounded-2xl border border-border bg-surface p-8 shadow-sm text-center">
      <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Idle</p>
      <h3 class="mt-3 text-2xl font-black tracking-tight">Run the audit to see results</h3>
      <p class="mt-3 text-sm text-muted-foreground max-w-md mx-auto leading-relaxed">Pick a provider and use case to receive a scored audit with risks, mitigations, and recommended actions.</p>
    </div>
  </div>
</div>

<script is:inline type="application/json" id="audit-data" set:html={JSON.stringify(providers)}></script>
<script is:inline type="application/json" id="audit-reviews-data" set:html={JSON.stringify(reviews)}></script>

<script>
  import { initVpnAudit } from "./VpnAudit.client";
  initVpnAudit();
</script>

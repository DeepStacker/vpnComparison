---
import { getCollection } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Grid from "@/components/ui/Grid.astro";
import Icon from "@/components/ui/Icon.astro";
import { getPlatformCountMap } from "@/lib/content/explorer";
import { platformHref } from "@/lib/content/links";
import { normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

const allPlatforms = await getCollection("platforms");
const countMap = await getPlatformCountMap();

const seo = normalizeSeoMeta({
  title: "VPN Platform Support — Windows, macOS, Linux, Mobile & More",
  description: "Compare VPN platform support across Windows, macOS, Linux, Android, iOS, routers, smart TVs, and browser extensions. Find providers with official apps for your devices.",
  canonical: canonicalUrl("/platforms/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Platforms", href: "/platforms/" },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section class="relative overflow-hidden pb-20 pt-24 md:pb-28 md:pt-32">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent"></div>
      <div class="absolute left-1/2 top-0 h-[500px] w-[1000px] -translate-x-1/2 bg-primary/5 blur-[120px]"></div>
    </div>
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <Badge tone="primary" class="mb-6">Device Compatibility</Badge>
        <Heading level={1} class="text-4xl font-black tracking-tight md:text-6xl">
          Platform <span class="text-primary">Support</span>
        </Heading>
        <Text size="xl" tone="muted" class="mt-6 max-w-2xl mx-auto leading-relaxed">
          Not every VPN works on every device. Browse which providers offer official apps for your platform — desktop, mobile, routers, smart TVs, and browser extensions.
        </Text>
      </div>
    </Container>
  </Section>

  <Section class="pb-32">
    <Container>
      <Grid cols={1} colsMd={2} colsLg={3} gap={8}>
        {allPlatforms.map((p) => {
          const count = countMap.get(p.data.id) ?? 0;
          return (
            <Card variant="raised" padding="none" class="group overflow-hidden flex flex-col h-full">
              <div class="p-8 flex flex-col flex-grow">
                <div class="flex items-center justify-between mb-6">
                  <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/5 text-primary border border-primary/10 shadow-sm group-hover:bg-primary group-hover:text-primary-foreground transition-all duration-300">
                    <Icon name={p.data.icon as any} size={28} />
                  </div>
                  {p.data.official ? (
                    <Badge tone="success" size="sm" class="shadow-sm">Official app</Badge>
                  ) : (
                    <Badge tone="neutral" size="sm" class="shadow-sm">Manual setup</Badge>
                  )}
                </div>
                
                <Heading level={2} class="text-2xl font-bold group-hover:text-primary transition-colors">
                  {p.data.name}
                </Heading>
                
                <div class="mt-4">
                  <Badge tone={count > 0 ? "primary" : "neutral"} size="sm" class="font-bold">
                    {count} {count === 1 ? "provider" : "providers"}
                  </Badge>
                </div>
                
                <div class="mt-auto pt-8">
                  <Button variant="glass" size="sm" href={platformHref(p.data.slug)} class="w-full rounded-xl">
                    View Providers
                  </Button>
                </div>
              </div>
            </Card>
          );
        })}
      </Grid>
    </Container>
  </Section>

  <Section class="bg-surface-sunken/30 py-32">
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 text-primary border border-primary/20 shadow-sm mb-8">
          <Icon name="monitor-smartphone" size={32} />
        </div>
        <Heading level={2} class="text-3xl font-black tracking-tight md:text-4xl">Cross-Platform Protection</Heading>
        <Text size="lg" tone="muted" class="mt-6 leading-relaxed">
          The best VPNs offer seamless protection across all your devices. Whether you need a VPN for Windows gaming, Linux privacy, or streaming on Android TV, platform support matters more than server count.
        </Text>
      </div>
    </Container>
  </Section>
</SeoLayout>

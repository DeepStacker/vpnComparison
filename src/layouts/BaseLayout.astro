---
/**
 * BaseLayout — the root HTML shell.
 *
 * Owns <html>/<head>/<body> scaffolding, site-wide metadata, the no-flash
 * theme script, the skip link, and slots for page-level JSON-LD. It does NOT
 * include the header/footer chrome — that's added by <SeoLayout>, so special
 * pages (e.g. legal/standalone tools) can opt out of chrome by using this.
 *
 * @prop seo - page SEO metadata (title, description, canonical, ...).
 * @prop jsonLd - additional page-level structured-data nodes.
 * @prop lang - document language (defaults to site locale).
 * @prop bodyClass - classes for <body>.
 */
import "@/styles/global.css";
import Meta from "@/components/seo/Meta.astro";
import JsonLd from "@/components/seo/JsonLd.astro";
import ThemeScript from "@/components/seo/ThemeScript.astro";
import SkipLink from "@/components/layout/SkipLink.astro";
import SearchDialog from "@/components/search/SearchDialog.astro";
import KeyboardShortcuts from "@/components/ui/KeyboardShortcuts.astro";
import { SITE } from "@/constants/site";
import { organizationJsonLd, websiteJsonLd } from "@/lib/schema/jsonld";
import { normalizeSeoMeta } from "@/lib/seo/meta";
import type { JsonLdNode } from "@/types/seo";
import type { SeoMeta } from "@/types/seo";

interface Props {
  seo: SeoMeta;
  jsonLd?: JsonLdNode | JsonLdNode[];
  lang?: string;
  bodyClass?: string;
}

const { seo, jsonLd, lang = SITE.locale, bodyClass } = Astro.props;
const meta = normalizeSeoMeta(seo);
const path = Astro.url.pathname;
const siteJsonLd: JsonLdNode[] = [organizationJsonLd(), websiteJsonLd()];
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; font-src 'self'" />
    <ThemeScript defaultTheme="system" />
    <Meta meta={meta} path={path} />
    <JsonLd data={siteJsonLd} />
    {pageJsonLd.length > 0 && <JsonLd data={pageJsonLd} />}
  </head>
  <body class={bodyClass}>
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden bg-ambient-glow" aria-hidden="true">
      <!-- Primary orb — top-left, slow drift -->
      <div class="bg-ambient-glow-orb -top-[10%] -left-[8%] h-[45%] w-[45%] bg-brand-500/20 dark:bg-brand-500/25 animate-float-slow"></div>
      <!-- Secondary orb — right side, medium drift -->
      <div class="bg-ambient-glow-orb top-[25%] -right-[12%] h-[55%] w-[50%] bg-brand-400/15 dark:bg-brand-600/20 animate-float-medium"></div>
      <!-- Tertiary orb — bottom-left, slow drift -->
      <div class="bg-ambient-glow-orb -bottom-[12%] left-[12%] h-[50%] w-[45%] bg-brand-300/15 dark:bg-brand-400/20 animate-float-slow"></div>
      <!-- Quaternary orb — center, very subtle -->
      <div class="bg-ambient-glow-orb top-[40%] left-[35%] h-[30%] w-[30%] bg-primary/10 dark:bg-primary/15 animate-float-medium" style="animation-delay: -8s;"></div>
    </div>
    <SkipLink />
    <slot />
    <SearchDialog />
    <KeyboardShortcuts />
  </body>
</html>

---
/**
 * Card — surface container for grouped content.
 * @prop variant - "default" (flat + border) | "raised" (shadow) | "outline" (border only).
 * @prop padding - "none" | "sm" | "md" (default) | "lg".
 * @prop href - makes the whole card a link (renders <a>).
 * @prop radius - corner radius scale.
 * Slots: default, "header", "footer".
 */
import { cx } from "@/lib/utils/string";
import { radiusClass } from "./maps";

interface Props {
  variant?: "default" | "raised" | "outline" | "glass" | "glass-subtle" | "glass-strong";
  padding?: "none" | "sm" | "md" | "lg";
  href?: string;
  radius?: keyof typeof radiusClass;
  element?: "div" | "article" | "li" | "section";
  class?: string;
}

const {
  variant = "default",
  padding = "md",
  href,
  radius = "lg",
  element: Tag = "div",
  class: className,
} = Astro.props;

const variantClass: Record<string, string> = {
  default: "bg-surface border border-border shadow-sm",
  raised: "bg-surface border border-border shadow-md",
  outline: "bg-transparent border border-border-strong",
  glass: "bg-glass border border-glass-border shadow-glass-inner",
  "glass-subtle": "bg-glass-subtle border border-glass-subtle-border shadow-glass-inner",
  "glass-strong": "bg-glass-strong border border-glass-strong-border shadow-glass-inner",
};

const padClass: Record<string, string> = {
  none: "p-0",
  sm: "p-4",
  md: "p-6",
  lg: "p-8",
};

const isInteractive = Boolean(href);

const classes = cx(
  variantClass[variant],
  padClass[padding],
  radiusClass[radius],
  "transition-all duration-300 ease-standard",
  isInteractive &&
    "hover:-translate-y-1 hover:shadow-xl hover:border-primary/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2",
  className,
);

const Element = href ? "a" : Tag;
---

<Element href={href} class={classes}>
  <slot name="header" />
  <slot />
  <slot name="footer" />
</Element>

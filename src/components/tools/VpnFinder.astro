---
interface VpnFinderProvider {
  id: string; slug: string; name: string; tagline: string;
  serverNetwork: { serverCount: number; countryCount: number; countries: string[]; virtualLocations: boolean };
  protocols: string[]; platforms: string[]; features: string[];
  streaming: Array<{ service: string; support: string; verifiedAt?: string }>;
  torrenting: { supported: boolean; labeledServers: boolean; rating?: number };
  loggingPolicy: string; jurisdiction: string;
  pricing: { currency: string; plans: Array<{ cycle: string; price: number; effectiveMonthly: number; featured?: boolean }>; freeTier: boolean };
  audits: Array<{ auditor: string; independent: boolean }>;
  killSwitch: boolean; multiHop: boolean; splitTunneling: boolean;
  adBlocker: boolean; dedicatedIp: boolean; simultaneousConnections: number;
}

interface VpnFinderReview {
  providerId: string;
  scores: {
    privacy: number; security: number; performance: number; streaming: number;
    torrenting: number; easeOfUse: number; value: number; overall: number;
  };
  verdict: { headline: string; summary: string; recommendation: string };
}

interface Props {
  providers: VpnFinderProvider[];
  reviews: VpnFinderReview[];
  featureNames: Record<string, string>;
  protocolNames: Record<string, string>;
  platformNames: Record<string, string>;
  streamingNames: Record<string, string>;
  countryNames: Record<string, string>;
}

const { providers, reviews, streamingNames, countryNames } = Astro.props;
---

<div id="vpn-finder-root" class="mx-auto max-w-3xl">
  <div id="finder-step-indicator" class="mb-8 flex items-center gap-2"></div>
  <div id="finder-content"></div>
</div>

<script is:inline type="application/json" id="finder-data" set:html={JSON.stringify(providers)}></script>
<script is:inline type="application/json" id="finder-reviews-data" set:html={JSON.stringify(reviews)}></script>
<script is:inline type="application/json" id="finder-streaming-names" set:html={JSON.stringify(streamingNames)}></script>
<script is:inline type="application/json" id="finder-country-names" set:html={JSON.stringify(countryNames)}></script>

<script>
  interface Provider {
    id: string;
    slug: string;
    name: string;
    tagline: string;
    serverNetwork: { serverCount: number; countryCount: number; countries: string[]; virtualLocations: boolean };
    protocols: string[];
    platforms: string[];
    features: string[];
    streaming: Array<{ service: string; support: string; verifiedAt?: string }>;
    torrenting: { supported: boolean; labeledServers: boolean; rating?: number };
    loggingPolicy: string;
    jurisdiction: string;
    pricing: { currency: string; plans: Array<{ cycle: string; price: number; effectiveMonthly: number; featured?: boolean }>; freeTier: boolean };
    audits: Array<{ auditor: string; independent: boolean }>;
    killSwitch: boolean;
    multiHop: boolean;
    splitTunneling: boolean;
    adBlocker: boolean;
    dedicatedIp: boolean;
    simultaneousConnections: number;
  }

  interface ReviewData {
    providerId: string;
    scores: {
      privacy: number; security: number; performance: number; streaming: number;
      torrenting: number; easeOfUse: number; value: number; overall: number;
    };
    verdict: { headline: string; summary: string; recommendation: string };
  }

  const allProviders: Provider[] = JSON.parse(document.getElementById("finder-data")!.textContent);
  const allReviews: ReviewData[] = JSON.parse(document.getElementById("finder-reviews-data")!.textContent);

  const reviewMap = new Map(allReviews.map((r) => [r.providerId, r]));

  const steps = [
    { id: "goal", question: "What do you need a VPN for?", type: "multi", options: [
      { value: "streaming", label: "Streaming (Netflix, Disney+, etc.)" },
      { value: "privacy", label: "Privacy & security" },
      { value: "torrenting", label: "Torrenting" },
      { value: "bypass", label: "Bypass censorship" },
      { value: "gaming", label: "Gaming" },
      { value: "general", label: "General browsing" },
    ]},
    { id: "budget", question: "What's your budget?", type: "single", options: [
      { value: "budget", label: "Under $3/month" },
      { value: "mid", label: "$3–$6/month" },
      { value: "premium", label: "$6–$10/month" },
      { value: "any", label: "No preference" },
    ]},
    { id: "platform", question: "Which platforms matter most?", type: "multi", options: [
      { value: "windows", label: "Windows" }, { value: "macos", label: "macOS" },
      { value: "linux", label: "Linux" }, { value: "android", label: "Android" },
      { value: "ios", label: "iPhone/iPad" }, { value: "router", label: "Router" },
    ]},
    { id: "privacy", question: "Privacy requirements?", type: "multi", options: [
      { value: "no-logs", label: "No-logs policy" },
      { value: "audits", label: "Independent audits" },
      { value: "privacy-jurisdiction", label: "Privacy-friendly jurisdiction" },
      { value: "open-source", label: "Open-source apps" },
    ]},
    { id: "streaming", question: "Which streaming services do you use?", type: "multi", options: [
      { value: "netflix", label: "Netflix" }, { value: "disney-plus", label: "Disney+" },
      { value: "prime-video", label: "Amazon Prime Video" }, { value: "hbo-max", label: "HBO Max" },
      { value: "hulu", label: "Hulu" }, { value: "bbc-iplayer", label: "BBC iPlayer" },
    ]},
  ];

  const privacyFriendlyJurisdictions = ["CH", "IS", "SE", "NL", "RO", "EE", "DK", "NO"];

  interface Answers {
    goal: string[];
    budget: string;
    platform: string[];
    privacy: string[];
    streaming: string[];
  }

  let currentStep = 0;
  let answers: Answers = {
    goal: [], budget: "", platform: [], privacy: [], streaming: [],
  };

  const indicator = document.getElementById("finder-step-indicator")!;
  const content = document.getElementById("finder-content")!;

  function render() {
    renderStepIndicator();
    if (currentStep < steps.length) {
      renderStep();
    } else {
      renderResults();
    }
  }

  function renderStepIndicator() {
    indicator.textContent = "";
    for (let i = 0; i < steps.length; i++) {
      const dot = document.createElement("div");
      dot.className =
        "h-2 rounded-full transition-all duration-500 " +
        (i === currentStep
          ? "w-12 bg-primary shadow-[0_0_15px_rgba(var(--primary-rgb),0.4)]"
          : i < currentStep
            ? "w-2 bg-primary/40"
            : "w-2 bg-border");
      indicator.appendChild(dot);
    }
  }

  function renderStep() {
    const step = steps[currentStep]!;
    content.innerHTML = "";

    const heading = document.createElement("h2");
    heading.className = "text-3xl font-black tracking-tight mb-2 text-foreground";
    heading.textContent = step.question;
    content.appendChild(heading);

    const stepNum = document.createElement("p");
    stepNum.className = "text-sm font-bold uppercase tracking-widest text-muted-foreground mb-10";
    stepNum.textContent = `Step ${currentStep + 1} of ${steps.length}`;
    content.appendChild(stepNum);

    const optionsContainer = document.createElement("div");
    optionsContainer.className = "grid gap-4 sm:grid-cols-2";

    const currentAnswers = answers[step.id as keyof Answers] as string[] | string;

    for (const opt of step.options) {
      const label = document.createElement("label");
      label.className =
        "group flex cursor-pointer items-center gap-4 rounded-2xl border border-border bg-surface p-5 transition-all duration-300 hover:border-primary/30 hover:shadow-lg has-[:checked]:border-primary has-[:checked]:bg-primary/5 has-[:checked]:shadow-md hover:-translate-y-0.5";

      const input = document.createElement("input");
      input.type = step.type === "single" ? "radio" : "checkbox";
      input.name = step.id;
      input.value = opt.value;
      input.className = "h-5 w-5 accent-primary shrink-0";

      if (step.type === "single") {
        if (currentAnswers === opt.value) input.checked = true;
      } else {
        if ((currentAnswers as string[]).includes(opt.value)) input.checked = true;
      }

      input.addEventListener("change", () => handleInput(step.id, step.type, input));
      label.appendChild(input);

      const span = document.createElement("span");
      span.className = "text-base font-bold text-foreground group-hover:text-primary transition-colors";
      span.textContent = opt.label;
      label.appendChild(span);

      optionsContainer.appendChild(label);
    }
    content.appendChild(optionsContainer);

    const btnRow = document.createElement("div");
    btnRow.className = "mt-12 flex items-center justify-between gap-4 pt-8 border-t border-border";

    if (currentStep > 0) {
      const back = document.createElement("button");
      back.type = "button";
      back.className =
        "rounded-xl border border-border bg-surface px-6 py-3 text-sm font-bold text-foreground transition-all duration-200 hover:bg-surface-raised hover:border-border-strong shadow-sm";
      back.textContent = "Back";
      back.addEventListener("click", () => {
        currentStep--;
        render();
      });
      btnRow.appendChild(back);
    } else {
      const spacer = document.createElement("div");
      btnRow.appendChild(spacer);
    }

    const next = document.createElement("button");
    next.type = "button";
    next.className =
      "rounded-xl bg-primary px-8 py-3 text-sm font-black uppercase tracking-widest text-primary-foreground transition-all duration-200 hover:brightness-110 disabled:opacity-30 disabled:cursor-not-allowed shadow-lg hover:-translate-y-0.5";
    next.textContent = currentStep === steps.length - 1 ? "See Results" : "Next Step";
    const ans = answers[step.id as keyof Answers] as string[] | string;
    next.disabled = step.type === "single" ? !ans : (ans as string[]).length === 0;
    next.addEventListener("click", () => {
      if (next.disabled) return;
      currentStep++;
      render();
    });
    btnRow.appendChild(next);

    content.appendChild(btnRow);
  }

  function handleInput(stepId: string, type: string, input: HTMLInputElement) {
    if (type === "single") {
      (answers as any)[stepId] = input.value;
    } else {
      const arr = answers[stepId as keyof Answers] as string[];
      if (input.checked) {
        arr.push(input.value);
      } else {
        const idx = arr.indexOf(input.value);
        if (idx >= 0) arr.splice(idx, 1);
      }
    }
    render();
  }

  /* ---------- Scoring ---------- */
  interface ScoreDetail {
    label: string;
    score: number;
    max: number;
    explanation: string;
  }

  interface ScoredProvider {
    provider: Provider;
    totalScore: number;
    details: ScoreDetail[];
    review?: ReviewData;
  }

  function scoreProviders(): ScoredProvider[] {
    return allProviders.map((p) => {
      const review = reviewMap.get(p.id);
      const details: ScoreDetail[] = [];
      let totalScore = 0;
      let totalWeight = 0;

      const goalAns = answers.goal;

      /* Goal: streaming */
      if (goalAns.includes("streaming") || goalAns.includes("general")) {
        const streamingScore = scoreStreaming(p);
        details.push({
          label: "Streaming support",
          score: streamingScore,
          max: 100,
          explanation: streamingScore >= 80
            ? "Works with most major streaming services."
            : streamingScore >= 40
              ? "Works with some streaming services."
              : "Limited streaming support.",
        });
        totalScore += streamingScore * 3;
        totalWeight += 3;
      }

      /* Goal: privacy */
      if (goalAns.includes("privacy")) {
        const privScore = scorePrivacy(p);
        details.push({
          label: "Privacy protection",
          score: privScore,
          max: 100,
          explanation: privScore >= 80
            ? "Strong privacy protections with no-logs policy and independent audits."
            : privScore >= 50
              ? "Good privacy features, but some concerns."
              : "Limited privacy safeguards.",
        });
        totalScore += privScore * 3;
        totalWeight += 3;
      }

      /* Goal: torrenting */
      if (goalAns.includes("torrenting")) {
        const torrScore = p.torrenting.supported ? 80 : 0;
        details.push({
          label: "Torrenting support",
          score: torrScore,
          max: 100,
          explanation: torrScore >= 80
            ? "Supports P2P/torrenting with labeled servers."
            : "Does not support or discourage torrenting.",
        });
        totalScore += torrScore * 2;
        totalWeight += 2;
      }

      /* Goal: bypass censorship */
      if (goalAns.includes("bypass")) {
        const bypassScore = scoreBypass(p);
        details.push({
          label: "Censorship bypass",
          score: bypassScore,
          max: 100,
          explanation: bypassScore >= 70
            ? "Strong obfuscation and multi-hop features for bypassing restrictions."
            : bypassScore >= 40
              ? "Some obfuscation capabilities."
              : "Limited censorship circumvention.",
        });
        totalScore += bypassScore * 2;
        totalWeight += 2;
      }

      /* Goal: gaming */
      if (goalAns.includes("gaming")) {
        const perfScore = review ? review.scores.performance * 10 : 50;
        details.push({
          label: "Performance for gaming",
          score: perfScore,
          max: 100,
          explanation: perfScore >= 75
            ? "Excellent performance with low latency."
            : perfScore >= 50
              ? "Adequate for casual gaming."
              : "May not be ideal for gaming.",
        });
        totalScore += perfScore * 2;
        totalWeight += 2;
      }

      /* Budget */
      if (answers.budget && answers.budget !== "any") {
        const budgetScore = scoreBudget(p, answers.budget);
        details.push({
          label: "Pricing",
          score: budgetScore,
          max: 100,
          explanation: budgetScore >= 80
            ? "Fits within your budget."
            : budgetScore >= 40
              ? "Slightly above your target budget."
              : "Above your target budget.",
        });
        totalScore += budgetScore * 2;
        totalWeight += 2;
      }

      /* Platform match */
      if (answers.platform.length > 0) {
        const platScore = scorePlatforms(p, answers.platform);
        details.push({
          label: "Platform support",
          score: platScore,
          max: 100,
          explanation: platScore >= 80
            ? "Supports all your platforms."
            : platScore >= 40
              ? "Supports most of your platforms."
              : "Limited platform support for your needs.",
        });
        totalScore += platScore * 2;
        totalWeight += 2;
      }

      /* Privacy requirements */
      if (answers.privacy.length > 0) {
        const privReqScore = scorePrivacyRequirements(p, answers.privacy);
        details.push({
          label: "Privacy requirements",
          score: privReqScore,
          max: 100,
          explanation: privReqScore >= 80
            ? "Meets all your privacy requirements."
            : privReqScore >= 40
              ? "Meets some privacy requirements."
              : "Few privacy requirements met.",
        });
        totalScore += privReqScore * 2;
        totalWeight += 2;
      }

      /* Streaming services */
      if (answers.streaming.length > 0) {
        const svcScore = scoreStreamingServices(p, answers.streaming);
        details.push({
          label: "Streaming service compatibility",
          score: svcScore,
          max: 100,
          explanation: svcScore >= 80
            ? "Verified to work with all your streaming services."
            : svcScore >= 40
              ? "Works with some of your streaming services."
              : "Limited or no streaming service compatibility.",
        });
        totalScore += svcScore * 2;
        totalWeight += 2;
      }

      /* Overall review score */
      if (review) {
        const overallScore = review.scores.overall * 10;
        details.push({
          label: "Overall rating",
          score: overallScore,
          max: 100,
          explanation: `Rated ${review.scores.overall.toFixed(1)}/10 by our reviewers.`,
        });
        totalScore += overallScore * 1;
        totalWeight += 1;
      }

      const finalScore = totalWeight > 0 ? Math.round(totalScore / totalWeight) : 50;

      return { provider: p, totalScore: finalScore, details, review };
    }).sort((a, b) => b.totalScore - a.totalScore);
  }

  function scoreStreaming(p: Provider): number {
    const svcs = p.streaming.filter((s) => s.support === "verified");
    return Math.min(100, svcs.length * 20);
  }

  function scorePrivacy(p: Provider): number {
    let score = 0;
    if (p.loggingPolicy === "no-logs") score += 40;
    else if (p.loggingPolicy === "minimal") score += 20;
    if (p.audits.some((a) => a.independent)) score += 30;
    if (privacyFriendlyJurisdictions.includes(p.jurisdiction)) score += 20;
    if (p.killSwitch) score += 10;
    return Math.min(100, score);
  }

  function scoreBypass(p: Provider): number {
    let score = 0;
    if (p.features.includes("obfuscation")) score += 30;
    if (p.multiHop) score += 30;
    if (p.protocols.includes("wireguard")) score += 20;
    if (p.serverNetwork.countryCount > 50) score += 20;
    return Math.min(100, score);
  }

  function scoreBudget(p: Provider, budget: string): number {
    const minMonthly = Math.min(...p.pricing.plans.map((pl) => pl.effectiveMonthly));
    const limits: Record<string, number> = { budget: 3, mid: 6, premium: 10 };
    const limit = limits[budget] ?? 999;
    if (minMonthly <= limit) return 100;
    if (minMonthly <= limit * 1.5) return 60;
    return 20;
  }

  function scorePlatforms(p: Provider, selected: string[]): number {
    let matchCount = 0;
    for (const plat of selected) {
      if (p.platforms.includes(plat)) matchCount++;
    }
    return Math.round((matchCount / selected.length) * 100);
  }

  function scorePrivacyRequirements(p: Provider, selected: string[]): number {
    let matchCount = 0;
    for (const req of selected) {
      if (req === "no-logs" && p.loggingPolicy === "no-logs") matchCount++;
      else if (req === "audits" && p.audits.length > 0) matchCount++;
      else if (req === "privacy-jurisdiction" && privacyFriendlyJurisdictions.includes(p.jurisdiction)) matchCount++;
      else if (req === "open-source" && p.protocols.includes("wireguard")) matchCount++;
    }
    return Math.round((matchCount / selected.length) * 100);
  }

  function scoreStreamingServices(p: Provider, selected: string[]): number {
    let matchCount = 0;
    for (const svc of selected) {
      const match = p.streaming.find((s) => s.service === svc);
      if (match && match.support === "verified") matchCount++;
      else if (match && match.support === "partial") matchCount += 0.5;
    }
    return Math.round((matchCount / selected.length) * 100);
  }

  /* ---------- Results ---------- */
  function renderResults() {
    const scored = scoreProviders();

    content.innerHTML = "";
    const top = scored[0];
    const confidence = computeFinderConfidence(scored);
    const risks = computeFinderRisks(scored);
    const actions = computeFinderActions(scored);

    const exec = document.createElement("div");
    exec.className =
      "mb-12 rounded-3xl border border-primary/20 bg-primary/5 p-8 shadow-sm";
    exec.innerHTML = `
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
        <div class="min-w-0">
          <p class="text-sm font-bold uppercase tracking-widest text-muted-foreground">Executive Summary</p>
          <h3 class="mt-2 text-2xl font-black tracking-tight">Recommended: ${escapeHtml(top?.provider.name ?? "—")}</h3>
          <p class="mt-3 text-base text-muted-foreground leading-relaxed max-w-2xl">
            Your answers map to privacy, performance, and compatibility criteria. Below is a ranked shortlist with category-level explanations, risks, and next steps.
          </p>
        </div>

        <div class="shrink-0 flex items-start gap-4">
          <!-- Radar chart placeholder -->
          <div class="rounded-2xl border border-primary/30 bg-primary/10 p-5">
            <p class="text-sm font-bold uppercase tracking-widest text-muted-foreground">Confidence</p>
            <div class="mt-2 flex items-baseline gap-2">
              <span class="text-4xl font-black tracking-tighter text-primary">${confidence}%</span>
              <span class="text-xs font-bold uppercase tracking-widest text-muted-foreground">demo</span>
            </div>
            <p class="mt-2 text-sm text-muted-foreground leading-relaxed">Higher confidence means more of your selected criteria are strongly supported.</p>
          </div>
        </div>
      </div>

      <!-- Score distribution chart -->
      <div class="mt-8 rounded-2xl border border-border/50 bg-surface p-6" id="finder-score-chart-container">
        <p class="text-sm font-bold uppercase tracking-widest text-muted-foreground mb-4">Match Score Distribution</p>
        <div id="finder-score-chart" style="height:120px"></div>
      </div>

      <div class="mt-6 grid gap-6 lg:grid-cols-3">
        <div class="rounded-2xl border border-border/50 bg-surface p-6">
          <p class="text-sm font-bold uppercase tracking-widest text-muted-foreground">Key Findings</p>
          <ul class="mt-4 space-y-3 text-sm text-foreground/90">
            ${renderFinderKeyFindings(scored)}
          </ul>
        </div>

        <div class="rounded-2xl border border-border/50 bg-surface p-6">
          <p class="text-sm font-bold uppercase tracking-widest text-muted-foreground">Potential Risks</p>
          <div class="mt-4 space-y-3">
            ${risks
              .map(
                (r) => `
                <div class="rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
                  <div class="flex items-center justify-between gap-3">
                    <p class="text-sm font-black text-foreground">${escapeHtml(r.title)}</p>
                    <span class="text-xs font-bold uppercase tracking-widest ${r.severity === "High" ? "text-warning" : r.severity === "Medium" ? "text-primary" : "text-success"}">${escapeHtml(r.severity)}</span>
                  </div>
                  <p class="mt-2 text-sm text-muted-foreground leading-relaxed">${escapeHtml(r.detail)}</p>
                </div>
              `,
              )
              .join("")}
          </div>
        </div>

        <div class="rounded-2xl border border-border/50 bg-surface p-6">
          <p class="text-sm font-bold uppercase tracking-widest text-muted-foreground">Recommended Actions</p>
          <div class="mt-4 space-y-3">
            ${actions
              .map(
                (a) => `
                <div class="rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
                  <p class="text-sm font-black text-foreground">${escapeHtml(a.action)}</p>
                  <p class="mt-2 text-sm text-muted-foreground leading-relaxed">${escapeHtml(a.rationale)}</p>
                </div>
              `,
              )
              .join("")}
          </div>
        </div>
      </div>
    `;

    // Render match score bar chart
    requestAnimationFrame(function() {
      var chartEl2 = document.getElementById("finder-score-chart");
      if (!chartEl2) return;
      var maxScore = 0;
      for (var si = 0; si < scored.length; si++) {
        var s = scored[si];
        if (s && s.totalScore > maxScore) maxScore = s.totalScore;
      }
      if (maxScore < 1) maxScore = 1;
      var htmlBar = '<div class="flex items-end justify-between gap-1" style="height:120px">';
      var count = Math.min(scored.length, 6);
      for (var si2 = 0; si2 < count; si2++) {
        var sr = scored[si2];
        if (!sr) break;
        var pct = (sr.totalScore / maxScore) * 100;
        var color = si2 === 0 ? 'var(--color-success)' : 'var(--color-primary)';
        htmlBar += '<div class="flex flex-col items-center flex-1 h-full justify-end">';
        htmlBar += '<span class="text-[9px] font-bold text-muted-foreground mb-1">' + sr.totalScore + '%</span>';
        htmlBar += '<div class="w-full rounded-t-md transition-all duration-700 ease-out" style="height:' + pct + '%;background:' + color + ';min-height:4px" title="' + escapeHtml(sr.provider.name) + ': ' + sr.totalScore + '%"></div>';
        htmlBar += '<span class="mt-1 text-[9px] font-bold text-muted-foreground truncate w-full text-center">' + escapeHtml(sr.provider.name.slice(0, 10)) + '</span>';
        htmlBar += '</div>';
      }
      htmlBar += '</div>';
      chartEl2.innerHTML = htmlBar;
    });

    content.appendChild(exec);

    const summary = document.createElement("div");
    summary.className = "mb-12 text-center";
    summary.innerHTML = `
      <h2 class="text-3xl font-black tracking-tight">Your VPN Recommendations</h2>
      <p class="mt-4 text-lg text-muted-foreground max-w-2xl mx-auto leading-relaxed">
        Based on your answers, here are the VPNs ranked by how well they match your specific requirements.
      </p>
    `;
    content.appendChild(summary);

    for (const [index, result] of scored.entries()) {
      const p = result.provider;
      const review = result.review;

      const card = document.createElement("div");
      card.className =
        "mb-8 rounded-3xl border border-border bg-surface p-8 shadow-sm transition-all duration-300 hover:shadow-xl hover:border-primary/30";

      const rankEmoji = index === 0 ? "🏆" : index === 1 ? "🥈" : index === 2 ? "🥉" : `#${index + 1}`;

      card.innerHTML = `
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
          <div class="flex items-center gap-6">
            <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-surface-sunken border border-border shadow-inner text-2xl">
              ${rankEmoji}
            </div>
            <div class="min-w-0">
              <h3 class="text-2xl font-black tracking-tight text-foreground">${escapeHtml(p.name)}</h3>
              <p class="mt-1 text-base text-muted-foreground leading-relaxed">${escapeHtml(p.tagline)}</p>
            </div>
          </div>
          <div class="shrink-0 flex flex-col items-center md:items-end">
            <div class="text-4xl font-black text-primary tracking-tighter">${result.totalScore}%</div>
            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground mt-1">Match Score</p>
          </div>
        </div>
      `;

      const scoreBar = document.createElement("div");
      scoreBar.className = "mt-8 h-3 w-full rounded-full bg-surface-sunken border border-border/50 overflow-hidden shadow-inner";
      const fill = document.createElement("div");
      fill.className =
        "h-full rounded-full transition-all duration-1000 ease-out " +
        (result.totalScore >= 80 ? "bg-success" : result.totalScore >= 50 ? "bg-primary" : "bg-warning");
      fill.style.width = `${result.totalScore}%`;
      scoreBar.appendChild(fill);
      card.appendChild(scoreBar);

      const detailsDiv = document.createElement("div");
      detailsDiv.className = "mt-10 grid gap-6 sm:grid-cols-2";

      const breakdown = document.createElement("div");
      breakdown.className = "mb-8 flex flex-wrap gap-2";
      breakdown.innerHTML = result.details
        .slice(0, 4)
        .map((d) => {
          const tone = d.score >= 80 ? "text-success border-success/20 bg-success/10" : d.score >= 60 ? "text-primary border-primary/20 bg-primary/10" : "text-warning border-warning/20 bg-warning/10";
          return `<button type="button" class="finder-chip inline-flex items-center rounded-full border ${tone} px-3 py-1 text-xs font-bold uppercase tracking-widest" data-detail-label="${escapeHtml(d.label)}" aria-pressed="false">${escapeHtml(d.label)}: ${d.score}%</button>`;
        })
        .join("");
      card.appendChild(breakdown);

      for (const detail of result.details) {
        const detailCard = document.createElement("div");
        detailCard.className = "rounded-2xl bg-surface-sunken/50 border border-border/50 p-5";
        detailCard.dataset.detailLabel = detail.label;

        const header = document.createElement("div");
        header.className = "flex items-center justify-between mb-3";
        
        const labelSpan = document.createElement("span");
        labelSpan.className = "text-sm font-bold uppercase tracking-widest text-muted-foreground";
        labelSpan.textContent = detail.label;
        header.appendChild(labelSpan);

        const valSpan = document.createElement("span");
        valSpan.className =
          "text-sm font-black " +
          (detail.score >= 70 ? "text-success" : detail.score >= 40 ? "text-primary" : "text-warning");
        valSpan.textContent = `${detail.score}%`;
        header.appendChild(valSpan);
        
        detailCard.appendChild(header);

        const expl = document.createElement("p");
        expl.className = "text-sm text-foreground font-medium leading-relaxed";
        expl.textContent = detail.explanation;
        detailCard.appendChild(expl);

        detailsDiv.appendChild(detailCard);
      }

      // Chip toggle: highlight and reveal the matching detail card.
      const chipButtons = Array.from(breakdown.querySelectorAll<HTMLButtonElement>(".finder-chip"));
      for (const btn of chipButtons) {
        btn.addEventListener("click", () => {
          const label = btn.dataset.detailLabel ?? "";
          const pressed = btn.getAttribute("aria-pressed") === "true";

          for (const other of chipButtons) {
            other.setAttribute("aria-pressed", "false");
          }

          for (const el of Array.from(detailsDiv.querySelectorAll<HTMLElement>("[data-detail-label]"))) {
            el.style.display = "";
            el.style.borderColor = "";
          }

          if (!pressed) {
            btn.setAttribute("aria-pressed", "true");
            for (const el of Array.from(detailsDiv.querySelectorAll<HTMLElement>("[data-detail-label]"))) {
              if ((el.dataset.detailLabel ?? "") !== label) el.style.display = "none";
              else el.style.borderColor = "rgba(var(--primary-rgb), 0.45)";
            }
          }
        });
      }

      card.appendChild(detailsDiv);

      const nextSteps = document.createElement("div");
      nextSteps.className = "mt-8 rounded-2xl border border-border/50 bg-surface-sunken/40 p-5";
      nextSteps.innerHTML = `
        <p class="text-sm font-black text-foreground">Next step</p>
        <p class="mt-2 text-sm text-muted-foreground leading-relaxed">Start with the top recommendation, then validate streaming and privacy behavior on your devices. If you need a second option, compare the top two match scores.</p>
      `;
      card.appendChild(nextSteps);

      const ctaRow = document.createElement("div");
      ctaRow.className = "mt-10 flex flex-wrap items-center gap-4 pt-8 border-t border-border";

      const detailBtn = document.createElement("a");
      detailBtn.href = `/vpn/${p.slug}/`;
      detailBtn.className =
        "inline-flex items-center rounded-xl bg-primary px-6 py-3 text-sm font-black uppercase tracking-widest text-primary-foreground no-underline transition-all duration-200 hover:brightness-110 shadow-lg hover:-translate-y-0.5";
      detailBtn.textContent = "View Details";
      ctaRow.appendChild(detailBtn);

      if (review) {
        const reviewBtn = document.createElement("a");
        reviewBtn.href = `/vpn/${p.slug}/#review`;
        reviewBtn.className =
          "inline-flex items-center rounded-xl border border-border bg-surface px-6 py-3 text-sm font-bold text-foreground no-underline transition-all duration-200 hover:bg-surface-raised hover:border-border-strong shadow-sm hover:-translate-y-0.5";
        reviewBtn.textContent = "Read Review";
        ctaRow.appendChild(reviewBtn);
      }

      card.appendChild(ctaRow);

      content.appendChild(card);
    }

    const restartDiv = document.createElement("div");
    restartDiv.className = "mt-16 text-center pt-12 border-t border-border";

    const restartBtn = document.createElement("button");
    restartBtn.type = "button";
    restartBtn.className =
      "rounded-xl border border-border bg-surface px-8 py-3 text-sm font-bold text-foreground transition-all duration-200 hover:bg-surface-raised hover:border-border-strong shadow-sm";
    restartBtn.textContent = "Start Over";
    restartBtn.addEventListener("click", () => {
      answers = { goal: [], budget: "", platform: [], privacy: [], streaming: [] };
      currentStep = 0;
      render();
    });
    restartDiv.appendChild(restartBtn);
    content.appendChild(restartDiv);

    const methodologyP = document.createElement("p");
    methodologyP.className = "mt-6 text-sm text-muted-foreground font-medium";
    methodologyP.innerHTML =
      'Recommendations are based on our structured provider data. <a href="/methodology/" class="text-primary font-bold no-underline hover:underline underline-offset-4">Learn how we score providers &rarr;</a>';
    content.appendChild(methodologyP);
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function computeFinderConfidence(scored: ScoredProvider[]): number {
    const top = scored[0];
    if (!top) return 60;
    const spread = top.totalScore - (scored[1]?.totalScore ?? top.totalScore);
    const base = Math.round(55 + (top.totalScore / 100) * 35);
    const bonus = Math.min(15, Math.max(0, spread));
    return Math.max(55, Math.min(98, base + bonus));
  }

  function computeFinderRisks(scored: ScoredProvider[]): Array<{ title: string; detail: string; severity: "Low" | "Medium" | "High" }> {
    const top = scored[0];
    const risks: Array<{ title: string; detail: string; severity: "Low" | "Medium" | "High" }> = [];
    if (!top) return risks;

    const privacyDetail = top.details.find((d) => d.label.toLowerCase().includes("privacy"));
    if (privacyDetail && privacyDetail.score < 60) {
      risks.push({
        title: "Privacy fit may be uneven",
        detail: "Your top match is strong overall, but privacy category support is not uniformly high. Validate no-logs behavior and audit coverage for your threat model.",
        severity: "Medium",
      });
    } else {
      risks.push({
        title: "Privacy coverage looks strong",
        detail: "Privacy-related criteria are well supported in the top recommendation based on this dataset.",
        severity: "Low",
      });
    }

    const streamingDetail = top.details.find((d) => d.label.toLowerCase().includes("streaming"));
    if (streamingDetail && streamingDetail.score < 60) {
      risks.push({
        title: "Streaming compatibility needs validation",
        detail: "Streaming support is present but not consistently high. Test your specific services and peak-hour performance before committing.",
        severity: "Medium",
      });
    } else {
      risks.push({
        title: "Streaming compatibility is likely",
        detail: "Streaming-related criteria are supported strongly in the top recommendation for the selected services.",
        severity: "Low",
      });
    }

    risks.push({
      title: "Device and usage constraints",
      detail: "Even strong VPNs can underperform if device limits or simultaneous connections don’t match your household or workflow. Confirm device limits and router support.",
      severity: "Low",
    });

    return risks.slice(0, 3);
  }

  function computeFinderActions(scored: ScoredProvider[]): Array<{ action: string; rationale: string }> {
    const top = scored[0];
    const second = scored[1];
    if (!top) return [];

    const actions: Array<{ action: string; rationale: string }> = [
      {
        action: "Validate on your primary device",
        rationale: "Start with the top recommendation and test connection stability, streaming behavior, and privacy settings on your main device.",
      },
      {
        action: "Compare the top two match scores",
        rationale: "If you need a backup, the second-best match often covers edge cases (streaming vs. privacy vs. usability).",
      },
      {
        action: "Confirm plan economics",
        rationale: "Check effective monthly pricing and any money-back terms before committing to a longer cycle.",
      },
    ];

    if (second && top.totalScore - second.totalScore < 8) {
      actions[1] = {
        action: "Both top options are close",
        rationale: "The top two providers are within a narrow margin. Choose based on your highest-priority category (privacy vs. streaming vs. usability).",
      };
    }

    return actions;
  }

  function renderFinderKeyFindings(scored: ScoredProvider[]): string {
    const top = scored[0];
    const second = scored[1];
    if (!top) return "";

    const topPrivacy = top.details.find((d) => d.label.toLowerCase().includes("privacy"));
    const topStreaming = top.details.find((d) => d.label.toLowerCase().includes("streaming"));
    const topValue = top.details.find((d) => d.label.toLowerCase().includes("overall")) ?? top.details[0];

    return [
      `<li class="flex gap-3"><span class="mt-0.5 h-5 w-5 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center text-[10px] font-black text-primary">1</span><span>Privacy: ${escapeHtml(String(topPrivacy?.score ?? 0))}%</span></li>`,
      `<li class="flex gap-3"><span class="mt-0.5 h-5 w-5 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center text-[10px] font-black text-primary">2</span><span>Streaming: ${escapeHtml(String(topStreaming?.score ?? 0))}%</span></li>`,
      `<li class="flex gap-3"><span class="mt-0.5 h-5 w-5 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center text-[10px] font-black text-primary">3</span><span>Overall strength: ${escapeHtml(String(topValue?.score ?? top.totalScore))}% (runner-up: ${escapeHtml(second?.provider.name ?? "—")})</span></li>`,
    ].join("");
  }

  render();
</script>

---
interface Props {
  value: number;
  size?: number;
  strokeWidth?: number;
  label?: string;
  class?: string;
}

const { value, size = 80, strokeWidth = 6, label } = Astro.props;
const radius = (size - strokeWidth) / 2;
const circumference = 2 * Math.PI * radius;
const clamped = Math.min(10, Math.max(0, value));
const offset = circumference - (clamped / 10) * circumference;

// Use CSS custom properties so the ring responds to .dark theme automatically.
const colorVar =
  clamped >= 9 ? "var(--success)" : clamped >= 8 ? "var(--primary)" : clamped >= 6 ? "var(--warning)" : "var(--danger)";
const bgVar =
  clamped >= 9 ? "var(--success-surface)" : clamped >= 8 ? "var(--accent)" : clamped >= 6 ? "var(--warning-surface)" : "var(--danger-surface)";
---

<div class="inline-flex flex-col items-center gap-1">
  <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} role="img" aria-label={label ?? `${value.toFixed(1)} out of 10`}>
    <circle cx={size / 2} cy={size / 2} r={radius} fill="none" stroke={bgVar} stroke-width={strokeWidth} />
    <circle
      cx={size / 2} cy={size / 2} r={radius}
      fill="none" stroke={colorVar} stroke-width={strokeWidth}
      stroke-dasharray={circumference} stroke-dashoffset={offset}
      stroke-linecap="round"
      transform={`rotate(-90 ${size / 2} ${size / 2})`}
      class="transition-all motion-safe:duration-700 motion-safe:ease-emphasized"
    />
    <text x="50%" y="50%" text-anchor="middle" dominant-baseline="central" font-size={size * 0.28} font-weight="700" fill="currentColor">
      {value.toFixed(1)}
    </text>
  </svg>
  {label && <span class="text-xs font-medium text-muted-foreground">{label}</span>}
</div>

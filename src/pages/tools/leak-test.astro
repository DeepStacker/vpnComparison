---
import { getCollection } from "astro:content";
import ToolLayout from "@/layouts/ToolLayout.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Badge from "@/components/ui/Badge.astro";
import { normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import VpnLeakTest from "@/components/tools/VpnLeakTest.astro";
import type { Breadcrumb } from "@/types/site";

const allProviders = await getCollection("providers");
const allReviews = await getCollection("reviews");

const providers = allProviders.map((e) => ({
  id: e.data.id, slug: e.data.slug, name: e.data.name,
  features: e.data.features, protocols: e.data.protocols,
  killSwitch: e.data.killSwitch, splitTunneling: e.data.splitTunneling,
  loggingPolicy: e.data.loggingPolicy,
}));
const reviews = allReviews.map((e) => ({
  providerId: e.data.provider.id,
  scores: { privacy: e.data.scores.privacy, security: e.data.scores.security },
}));

const seo = normalizeSeoMeta({
  title: "Leak & Exposure Test — DNS, IPv6 & WebRTC Leak Simulation",
  description: "Simulate leak testing scenarios across providers. Test DNS, IPv6, and WebRTC leak protection with risk assessment and mitigation guidance.",
  canonical: canonicalUrl("/tools/leak-test/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "VPN Tools", href: "/tools/" },
  { label: "Leak Test", href: "/tools/leak-test/" },
];
---

<ToolLayout seo={seo} breadcrumbs={breadcrumbs}>
  <div class="mb-8 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <Badge tone="danger" class="mb-3">Security test</Badge>
      <Heading level={1} class="text-3xl font-black tracking-tight md:text-4xl">Leak & Exposure Test</Heading>
      <Text size="base" tone="muted" class="mt-2 max-w-2xl leading-relaxed">
        Simulate DNS, IPv6, and WebRTC leak testing against any provider. Each test includes risk assessment, severity ratings, and recommended mitigations.
      </Text>
    </div>
    <a href="/tools/" class="text-sm font-bold uppercase tracking-widest text-primary no-underline">← Back to tools</a>
  </div>

  <VpnLeakTest providers={providers} reviews={reviews} />
</ToolLayout>

---
import { getCollection } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Grid from "@/components/ui/Grid.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import { formatDate } from "@/lib/utils/date";
import type { Breadcrumb } from "@/types/site";

const allBestLists = await getCollection("best-lists");
const allAuthors = await getCollection("authors");
const authorMap = new Map(allAuthors.map((a) => [a.id, a.data.name]));

const seo = normalizeSeoMeta({
  title: buildTitle("Best VPN Lists — Curated Shortlists"),
  description: "Curated VPN shortlists for streaming, privacy, speed, torrenting, and budget. Expert-ranked lists updated for 2025.",
  canonical: canonicalUrl("/best-lists/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Best VPN Lists", href: "/best-lists/" },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section background>
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <Heading level={1}>Best VPN Lists</Heading>
        <Text tone="muted" size="lg" class="mt-3 max-w-prose mx-auto">
          Expert-curated shortlists for every need — streaming, privacy, speed, torrenting, and budget.
          Every entry is backed by hands-on testing and transparent criteria.
        </Text>
      </div>
    </Container>
  </Section>

  <Section>
    <Container>
      {allBestLists.length === 0 && (
        <div class="flex flex-col items-center justify-center rounded-lg border border-dashed border-border bg-surface-sunken/40 px-6 py-12 text-center">
          <Text tone="muted">No best lists published yet.</Text>
        </div>
      )}
      <Grid cols={1} colsMd={2} colsLg={3} gap={6}>
        {allBestLists.map((bl) => {
          const authorName = authorMap.get(bl.data.author.id);
          return (
            <Card variant="raised" padding="md">
              <div class="flex items-start justify-between gap-2">
                <Heading level={2} size="xl">{bl.data.title}</Heading>
              </div>
              <Text size="sm" tone="muted" class="mt-2">{bl.data.summary}</Text>
              <div class="mt-3 flex flex-wrap items-center gap-2">
                <Badge tone="neutral" size="sm">{bl.data.entries.length} entries</Badge>
                <Badge tone="primary" size="sm">{bl.data.category}</Badge>
              </div>
              <div class="mt-3 flex flex-wrap gap-3 text-xs text-muted-foreground">
                {authorName && <span>By {authorName}</span>}
                <span>{formatDate(bl.data.publishedAt)}</span>
              </div>
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/best-lists/${bl.id}/`}>View List</Button>
              </div>
            </Card>
          );
        })}
      </Grid>
    </Container>
  </Section>
</SeoLayout>

---
/**
 * Badge — compact status/label indicator with a filled tone background.
 * @prop tone - "neutral" | "primary" | "success" | "warning" | "danger" | "info".
 * @prop size - "sm" | "md".
 */
import { cx } from "@/lib/utils/string";

interface Props {
  tone?: "neutral" | "primary" | "success" | "warning" | "danger" | "info";
  size?: "sm" | "md";
  class?: string;
}

const { tone = "neutral", size = "sm", class: className } = Astro.props;

const toneClass: Record<string, string> = {
  neutral: "bg-surface-sunken/50 text-muted-foreground border-border/50",
  primary: "bg-primary/10 text-primary border-primary/20 shadow-sm shadow-primary/5",
  success: "bg-success/10 text-success border-success/20",
  warning: "bg-warning/10 text-warning border-warning/20",
  danger: "bg-danger/10 text-danger border-danger/20",
  info: "bg-info/10 text-info border-info/20",
};

const sizeClass: Record<string, string> = {
  sm: "text-[10px] px-2 py-0.5 tracking-wider uppercase font-black",
  md: "text-xs px-2.5 py-1 font-bold",
};

const classes = cx(
  "inline-flex items-center rounded-lg border whitespace-nowrap transition-all duration-200",
  toneClass[tone],
  sizeClass[size],
  className,
);
---

<span class={classes}>
  <slot />
</span>

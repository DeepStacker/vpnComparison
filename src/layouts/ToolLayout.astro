---
/**
 * ToolLayout — full-bleed, app-like layout for interactive decision tools
 * (e.g. the VPN picker quiz). Keeps chrome minimal and gives the tool maximum
 * width. The tool UI is provided via the default slot.
 *
 * @prop seo - page SEO metadata.
 * @prop breadcrumbs - breadcrumb trail.
 * @prop jsonLd - extra structured data (e.g. WebApplication schema).
 * Slots: "intro" (above the tool surface), default (tool surface).
 */
import SeoLayout from "./SeoLayout.astro";
import Breadcrumbs from "@/components/ui/Breadcrumbs.astro";
import type { JsonLdNode, SeoMeta } from "@/types/seo";
import type { Breadcrumb } from "@/types/site";

interface Props {
  seo: SeoMeta;
  breadcrumbs?: Breadcrumb[];
  jsonLd?: JsonLdNode | JsonLdNode[];
}

const { seo, breadcrumbs = [], jsonLd } = Astro.props;
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs} renderBreadcrumbs={false} container="full" jsonLd={jsonLd}>
  <div class="relative overflow-hidden pb-20 pt-24 md:pb-28 md:pt-32">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent"></div>
      <div class="absolute left-1/2 top-0 h-[500px] w-[1000px] -translate-x-1/2 bg-primary/5 blur-[120px]"></div>
    </div>
    <div class="container-page">
      {breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} class="mb-8" />}
      <slot name="intro" />
    </div>
  </div>

  <div class="container-page pb-32">
    <section class="rounded-3xl border border-border bg-surface p-6 shadow-xl sm:p-10">
      <slot />
    </section>
  </div>
</SeoLayout>

---
/**
 * Header — sticky site header with primary navigation, theme toggle, and a
 * <details>-based mobile menu (no JS hydration). The current route is marked
 * with aria-current when it matches a nav item's href prefix.
 */
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import Icon from "@/components/ui/Icon.astro";
import { PRIMARY_NAV } from "@/constants/navigation";
import { cx } from "@/lib/utils/string";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(href.replace(/\/$/, "") + "/");
---

<header class="sticky top-4 z-[1200] mx-auto w-[calc(100%-2rem)] max-w-6xl rounded-2xl bg-glass-strong border border-glass-strong-border shadow-glass-inner shadow-2xl backdrop-blur-xl transition-all duration-300 after-glass-shine">
  <div class="px-6 flex h-16 items-center justify-between gap-4">
    <Logo />

    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {
          PRIMARY_NAV.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class={cx(
                  "relative rounded-xl px-4 py-2 text-sm font-bold no-underline transition-all duration-200",
                  isActive(item.href)
                    ? "text-primary bg-primary/5"
                    : "text-muted-foreground hover:text-foreground hover:bg-surface-raised",
                )}
              >
                {item.label}
                {isActive(item.href) && (
                  <span class="absolute -bottom-1 left-1/2 h-1 w-1 -translate-x-1/2 rounded-full bg-primary shadow-[0_0_8px_rgba(var(--primary-rgb),0.6)]" />
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-1">
      <!-- Quick actions dropdown -->
      <details class="group relative">
        <summary
          class="inline-flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-xl text-muted-foreground hover:text-foreground hover:bg-surface-raised border border-transparent hover:border-border transition-all focus-visible:outline-none [&::-webkit-details-marker]:hidden"
          aria-label="Quick actions"
          title="Quick actions"
        >
          <Icon name="zap" size={18} />
        </summary>
        <div class="absolute right-0 top-12 w-56 rounded-2xl bg-glass-strong border border-glass-strong-border p-2 shadow-glass-inner shadow-2xl backdrop-blur-xl after-glass-shine">
          <ul class="flex flex-col gap-0.5">
            <li><a href="/dashboard/" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold text-foreground no-underline transition-all hover:bg-primary/5 hover:text-primary"><Icon name="layout-dashboard" size={16} class="text-muted-foreground" /> Dashboard</a></li>
            <li><a href="/insights/" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold text-foreground no-underline transition-all hover:bg-primary/5 hover:text-primary"><Icon name="bar-chart-3" size={16} class="text-muted-foreground" /> Insights</a></li>
            <li><a href="/activity/" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold text-foreground no-underline transition-all hover:bg-primary/5 hover:text-primary"><Icon name="activity" size={16} class="text-muted-foreground" /> Activity</a></li>
            <li><hr class="my-1 border-border/50" /></li>
            <li><a href="/settings/" class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold text-foreground no-underline transition-all hover:bg-primary/5 hover:text-primary"><Icon name="settings" size={16} class="text-muted-foreground" /> Settings</a></li>
            <li><button type="button" id="shortcuts-dialog-trigger" class="flex w-full items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold text-foreground no-underline transition-all hover:bg-primary/5 hover:text-primary cursor-pointer"><Icon name="keyboard" size={16} class="text-muted-foreground" /> Shortcuts</button></li>
          </ul>
        </div>
      </details>

      <button
        type="button"
        id="search-dialog-trigger"
        class="inline-flex h-10 w-10 items-center justify-center rounded-xl text-muted-foreground hover:text-foreground hover:bg-surface-raised border border-transparent hover:border-border transition-all focus-visible:outline-none cursor-pointer"
        aria-label="Search"
        title="Search (⌘K)"
      >
        <Icon name="search" size={20} />
      </button>
      <ThemeToggle />
      <details class="group relative md:hidden">
        <summary
          class="inline-flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-xl border border-border bg-surface text-foreground hover:bg-surface-raised focus-visible:outline-none [&::-webkit-details-marker]:hidden"
          aria-label="Open menu"
        >
          <Icon name="menu" size={20} class="group-open:hidden" />
          <Icon name="x" size={20} class="hidden group-open:block" />
        </summary>
        <div
          class="absolute right-0 top-14 w-64 rounded-2xl bg-glass-strong border border-glass-strong-border p-2 shadow-glass-inner shadow-2xl animate-in fade-in zoom-in-95 duration-200 backdrop-blur-xl after-glass-shine"
        >
          <ul class="flex flex-col gap-1">
            {
              PRIMARY_NAV.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={isActive(item.href) ? "page" : undefined}
                    class={cx(
                      "block rounded-xl px-4 py-3 text-sm font-bold no-underline transition-all",
                      isActive(item.href)
                        ? "bg-primary/10 text-primary"
                        : "text-muted-foreground hover:text-foreground hover:bg-surface-raised",
                    )}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </details>
    </div>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const searchTrigger = document.getElementById("search-dialog-trigger");
    if (searchTrigger && typeof (window as any).openSearchDialog === "function") {
      searchTrigger.addEventListener("click", () => {
        (window as any).openSearchDialog();
      });
    }
    const shortcutsTrigger = document.getElementById("shortcuts-dialog-trigger");
    if (shortcutsTrigger && typeof (window as any).openShortcutsDialog === "function") {
      shortcutsTrigger.addEventListener("click", () => {
        (window as any).openShortcutsDialog();
      });
    }
  });
</script>

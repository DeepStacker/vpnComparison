---
import SeoLayout from "@/layouts/SeoLayout.astro";
import Heading from "@/components/ui/Heading.astro";
import Icon from "@/components/ui/Icon.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

const seo = normalizeSeoMeta({
  title: buildTitle("Testing Methodology — How We Review VPNs"),
  description: "Learn how FreeVPN4USA tests and reviews VPN services. Our methodology covers speed testing, privacy verification, streaming support, and security audits.",
  canonical: canonicalUrl("/methodology/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Methodology", href: "/methodology/" },
];

const dimensions = [
  {
    title: "Speed Testing", icon: "zap",
    items: [
      "Download speed reduction percentage compared to baseline",
      "Upload speed impact for streaming and torrenting",
      "Latency increase for real-time applications like gaming and video calls",
      "Connection stability and consistency across multiple tests",
    ]
  },
  {
    title: "Privacy & Security", icon: "shield",
    items: [
      "DNS leak testing across multiple server connections",
      "IPv6 and WebRTC leak verification",
      "Kill switch reliability testing",
      "Independent audit report verification",
    ]
  },
  {
    title: "Streaming Support", icon: "play",
    items: [
      "Verified access to Netflix, Prime Video, Disney+",
      "HBO Max, Hulu, and BBC iPlayer compatibility",
      "Regional content unblocking effectiveness",
      "Consistency across different server locations",
    ]
  },
  {
    title: "Torrenting & P2P", icon: "download",
    items: [
      "P2P traffic support and labeled servers",
      "Download and upload speed for torrenting",
      "Port forwarding availability",
      "Compatibility with major torrent clients",
    ]
  },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <div class="py-8">
    <div class="mb-8">
      <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Methodology</p>
      <Heading level={1} class="text-3xl font-black tracking-tight mt-1">How We Test VPNs</Heading>
      <p class="mt-1 text-sm text-muted-foreground max-w-xl">Transparent, consistent, and reproducible — every VPN review is fair, accurate, and useful.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2 mb-10">
      <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm lg:col-span-2">
        <Heading level={2} class="text-base font-black uppercase tracking-widest mb-4">Testing Environment</Heading>
        <p class="text-sm text-muted-foreground leading-relaxed mb-6">All VPN tests are conducted from multiple geographic locations using standardized hardware and connection types. Our primary test bench uses a 1 Gbps fiber connection in North America, supplemented by 100 Mbps connections in Europe and Asia-Pacific regions. Tests run on Windows, macOS, iOS, and Android to ensure cross-platform accuracy.</p>
        <div class="grid gap-3 sm:grid-cols-2">
          {[
            "Clean test environment with no other VPN software installed",
            "Baseline speed measured before each test session",
            "Multiple server locations tested per provider",
            "Tests at different times of day for network congestion",
          ].map((item) => `
            <div class="flex items-start gap-3 rounded-xl bg-surface-sunken/40 border border-border/50 p-3.5">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-success/10 text-success"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
              <span class="text-sm text-foreground">${item}</span>
            </div>
          `).join('')}
        </div>
      </div>

      {dimensions.map((dim) => `
        <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/5 text-primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><use href="/icons/lucide.svg#${dim.icon}"/></svg>
            </span>
            <Heading level={2} class="text-base font-black uppercase tracking-widest">${dim.title}</Heading>
          </div>
          <ul class="space-y-2">
            ${dim.items.map((item) => `
              <li class="flex items-start gap-3 text-sm text-muted-foreground">
                <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-primary"></span>
                <span>${item}</span>
              </li>
            `).join('')}
          </ul>
        </div>
      `).join('')}
    </div>

    <div class="rounded-2xl border border-border bg-surface-sunken/30 p-6">
      <div class="flex items-center gap-2 mb-4">
        <Icon name="star" size={16} class="text-warning" />
        <Heading level={2} class="text-base font-black uppercase tracking-widest">Scoring Rubric</Heading>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        {[
          { label: "Score Range", desc: "Each dimension scored 0-10, overall score is a weighted average" },
          { label: "Weighting", desc: "Privacy & Security weighted highest (30%), followed by Performance (25%)" },
          { label: "Verification", desc: "All claims verified through independent testing and audit report review" },
        ].map((r) => `
          <div class="rounded-xl border border-border bg-surface p-4">
            <p class="text-sm font-bold text-foreground">${r.label}</p>
            <p class="text-xs text-muted-foreground mt-1">${r.desc}</p>
          </div>
        `).join('')}
      </div>
    </div>
  </div>
</SeoLayout>

---
import { cx } from "@/lib/utils/string";

interface Props {
  price: number;
  cycle: string;
  currency?: string;
  featured?: boolean;
  className?: string;
}

const { price, cycle, currency = "USD", featured, className } = Astro.props;
const sym = currency === "USD" ? "$" : currency === "EUR" ? "€" : currency + " ";
---

<div class={cx("inline-flex flex-col items-start", featured ? 'text-primary' : 'text-foreground', className)}>
  <div class="flex items-baseline gap-1">
    <span class="text-4xl font-bold tracking-tight">{sym}{price.toFixed(2)}</span>
    <span class="text-sm font-bold text-muted-foreground">/mo</span>
  </div>
  <span class="text-xs font-bold uppercase tracking-widest text-muted-foreground mt-1">{cycle} plan{featured ? ' · Best value' : ''}</span>
</div>


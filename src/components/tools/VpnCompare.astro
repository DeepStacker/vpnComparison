---
interface VpnCompareProvider {
  id: string; slug: string; name: string; tagline: string;
  serverNetwork: { serverCount: number; countryCount: number; countries: string[]; virtualLocations: boolean };
  protocols: string[]; platforms: string[]; features: string[];
  streaming: Array<{ service: string; support: string; verifiedAt?: string }>;
  torrenting: { supported: boolean; labeledServers: boolean; rating?: number };
  loggingPolicy: string; jurisdiction: string;
  pricing: { currency: string; plans: Array<{ cycle: string; price: number; effectiveMonthly: number; featured?: boolean }>; moneyBackGuaranteeDays: number; freeTier: boolean };
  audits: Array<{ auditor: string; independent: boolean }>;
  killSwitch: boolean; multiHop: boolean; splitTunneling: boolean;
  adBlocker: boolean; dedicatedIp: boolean; simultaneousConnections: number;
}

interface VpnCompareReview {
  providerId: string;
  scores: {
    privacy: number; security: number; performance: number; streaming: number;
    torrenting: number; easeOfUse: number; value: number; overall: number;
  };
  verdict: { headline: string; summary: string; recommendation: string };
}

interface VpnCompareEntry {
  slug: string;
  title: string;
  providerIds: string[];
}

interface Props {
  providers: VpnCompareProvider[];
  reviews: VpnCompareReview[];
  comparisons: VpnCompareEntry[];
  countryNames: Record<string, string>;
}

const { providers, reviews, comparisons, countryNames } = Astro.props;
---

<div id="vpn-compare-root" class="mx-auto max-w-5xl">
  <div id="compare-selector" class="mb-8"></div>
  <div id="compare-matrix"></div>
</div>

<script is:inline type="application/json" id="compare-data" set:html={JSON.stringify(providers)}></script>
<script is:inline type="application/json" id="compare-reviews-data" set:html={JSON.stringify(reviews)}></script>
<script is:inline type="application/json" id="compare-comparisons-data" set:html={JSON.stringify(comparisons)}></script>
<script is:inline type="application/json" id="compare-country-names" set:html={JSON.stringify(countryNames)}></script>
<script>
  import { initVpnCompare } from "./VpnCompare.client";
  initVpnCompare();
</script>

---
import { getCollection } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Grid from "@/components/ui/Grid.astro";
import Icon from "@/components/ui/Icon.astro";
import { getCountryCountMap } from "@/lib/content/explorer";
import { countryHref } from "@/lib/content/links";
import { normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";
import type { Region } from "@/types/provider";

const allCountries = await getCollection("countries");
const countMap = await getCountryCountMap();

const regionOrder: Region[] = [
  "north-america", "south-america", "europe", "asia", "africa", "oceania", "middle-east",
];
const regionLabels: Record<Region, string> = {
  "north-america": "North America",
  "south-america": "South America",
  europe: "Europe",
  asia: "Asia",
  africa: "Africa",
  oceania: "Oceania",
  "middle-east": "Middle East",
};

const grouped = new Map<Region, typeof allCountries>();
for (const region of regionOrder) {
  grouped.set(region, []);
}
for (const c of allCountries) {
  const list = grouped.get(c.data.region);
  if (list) list.push(c);
}

const seo = normalizeSeoMeta({
  title: "VPN Server Locations by Country",
  description: "Browse VPN server locations by country. Find out which VPN providers have servers in each country and compare privacy jurisdictions.",
  canonical: canonicalUrl("/countries/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Countries", href: "/countries/" },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section class="relative overflow-hidden pb-20 pt-24 md:pb-28 md:pt-32">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent"></div>
      <div class="absolute left-1/2 top-0 h-[500px] w-[1000px] -translate-x-1/2 bg-primary/5 blur-[120px]"></div>
    </div>
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <Badge tone="primary" class="mb-6">Global Network</Badge>
        <Heading level={1} class="text-4xl font-black tracking-tight md:text-6xl">
          VPN Server <span class="text-primary">Locations</span>
        </Heading>
        <Text size="xl" tone="muted" class="mt-6 max-w-2xl mx-auto leading-relaxed">
          Browse VPN server availability by country. Each page shows which providers have servers in that location, privacy jurisdiction notes, and related content.
        </Text>
      </div>
    </Container>
  </Section>

  {regionOrder.map((region) => {
    const countries = grouped.get(region) ?? [];
    if (countries.length === 0) return null;
    return (
      <Section class="pb-20">
        <Container>
          <div class="flex items-center gap-4 mb-8">
            <div class="h-px flex-grow bg-border"></div>
            <Badge tone="primary" size="md" class="shadow-sm uppercase tracking-widest font-black">{regionLabels[region]}</Badge>
            <div class="h-px flex-grow bg-border"></div>
          </div>
          
          <Grid cols={1} colsMd={2} colsLg={4} gap={4}>
            {countries
              .sort((a, b) => a.data.name.localeCompare(b.data.name))
              .map((c) => {
                const count = countMap.get(c.data.code) ?? 0;
                return (
                  <a
                    href={countryHref(c.data.slug)}
                    class="group flex items-center gap-4 rounded-2xl border border-border bg-surface p-4 no-underline transition-all duration-200 hover:border-primary/30 hover:shadow-md hover:-translate-y-0.5"
                  >
                    <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-surface-sunken text-2xl leading-none shadow-inner group-hover:bg-primary/5 transition-colors">
                      {c.data.flagEmoji}
                    </span>
                    <div class="min-w-0">
                      <div class="text-base font-bold text-foreground group-hover:text-primary transition-colors truncate">{c.data.name}</div>
                      <div class="text-xs font-bold text-muted-foreground uppercase tracking-wider mt-0.5">
                        {count} {count === 1 ? "provider" : "providers"}
                      </div>
                    </div>
                  </a>
                );
              })}
          </Grid>
        </Container>
      </Section>
    );
  })}

  <Section background padding="loose">
    <Container>
      <div class="mx-auto max-w-xl text-center">
        <Icon name="globe" size={32} class="mx-auto text-primary" />
        <Heading level={2} class="mt-4">Why Server Location Matters</Heading>
        <Text tone="muted" class="mt-3 leading-relaxed">
          Server location affects connection speed, streaming access, and privacy. Servers in privacy-friendly jurisdictions offer stronger legal protection, while servers in specific countries enable access to regional content.
        </Text>
        <div class="mt-6">
          <Button variant="outline" href="/guides/">Learn More in Our Guides</Button>
        </div>
      </div>
    </Container>
  </Section>
</SeoLayout>

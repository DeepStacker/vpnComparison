---
import ToolLayout from "@/layouts/ToolLayout.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Badge from "@/components/ui/Badge.astro";
import Icon from "@/components/ui/Icon.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

const seo = normalizeSeoMeta({
  title: buildTitle("VPN Tools — Recommender & Comparison Builder"),
  description: "Interactive tools to find the right VPN and compare providers side by side across pricing, privacy, features, and performance.",
  canonical: canonicalUrl("/tools/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "VPN Tools", href: "/tools/" },
];
---

<ToolLayout seo={seo} breadcrumbs={breadcrumbs}>
  <div slot="intro">
    <div class="mx-auto max-w-3xl text-center">
      <Badge tone="primary" class="mb-6">Interactive Tools</Badge>
      <Heading level={1} class="text-4xl font-black tracking-tight md:text-6xl">
        VPN <span class="text-primary">Tools</span>
      </Heading>
      <Text size="xl" tone="muted" class="mt-6 leading-relaxed">
        Interactive tools that turn our structured VPN database into actionable recommendations and side-by-side comparisons.
      </Text>
    </div>
  </div>

  <div class="grid gap-8 sm:grid-cols-2">
    <a href="/tools/finder/" class="group relative overflow-hidden rounded-2xl border border-border bg-surface p-8 no-underline transition-all duration-300 hover:border-primary/30 hover:shadow-2xl hover:-translate-y-1">
      <div class="absolute top-0 right-0 -mt-4 -mr-4 h-24 w-24 rounded-full bg-primary/5 blur-2xl group-hover:bg-primary/10 transition-colors"></div>
      <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/5 text-primary border border-primary/10 shadow-sm group-hover:bg-primary group-hover:text-primary-foreground transition-all duration-300">
        <Icon name="wand-2" size={28} />
      </div>
      <Heading level={2} class="text-2xl font-bold mt-6 group-hover:text-primary transition-colors">VPN Recommender</Heading>
      <Text size="base" tone="muted" class="mt-4 leading-relaxed">
        Answer a few questions about your needs — privacy, streaming, budget, platforms — and get a personalized VPN recommendation with full transparency.
      </Text>
      <div class="mt-8 flex items-center gap-2 text-sm font-black uppercase tracking-widest text-primary">
        <span>Try the finder</span>
        <Icon name="arrow-right" size={16} class="transition-transform group-hover:translate-x-1" />
      </div>
    </a>

    <a href="/tools/compare/" class="group relative overflow-hidden rounded-2xl border border-border bg-surface p-8 no-underline transition-all duration-300 hover:border-primary/30 hover:shadow-2xl hover:-translate-y-1">
      <div class="absolute top-0 right-0 -mt-4 -mr-4 h-24 w-24 rounded-full bg-primary/5 blur-2xl group-hover:bg-primary/10 transition-colors"></div>
      <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/5 text-primary border border-primary/10 shadow-sm group-hover:bg-primary group-hover:text-primary-foreground transition-all duration-300">
        <Icon name="arrow-left-right" size={28} />
      </div>
      <Heading level={2} class="text-2xl font-bold mt-6 group-hover:text-primary transition-colors">Comparison Builder</Heading>
      <Text size="base" tone="muted" class="mt-4 leading-relaxed">
        Select up to 4 VPN providers and compare them side by side across pricing, jurisdiction, logging policy, network size, features, and review scores.
      </Text>
      <div class="mt-8 flex items-center gap-2 text-sm font-black uppercase tracking-widest text-primary">
        <span>Build a comparison</span>
        <Icon name="arrow-right" size={16} class="transition-transform group-hover:translate-x-1" />
      </div>
    </a>
  </div>

  <div class="mt-12 rounded-2xl border border-border bg-surface-sunken/30 p-8">
    <Heading level={2} class="text-xl font-bold mb-6">Why use our tools?</Heading>
    <div class="grid gap-6 md:grid-cols-3">
      <div class="flex items-start gap-4">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-success/10 text-success border border-success/20">
          <Icon name="check" size={16} />
        </div>
        <div>
          <p class="font-bold text-foreground">Data-driven</p>
          <p class="mt-1 text-sm text-muted-foreground leading-relaxed">Every recommendation is based on our structured provider database, not editorial opinion.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-success/10 text-success border border-success/20">
          <Icon name="check" size={16} />
        </div>
        <div>
          <p class="font-bold text-foreground">Transparent</p>
          <p class="mt-1 text-sm text-muted-foreground leading-relaxed">The finder shows you exactly how each score is calculated and why we recommend it.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-success/10 text-success border border-success/20">
          <Icon name="check" size={16} />
        </div>
        <div>
          <p class="font-bold text-foreground">Independent</p>
          <p class="mt-1 text-sm text-muted-foreground leading-relaxed">No affiliate bias. Our provider data is verified through hands-on testing and audit reports.</p>
        </div>
      </div>
    </div>
  </div>
</ToolLayout>

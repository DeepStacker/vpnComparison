---
interface Props {
  quote: string;
  attribution?: string;
  class?: string;
}
const { quote, attribution } = Astro.props;
---

<figure class="my-8 border-l-4 border-primary bg-surface-sunken px-6 py-5 rounded-r-lg">
  <blockquote class="text-lg font-medium leading-relaxed text-foreground italic">
    "{quote}"
  </blockquote>
  {attribution && (
    <figcaption class="mt-3 text-sm text-muted-foreground">— {attribution}</figcaption>
  )}
</figure>

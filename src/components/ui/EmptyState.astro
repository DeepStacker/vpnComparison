---
/**
 * EmptyState — placeholder for empty result sets (search, filters, lists).
 * @prop icon - lucide icon name (default: "inbox").
 * @prop title - short headline.
 * @prop description - supporting copy.
 * Slot "action" - optional primary CTA.
 */
import Icon from "./Icon.astro";
import { cx } from "@/lib/utils/string";

interface Props {
  icon?: string;
  title: string;
  description?: string;
  class?: string;
}

const { icon = "inbox", title, description, class: className } = Astro.props;
---

<div class={cx("flex flex-col items-center justify-center rounded-lg border border-dashed border-border bg-surface-sunken/40 px-6 py-12 text-center", className)}>
  <Icon name={icon} size={28} class="text-muted-foreground" />
  <p class="mt-3 text-base font-semibold text-foreground">{title}</p>
  {description && <p class="mt-1 max-w-sm text-sm text-muted-foreground">{description}</p>}
  <div class="mt-4">
    <slot name="action" />
  </div>
</div>

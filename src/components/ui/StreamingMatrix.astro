---
interface StreamingEntry {
  service: string;
  support: "verified" | "partial" | "unsupported" | "unknown";
  verifiedAt?: string;
  notes?: string;
  regionsTested?: string[];
}

interface Props {
  items: StreamingEntry[];
  serviceNames: Record<string, string>;
  class?: string;
}

import Icon from "./Icon.astro";
import { cx } from "@/lib/utils/string";

const { items, serviceNames, class: className } = Astro.props;

const statusConfig = {
  verified: { icon: "circle-check", color: "text-success", bg: "bg-success-surface", label: "Verified" },
  partial: { icon: "alert-triangle", color: "text-warning", bg: "bg-warning-surface", label: "Partial" },
  unsupported: { icon: "circle-x", color: "text-danger", bg: "bg-danger-surface", label: "Unsupported" },
  unknown: { icon: "help-circle", color: "text-muted-foreground", bg: "bg-surface-sunken", label: "Unknown" },
};
---

<div class={cx("grid gap-3", className)} style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr))">
  {items.map((s) => {
    const cfg = statusConfig[s.support] ?? statusConfig.unknown;
    const name = serviceNames[s.service] ?? s.service;
    return (
      <div class="group flex items-start gap-3 rounded-lg border border-border bg-surface p-4 transition-all motion-safe:duration-150 hover:border-primary/30 hover:shadow-sm">
        <div class={cx("flex h-8 w-8 shrink-0 items-center justify-center rounded-full", cfg.bg, cfg.color)}>
          <Icon name={cfg.icon} size={16} />
        </div>
        <div class="min-w-0">
          <div class="text-sm font-medium text-foreground">{name}</div>
          <div class={cx("text-xs font-medium", cfg.color)}>{cfg.label}</div>
          {s.regionsTested && s.regionsTested.length > 0 && (
            <div class="mt-1 text-xs text-muted-foreground">{s.regionsTested.join(", ")}</div>
          )}
        </div>
      </div>
    );
  })}
</div>

---
/**
 * EmptyState — placeholder for empty result sets (search, filters, lists).
 * @prop icon - lucide icon name (default: "inbox").
 * @prop title - short headline.
 * @prop description - supporting copy.
 * Slot "action" - optional primary CTA.
 */
import Icon from "./Icon.astro";
import { cx } from "@/lib/utils/string";

interface Props {
  icon?: string;
  title: string;
  description?: string;
  class?: string;
}

const { icon = "inbox", title, description, class: className } = Astro.props;
---

<div class={cx("flex flex-col items-center justify-center rounded-3xl border-2 border-dashed border-border bg-surface-sunken/30 px-8 py-16 text-center", className)}>
  <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-surface border border-border shadow-sm mb-6">
    <Icon name={icon} size={32} class="text-muted-foreground" />
  </div>
  <p class="text-xl font-bold text-foreground">{title}</p>
  {description && <p class="mt-2 max-w-sm text-base text-muted-foreground leading-relaxed">{description}</p>}
  <div class="mt-8">
    <slot name="action" />
  </div>
</div>

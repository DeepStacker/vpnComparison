---
import ToolLayout from "@/layouts/ToolLayout.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

const seo = normalizeSeoMeta({
  title: buildTitle("VPN Tools — Recommender & Comparison Builder"),
  description: "Interactive tools to find the right VPN and compare providers side by side across pricing, privacy, features, and performance.",
  canonical: canonicalUrl("/tools/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "VPN Tools", href: "/tools/" },
];
---

<ToolLayout seo={seo} breadcrumbs={breadcrumbs}>
  <div slot="intro">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">VPN Tools</h1>
      <p class="mt-3 text-lg text-muted-foreground">
        Interactive tools that turn our structured VPN database into actionable recommendations and side-by-side comparisons.
      </p>
    </div>
  </div>

  <div class="grid gap-8 sm:grid-cols-2">
    <a href="/tools/finder/" class="group rounded-xl border border-border bg-surface p-8 no-underline transition-all hover:border-primary hover:shadow-md">
      <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-primary-foreground">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 4V2"/><path d="M15 16v-2"/><path d="M15 8v2"/><path d="M8 9h2"/><path d="M20 9h2"/><path d="M17.5 11.5 6 3l-1 2 8.5 11.5"/><path d="M18 17c0 1.7-1.3 3-3 3s-3-1.3-3-3 1.3-3 3-3 3 1.3 3 3"/><circle cx="7" cy="17" r="4"/></svg>
      </div>
      <h2 class="mt-6 text-xl font-semibold text-foreground">VPN Recommender</h2>
      <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
        Answer a few questions about your needs — privacy, streaming, budget, platforms — and get a personalized VPN recommendation with full transparency on how each score is calculated.
      </p>
      <div class="mt-4 flex items-center gap-2 text-sm font-medium text-primary">
        <span>Try the finder</span>
        <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </div>
    </a>

    <a href="/tools/compare/" class="group rounded-xl border border-border bg-surface p-8 no-underline transition-all hover:border-primary hover:shadow-md">
      <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-primary-foreground">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
      </div>
      <h2 class="mt-6 text-xl font-semibold text-foreground">Comparison Builder</h2>
      <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
        Select up to 4 VPN providers and compare them side by side across pricing, jurisdiction, logging policy, network size, features, and review scores.
      </p>
      <div class="mt-4 flex items-center gap-2 text-sm font-medium text-primary">
        <span>Build a comparison</span>
        <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </div>
    </a>
  </div>

  <div class="mt-12 rounded-xl border border-border bg-surface p-6">
    <h2 class="text-lg font-semibold">Why use our tools?</h2>
    <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
      <li class="flex items-start gap-2">
        <span class="mt-0.5 text-primary">&#x2022;</span>
        <span><strong class="text-foreground">Data-driven:</strong> Every recommendation and comparison is based on our structured provider database, not editorial opinion.</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="mt-0.5 text-primary">&#x2022;</span>
        <span><strong class="text-foreground">Transparent:</strong> The finder shows you exactly how each score is calculated, and the comparison builder highlights the winner in each category.</span>
      </li>
      <li class="flex items-start gap-2">
        <span class="mt-0.5 text-primary">&#x2022;</span>
        <span><strong class="text-foreground">Independent:</strong> No affiliate bias. Our provider database is verified through hands-on testing and public audit reports.</span>
      </li>
    </ul>
  </div>
</ToolLayout>

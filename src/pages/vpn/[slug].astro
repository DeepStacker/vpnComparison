---
import { getCollection, getEntry, render } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import ScoreBar from "@/components/ui/ScoreBar.astro";
import ScoreRing from "@/components/ui/ScoreRing.astro";
import PriceTag from "@/components/ui/PriceTag.astro";
import StreamingMatrix from "@/components/ui/StreamingMatrix.astro";
import Grid from "@/components/ui/Grid.astro";
import Chip from "@/components/ui/Chip.astro";
import Icon from "@/components/ui/Icon.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import { cx } from "@/lib/utils/string";
import { featureHref, protocolHref, platformHref, countryHref } from "@/lib/content/links";
import type { Breadcrumb } from "@/types/site";
import type { ISODateString } from "@/types/common";

export async function getStaticPaths() {
  const providers = await getCollection("providers");
  return providers.map((p) => ({ params: { slug: p.data.slug } }));
}

const { slug } = Astro.params;
const providerEntry = await getEntry("providers", slug);
if (!providerEntry) return Astro.redirect("/404");

const provider = providerEntry.data;
const overviewEntry = await getEntry("provider-overviews", slug);
const OverviewContent = overviewEntry ? (await render(overviewEntry)).Content : null;

const allReviews = await getCollection("reviews");
const review = allReviews.find((r) => r.data.provider.id === slug);
const reviewData = review?.data;

const [allFeatures, allProtocols, allPlatforms, allStreamingSvcs, allCountries, allComparisons, allGuides] =
  await Promise.all([
    getCollection("features"),
    getCollection("protocols"),
    getCollection("platforms"),
    getCollection("streaming-services"),
    getCollection("countries"),
    getCollection("comparisons"),
    getCollection("guides"),
  ]);

const featureNameMap = new Map(allFeatures.map((f) => [f.data.id, f.data.name]));
const featureSlugMap = new Map(allFeatures.map((f) => [f.data.id, f.data.slug]));
const protocolNameMap = new Map(allProtocols.map((p) => [p.data.id, p.data.name]));
const protocolSlugMap = new Map(allProtocols.map((p) => [p.data.id, p.data.slug]));
const platformNameMap = new Map(allPlatforms.map((p) => [p.data.id, p.data.name]));
const platformSlugMap = new Map(allPlatforms.map((p) => [p.data.id, p.data.slug]));
const streamingNameMap = new Map(allStreamingSvcs.map((s) => [s.data.id, s.data.name]));
const countryNameMap = new Map(allCountries.map((c) => [c.data.code, c.data.name]));
const countrySlugMap = new Map(allCountries.map((c) => [c.data.code, c.data.slug]));

const allScores = reviewData?.scores;

const relatedComparisons = allComparisons.filter((c) =>
  c.data.providers.some((ref) => ref.id === provider.id),
);
const relatedGuides = allGuides.filter((g) =>
  g.data.relatedProviders?.some((ref) => ref.id === provider.id),
);

const reviewAuthorEntry = review?.data?.reviewer?.id
  ? await getEntry("authors", review.data.reviewer.id)
  : null;
const authorName = reviewAuthorEntry?.data?.name;

const pageTitle = reviewData?.title
  ? buildTitle(reviewData.title)
  : buildTitle(`${provider.name} Review`);
const seo = normalizeSeoMeta({
  title: pageTitle,
  description: reviewData?.summary ?? `${provider.name} overview with specs, features, pricing, and scores.`,
  canonical: canonicalUrl(`/vpn/${slug}/`),
  publishedAt: reviewData?.publishedAt as ISODateString | undefined,
  author: authorName,
});

const breadcrumbs: Breadcrumb[] = [
  { label: "VPN Reviews", href: "/vpn/" },
  { label: provider.name, href: `/vpn/${slug}/` },
];

const jurisdictionCountrySlug = countrySlugMap.get(provider.jurisdiction);

const cheapest = provider.pricing.plans.find((p) => p.featured) ?? provider.pricing.plans[0];

/** Simple capitalize helper */
function capitalize(s: string): string {
  return s.charAt(0).toUpperCase() + s.slice(1);
}
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>

  <!-- ============================================================
       PROVIDER HERO
       ============================================================ -->
  <Section class="relative overflow-hidden bg-gradient-hero pt-24 pb-16" padding="none">
    <div class="pointer-events-none absolute inset-0 bg-dot-grid opacity-[0.05]" aria-hidden="true" />
    <div class="pointer-events-none absolute -left-20 -top-20 h-96 w-96 rounded-full bg-white/5 blur-[120px]" aria-hidden="true" />
    <div class="pointer-events-none absolute -bottom-16 -right-16 h-80 w-80 rounded-full bg-primary/10 blur-[100px]" aria-hidden="true" />
    <Container>
      <div class="flex flex-col gap-12 lg:flex-row lg:items-center lg:justify-between">
        <!-- Left: identity + meta -->
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-6 mb-6">
            <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl bg-white/10 backdrop-blur-md ring-1 ring-white/20 shadow-xl">
              <img src={`/logos/${slug}.svg`} alt={`${provider.name} logo`} class="h-12 w-12 object-contain" width={48} height={48} loading="eager" />
            </div>
            <div>
              <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">{provider.name} Review</h1>
              {reviewData && (
                <div class="mt-3 flex items-center gap-4">
                  {reviewData.verdict.recommendation === "recommended" && (
                    <Badge tone="success" size="md" class="rounded-full border border-white/20 bg-white/10 text-white">Editor's Choice</Badge>
                  )}
                  <Text size="sm" class="text-white/60 font-medium">
                    Updated {reviewData.updatedAt ?? provider.updatedAt}
                  </Text>
                </div>
              )}
            </div>
          </div>

          <!-- Verdict headline -->
          {reviewData?.verdict && (
            <p class="max-w-3xl text-xl leading-relaxed text-white/90 font-bold">
              {reviewData.verdict.headline}
            </p>
          )}
          <p class="mt-4 max-w-2xl text-lg leading-relaxed text-white/70">
            {provider.tagline}
          </p>

          <!-- CTA row -->
          <div class="mt-10 flex flex-wrap items-center gap-4">
            {cheapest && (
              <div class="flex items-center gap-4 rounded-xl bg-white/10 backdrop-blur-md border border-white/10 px-6 py-3">
                <div class="flex items-baseline gap-1 text-white">
                  <span class="text-3xl font-bold tracking-tight">${cheapest.effectiveMonthly.toFixed(2)}</span>
                  <span class="text-sm font-medium text-white/60">/mo</span>
                </div>
                <div class="text-xs font-bold uppercase tracking-widest text-white/50">
                  {cheapest.cycle === "monthly" ? "Monthly" : cheapest.cycle === "yearly" ? "Annual" : "2-year"} plan
                </div>
              </div>
            )}
            <Button href={provider.websiteUrl} variant="glass" size="lg" target="_blank" rel="noopener noreferrer" class="rounded-xl px-8">
              Visit Website <Icon name="external-link" size={18} />
            </Button>
            {review && (
              <Button href="#scores" size="lg" class="rounded-xl px-8 shadow-xl">
                Read Review
              </Button>
            )}
          </div>
        </div>

        <!-- Right: score ring -->
        {allScores && (
          <a href="#scores" class="flex shrink-0 flex-col items-center gap-4 no-underline group/score transition-transform hover:scale-105">
            <div class="relative flex items-center justify-center">
              <svg width="180" height="180" viewBox="0 0 180 180" role="img" aria-label={`Overall score ${allScores.overall.toFixed(1)} out of 10`}>
                <circle cx="90" cy="90" r="80" fill="none" stroke="rgb(255 255 255 / 0.1)" stroke-width="10" />
                <circle cx="90" cy="90" r="80" fill="none" stroke="white" stroke-width="10"
                  stroke-dasharray={`${2 * Math.PI * 80}`}
                  stroke-dashoffset={`${2 * Math.PI * 80 * (1 - allScores.overall / 10)}`}
                  stroke-linecap="round" transform="rotate(-90 90 90)"
                  class="transition-all motion-safe:duration-1000 motion-safe:ease-emphasized" />
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span class="text-5xl font-bold text-white">{allScores.overall.toFixed(1)}</span>
                <span class="text-xs font-bold tracking-widest text-white/50 uppercase mt-1">Score</span>
              </div>
            </div>
          </a>
        )}
      </div>
    </Container>
  </Section>

  <!-- ============================================================
       KEY STATS ROW
       ============================================================ -->
  <Section padding="tight">
    <Container>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
        <div class="flex items-center gap-4 rounded-2xl border border-border bg-surface p-4 shadow-sm">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <Icon name="server" size={20} />
          </div>
          <div class="min-w-0">
            <Text size="base" weight="semibold" class="tabular-nums leading-none">{provider.serverNetwork.serverCount.toLocaleString()}</Text>
            <Text size="xs" tone="muted" class="mt-1 font-bold uppercase tracking-widest">Servers</Text>
          </div>
        </div>

        <div class="flex items-center gap-4 rounded-2xl border border-border bg-surface p-4 shadow-sm">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <Icon name="globe" size={20} />
          </div>
          <div class="min-w-0">
            <Text size="base" weight="semibold" class="tabular-nums leading-none">{provider.serverNetwork.countryCount}</Text>
            <Text size="xs" tone="muted" class="mt-1 font-bold uppercase tracking-widest">Countries</Text>
          </div>
        </div>

        <div class="flex items-center gap-4 rounded-2xl border border-border bg-surface p-4 shadow-sm">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <Icon name="monitor-smartphone" size={20} />
          </div>
          <div class="min-w-0">
            <Text size="base" weight="semibold" class="tabular-nums leading-none">{provider.simultaneousConnections === 0 ? "∞" : provider.simultaneousConnections}</Text>
            <Text size="xs" tone="muted" class="mt-1 font-bold uppercase tracking-widest">Devices</Text>
          </div>
        </div>

        <div class="flex items-center gap-4 rounded-2xl border border-border bg-surface p-4 shadow-sm">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <Icon name="shield" size={20} />
          </div>
          <div class="min-w-0">
            <Text size="base" weight="semibold" class="leading-none">{provider.loggingPolicy === "no-logs" ? "No-logs" : capitalize(provider.loggingPolicy)}</Text>
            <Text size="xs" tone="muted" class="mt-1 font-bold uppercase tracking-widest">Logging</Text>
          </div>
        </div>

        <div class="flex items-center gap-4 rounded-2xl border border-border bg-surface p-4 shadow-sm">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <Icon name="landmark" size={20} />
          </div>
          <div class="min-w-0">
            {jurisdictionCountrySlug
              ? <a href={countryHref(jurisdictionCountrySlug)} class="no-underline"><Text size="base" weight="semibold" class="text-primary hover:underline leading-none">{countryNameMap.get(provider.jurisdiction) ?? provider.jurisdiction}</Text></a>
              : <Text size="base" weight="semibold" class="leading-none">{countryNameMap.get(provider.jurisdiction) ?? provider.jurisdiction}</Text>
            }
            <Text size="xs" tone="muted" class="mt-1 font-bold uppercase tracking-widest">Jurisdiction</Text>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- ============================================================
       SCORE BREAKDOWN
       ============================================================ -->
  {allScores && (
    <Section background id="scores" padding="loose">
      <Container>
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
          <div>
            <Badge tone="primary" size="md" class="rounded-full mb-4">Review scores</Badge>
            <Heading level={2} class="text-4xl font-bold">Score Breakdown — {allScores.overall.toFixed(1)} / 10</Heading>
            {reviewData?.testDate && <Text size="sm" tone="muted" class="mt-2 font-medium">Last tested on {reviewData.testDate}</Text>}
          </div>
          <Button variant="outline" size="sm" href="/methodology/" class="rounded-full">Our Methodology</Button>
        </div>
        <div class="grid gap-12 lg:grid-cols-3">
          <div class="lg:col-span-2 space-y-2">
            <ScoreBar value={allScores.performance} label="Performance" />
            <ScoreBar value={allScores.privacy} label="Privacy" />
            <ScoreBar value={allScores.security} label="Security" />
            <ScoreBar value={allScores.streaming} label="Streaming" />
            <ScoreBar value={allScores.torrenting} label="Torrenting" />
            <ScoreBar value={allScores.easeOfUse} label="Ease of Use" />
            <ScoreBar value={allScores.value} label="Value" />
          </div>
          <div>
            {reviewData?.verdict && (
              <Card variant="default" padding="lg" class="h-full flex flex-col rounded-3xl border-2 border-primary/10 shadow-lg relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-10">
                  <Icon name="quote" size={64} />
                </div>
                <div class="flex items-center gap-3 mb-6">
                  <div class="flex h-10 w-10 items-center justify-center rounded-full shadow-sm"
                    class:list={{
                      "bg-success text-success-foreground": reviewData.verdict.recommendation === "recommended",
                      "bg-warning text-warning-foreground": reviewData.verdict.recommendation === "conditional",
                      "bg-danger text-danger-foreground": reviewData.verdict.recommendation === "not-recommended",
                    }}
                  >
                    <Icon name={reviewData.verdict.recommendation === "recommended" ? "check" : "alert-triangle"} size={20} />
                  </div>
                  <Badge
                    tone={reviewData.verdict.recommendation === "recommended" ? "success" : reviewData.verdict.recommendation === "conditional" ? "warning" : "danger"}
                    class="rounded-full px-4 py-1"
                  >
                    {reviewData.verdict.recommendation === "recommended" ? "Recommended" : capitalize(reviewData.verdict.recommendation)}
                  </Badge>
                </div>
                <Heading level={3} class="text-2xl font-bold leading-tight">{reviewData.verdict.headline}</Heading>
                <Text size="base" tone="muted" class="mt-4 leading-relaxed flex-1">{reviewData.verdict.summary}</Text>
                
                <div class="mt-8 pt-6 border-t border-border">
                  <Text size="xs" tone="muted" class="italic leading-relaxed mb-6">{reviewData.methodology}</Text>
                  <Button href={provider.websiteUrl} fullWidth size="lg" class="rounded-xl shadow-md">
                    Get {provider.name} <Icon name="arrow-right" size={18} />
                  </Button>
                </div>
              </Card>
            )}
          </div>
        </div>
      </Container>
    </Section>
  )}

  <!-- ============================================================
       PROS & CONS
       ============================================================ -->
  {reviewData && (reviewData.pros.length > 0 || reviewData.cons.length > 0) ? (
    <Section>
      <Container>
        <div class="mb-8">
          <Badge tone="primary" size="md" class="rounded-full mb-4">Pros & Cons</Badge>
          <Heading level={2} class="text-3xl font-bold">The Good & The Bad</Heading>
          <Text tone="muted" class="mt-2 text-lg">What sets {provider.name} apart — and where it falls short.</Text>
        </div>
        <Grid cols={1} colsMd={2} gap={8}>
          {reviewData.pros.length > 0 && (
            <Card variant="default" padding="lg" class="border-t-4 border-success rounded-2xl shadow-sm">
              <Heading level={3} class="text-xl font-bold flex items-center gap-3 text-success mb-6">
                <Icon name="check-circle" size={24} />
                Pros
              </Heading>
              <ul class="space-y-4">
                {reviewData.pros.map((pro) => (
                  <li class="flex items-start gap-4">
                    <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-success/10 text-success">
                      <Icon name="check" size={14} />
                    </div>
                    <Text size="base" class="leading-relaxed font-medium">{pro}</Text>
                  </li>
                ))}
              </ul>
            </Card>
          )}
          {reviewData.cons.length > 0 && (
            <Card variant="default" padding="lg" class="border-t-4 border-danger rounded-2xl shadow-sm">
              <Heading level={3} class="text-xl font-bold flex items-center gap-3 text-danger mb-6">
                <Icon name="alert-circle" size={24} />
                Cons
              </Heading>
              <ul class="space-y-4">
                {reviewData.cons.map((con) => (
                  <li class="flex items-start gap-4">
                    <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-danger/10 text-danger">
                      <Icon name="x" size={14} />
                    </div>
                    <Text size="base" class="leading-relaxed font-medium">{con}</Text>
                  </li>
                ))}
              </ul>
            </Card>
          )}
        </Grid>
      </Container>
    </Section>
  ) : null}

  <!-- ============================================================
       PRICING
       ============================================================ -->
  <Section background padding="loose">
    <Container>
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10">
        <div>
          <Badge tone="primary" size="md" class="rounded-full mb-4">Pricing</Badge>
          <Heading level={2} class="text-3xl font-bold">Plans & Pricing</Heading>
          <Text tone="muted" class="mt-2 text-lg">
            {provider.pricing.freeTier ? "Free tier available" : "Transparent pricing for every need."}
          </Text>
        </div>
        {provider.pricing.moneyBackGuaranteeDays > 0 && (
          <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-success/10 text-success text-sm font-bold border border-success/20">
            <Icon name="shield-check" size={18} />
            {provider.pricing.moneyBackGuaranteeDays}-day money-back guarantee
          </div>
        )}
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {provider.pricing.plans.map((plan) => (
          <Card padding="lg" variant="default" class={cx("rounded-3xl transition-all duration-300", plan.featured ? "border-2 border-primary shadow-xl scale-105 z-10 bg-surface" : "border border-border shadow-sm hover:shadow-md")}>
            {plan.featured && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-primary-foreground text-[10px] font-bold uppercase tracking-widest px-4 py-1 rounded-full shadow-sm">
                Best Value
              </div>
            )}
            <div class="text-center">
              <Badge tone={plan.featured ? "primary" : "neutral"} size="md" class="rounded-full mb-6">{capitalize(plan.cycle)}</Badge>
              <PriceTag price={plan.effectiveMonthly} cycle={plan.cycle} featured={plan.featured} />
              <Text size="sm" tone="muted" class="mt-4 font-medium">${plan.price.toFixed(2)} billed {plan.cycle === "monthly" ? "monthly" : plan.cycle === "yearly" ? "annually" : "every 2 years"}</Text>
              <Button href={provider.websiteUrl} variant={plan.featured ? "primary" : "outline"} fullWidth size="md" class="mt-8 rounded-xl">
                Get Started
              </Button>
            </div>
          </Card>
        ))}
      </div>
      <div class="mt-12 flex flex-col items-center gap-6">
        <div class="flex flex-wrap justify-center gap-3">
          <Text size="sm" tone="muted" weight="semibold" class="mr-2">Accepted Payment Methods:</Text>
          {provider.pricing.paymentMethods.map((m) => (
            <Badge tone="neutral" size="sm" class="rounded-full px-3">{m}</Badge>
          ))}
        </div>
        {provider.pricing.freeTierNotes && (
          <div class="max-w-2xl text-center p-4 rounded-xl bg-info/5 border border-info/10 text-info text-sm font-medium">
            <Icon name="info" size={16} class="inline-block mr-2" />
            {provider.pricing.freeTierNotes}
          </div>
        )}
      </div>
    </Container>
  </Section>

  <!-- ============================================================
       GROUPED SPECIFICATION PANEL
       ============================================================ -->
  <Section padding="loose">
    <Container>
      <div class="mb-10">
        <Badge tone="primary" size="md" class="rounded-full mb-4">Specifications</Badge>
        <Heading level={2} class="text-3xl font-bold">Features & Compatibility</Heading>
        <Text tone="muted" class="mt-2 text-lg">Technical details and platform support.</Text>
      </div>

      <Card variant="default" padding="lg" class="rounded-3xl border border-border shadow-sm bg-surface">
        <div class="grid gap-12 lg:grid-cols-2">
          <!-- Left column: Features + Protocols + Platforms -->
          <div class="space-y-10">
            <!-- Features -->
            <div>
              <Heading level={3} class="text-xs font-bold uppercase tracking-widest flex items-center gap-3 mb-6 text-foreground">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary">
                  <Icon name="list-checks" size={16} />
                </div>
                Core Features
              </Heading>
              <div class="flex flex-wrap gap-2">
                {provider.features.map((fid) => {
                  const name = featureNameMap.get(fid);
                  const fslug = featureSlugMap.get(fid);
                  if (!name || !fslug) return null;
                  return <a href={featureHref(fslug)} class="no-underline"><Badge tone="neutral" size="md" class="rounded-full px-4 py-1.5 hover:bg-primary/10 hover:text-primary transition-colors">{name}</Badge></a>;
                })}
              </div>
            </div>

            <!-- Protocols -->
            <div>
              <Heading level={3} class="text-xs font-bold uppercase tracking-widest flex items-center gap-3 mb-6 text-foreground">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary">
                  <Icon name="terminal" size={16} />
                </div>
                Supported Protocols
              </Heading>
              <div class="flex flex-wrap gap-2">
                {provider.protocols.map((pid) => {
                  const name = protocolNameMap.get(pid);
                  const pslug = protocolSlugMap.get(pid);
                  if (!name || !pslug) return null;
                  return <a href={protocolHref(pslug)} class="no-underline"><Badge tone="neutral" size="md" class="rounded-full px-4 py-1.5 hover:bg-primary/10 hover:text-primary transition-colors">{name}</Badge></a>;
                })}
              </div>
            </div>

            <!-- Platforms -->
            <div>
              <Heading level={3} class="text-xs font-bold uppercase tracking-widest flex items-center gap-3 mb-6 text-foreground">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary">
                  <Icon name="monitor-smartphone" size={16} />
                </div>
                Platform Support
              </Heading>
              <div class="flex flex-wrap gap-2">
                {provider.platforms.map((pid) => {
                  const name = platformNameMap.get(pid);
                  const pslug = platformSlugMap.get(pid);
                  if (!name || !pslug) return null;
                  return <a href={platformHref(pslug)} class="no-underline"><Chip class="rounded-full px-4 py-1.5 hover:bg-primary/10 hover:text-primary transition-colors">{name}</Chip></a>;
                })}
              </div>
            </div>
          </div>

          <!-- Right column: Server locations + DNS/Leak/Obfuscation -->
          <div class="space-y-10">
            <!-- Server locations -->
            <div>
              <Heading level={3} class="text-xs font-bold uppercase tracking-widest flex items-center gap-3 mb-6 text-foreground">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary">
                  <Icon name="globe" size={16} />
                </div>
                Server Locations ({provider.serverNetwork.countries.length})
              </Heading>
              <div class="flex flex-wrap gap-2">
                {provider.serverNetwork.countries.map((code) => {
                  const cslug = countrySlugMap.get(code);
                  if (!cslug) return <Chip class="rounded-full px-3 py-1">{code}</Chip>;
                  return <a href={countryHref(cslug)} class="no-underline"><Chip class="rounded-full px-3 py-1 hover:bg-primary/10 hover:text-primary transition-colors">{code}</Chip></a>;
                })}
              </div>
            </div>

            <!-- DNS / Leak / Obfuscation details inline -->
            <div class="space-y-3">
              {provider.dnsHandling && (
                <div class="rounded-lg border border-border bg-surface-sunken/50 p-3">
                  <Heading level={4} class="text-xs font-semibold flex items-center gap-1.5">
                    <Icon name="search" size={12} class="text-primary" /> DNS Handling
                  </Heading>
                  <Text size="xs" tone="muted" class="mt-1 leading-relaxed">{provider.dnsHandling}</Text>
                </div>
              )}
              {provider.leakProtection && (
                <div class="rounded-lg border border-border bg-surface-sunken/50 p-3">
                  <Heading level={4} class="text-xs font-semibold flex items-center gap-1.5">
                    <Icon name="shield" size={12} class="text-primary" /> Leak Protection
                  </Heading>
                  <Text size="xs" tone="muted" class="mt-1 leading-relaxed">{provider.leakProtection}</Text>
                </div>
              )}
              {provider.obfuscationType && provider.obfuscationType !== "none" && (
                <div class="rounded-lg border border-border bg-surface-sunken/50 p-3">
                  <Heading level={4} class="text-xs font-semibold flex items-center gap-1.5">
                    <Icon name="eye-off" size={12} class="text-primary" /> Obfuscation
                  </Heading>
                  <Text size="xs" tone="muted" class="mt-1 leading-relaxed">
                    Type: {capitalize(provider.obfuscationType)}{provider.postQuantum ? ' · Post-quantum ready' : ''}
                  </Text>
                </div>
              )}
            </div>
          </div>
        </div>
      </Card>
    </Container>
  </Section>

  <!-- ============================================================
       STREAMING
       ============================================================ -->
  {provider.streaming.length > 0 && (
    <Section background padding="loose">
      <Container>
        <div class="mb-10">
          <Badge tone="primary" size="md" class="rounded-full mb-4">Streaming</Badge>
          <Heading level={2} class="text-3xl font-bold">Streaming Support</Heading>
          <Text tone="muted" class="mt-2 text-lg">Verified compatibility with major streaming platforms.</Text>
        </div>
        <div class="rounded-3xl border border-border bg-surface p-8 shadow-sm">
          <StreamingMatrix items={provider.streaming} serviceNames={Object.fromEntries(streamingNameMap)} />
        </div>
      </Container>
    </Section>
  )}

  <!-- ============================================================
       TORRENTING
       ============================================================ -->
  {provider.torrenting.supported && (
    <Section padding="loose">
      <Container>
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10">
          <div>
            <Badge tone="primary" size="md" class="rounded-full mb-4">Torrenting</Badge>
            <Heading level={2} class="text-3xl font-bold">P2P & Torrenting</Heading>
            <Text tone="muted" class="mt-2 text-lg">Optimized for secure and fast file sharing.</Text>
          </div>
          {provider.torrenting.rating != null && (
            <ScoreRing value={provider.torrenting.rating} size={64} strokeWidth={5} label="Rating" />
          )}
        </div>
        <div class="flex flex-wrap gap-3 mb-6">
          <Badge tone="success" size="md" class="rounded-full px-4 py-1.5">P2P Supported</Badge>
          {provider.torrenting.labeledServers && <Badge tone="info" size="md" class="rounded-full px-4 py-1.5">Labeled P2P Servers</Badge>}
          {provider.torrenting.portForwarding && <Badge tone="primary" size="md" class="rounded-full px-4 py-1.5">Port Forwarding</Badge>}
        </div>
        {provider.torrenting.notes && (
          <div class="p-6 rounded-2xl bg-surface-raised border border-border text-base text-muted-foreground leading-relaxed max-w-3xl">
            {provider.torrenting.notes}
          </div>
        )}
      </Container>
    </Section>
  )}

  <!-- ============================================================
       OVERVIEW (factual MDX)
       ============================================================ -->
  {OverviewContent && (
    <Section background padding="loose">
      <Container size="prose">
        <div class="mb-10">
          <Badge tone="primary" size="md" class="rounded-full mb-4">Factual overview</Badge>
          <Heading level={2} class="text-3xl font-bold">In-Depth Overview</Heading>
        </div>
        <div class="prose prose-slate dark:prose-invert max-w-none">
          <OverviewContent />
        </div>
      </Container>
    </Section>
  )}

  <!-- ============================================================
       RELATED CONTENT
       ============================================================ -->
  <Section padding="loose">
    <Container>
      <div class="mb-10">
        <Heading level={2} class="text-3xl font-bold">Explore More</Heading>
        <Text tone="muted" class="mt-2 text-lg">Browse VPNs by feature, protocol, platform, country, or streaming service.</Text>
      </div>
      <div class="flex flex-wrap gap-3">
        <Button variant="secondary" size="md" href="/features/" class="rounded-full">Browse Features</Button>
        <Button variant="secondary" size="md" href="/protocols/" class="rounded-full">Browse Protocols</Button>
        <Button variant="secondary" size="md" href="/platforms/" class="rounded-full">Browse Platforms</Button>
        <Button variant="secondary" size="md" href="/countries/" class="rounded-full">Browse Countries</Button>
        <Button variant="secondary" size="md" href="/streaming/" class="rounded-full">Browse Streaming</Button>
        <Button variant="secondary" size="md" href="/comparisons/" class="rounded-full">Compare Providers</Button>
      </div>
    </Container>
  </Section>

  {(relatedComparisons.length > 0 || relatedGuides.length > 0) && (
    <Section background padding="loose">
      <Container>
        <div class="mb-10">
          <Heading level={2} class="text-3xl font-bold">Related Content</Heading>
        </div>
        <Grid cols={1} colsMd={2} gap={8}>
          {relatedComparisons.map((c) => (
            <Card variant="default" padding="lg" class="rounded-3xl border border-border shadow-sm hover:shadow-md transition-all">
              <Heading level={3} class="text-xl font-bold">{c.data.title}</Heading>
              <Text size="base" tone="muted" class="mt-3 leading-relaxed">{c.data.summary}</Text>
              <div class="mt-6">
                <Button variant="outline" size="sm" href={`/comparisons/${c.id}/`} class="rounded-full">Read Comparison</Button>
              </div>
            </Card>
          ))}
          {relatedGuides.map((g) => (
            <Card variant="default" padding="lg" class="rounded-3xl border border-border shadow-sm hover:shadow-md transition-all">
              <Heading level={3} class="text-xl font-bold">{g.data.title}</Heading>
              <Text size="base" tone="muted" class="mt-3 leading-relaxed">{g.data.summary}</Text>
              <div class="mt-4 flex items-center justify-between">
                <Badge tone="neutral" size="sm" class="rounded-full px-3">{capitalize(g.data.difficulty)}</Badge>
                <Button variant="outline" size="sm" href={`/guides/${g.id}/`} class="rounded-full">Read Guide</Button>
              </div>
            </Card>
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  <!-- ============================================================
       FOOTNOTES
       ============================================================ -->
  <Section padding="tight">
    <Container>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-muted-foreground">
        <span>Founded: {provider.foundedYear}</span>
        <span>·</span>
        <span>Updated: {provider.updatedAt}</span>
        {provider.audits.length > 0 && (
          <>
            <span>·</span>
            <span>{provider.audits.length} independent audit{provider.audits.length !== 1 ? "s" : ""}</span>
          </>
        )}
        {provider.ramOnlyServers && (
          <>
            <span>·</span>
            <span>RAM-only servers</span>
          </>
        )}
      </div>
    </Container>
  </Section>

</SeoLayout>




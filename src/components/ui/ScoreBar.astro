---
interface Props {
  value: number;
  label: string;
  class?: string;
}

const { value, label } = Astro.props;
const clamped = Math.min(10, Math.max(0, value));
const pct = (clamped / 10) * 100;

const color =
  clamped >= 9 ? "var(--color-success)" : clamped >= 8 ? "var(--color-primary)" : clamped >= 6 ? "var(--color-warning)" : "var(--color-danger)";
---

<div class="group flex items-center gap-4 rounded-lg px-3 py-2 -mx-3 transition-colors motion-safe:duration-150 hover:bg-surface-raised">
  <span class="w-28 text-right text-sm font-bold text-foreground shrink-0">{label}</span>
  <div class="flex-1 h-3 rounded-full bg-surface-sunken overflow-hidden border border-border/50">
    <div
      class="h-full rounded-full transition-all motion-safe:duration-700 motion-safe:ease-emphasized group-hover:brightness-110 shadow-sm"
      style={`width: ${pct}%; background-color: ${color}`}
    />
  </div>
  <span class="w-10 text-right text-sm font-bold tabular-nums text-foreground shrink-0">{value.toFixed(1)}</span>
</div>

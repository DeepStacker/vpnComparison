---
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Icon from "@/components/ui/Icon.astro";
import Button from "@/components/ui/Button.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import { SITE } from "@/constants/site";
import type { Breadcrumb } from "@/types/site";

const seo = normalizeSeoMeta({
  title: buildTitle("About FreeVPN4USA — VPN Intelligence Platform"),
  description: "FreeVPN4USA helps you choose the right VPN through transparent information, structured comparisons, educational content, and interactive decision-making tools.",
  canonical: canonicalUrl("/about/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "About", href: "/about/" },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section class="relative overflow-hidden pb-20 pt-24 md:pb-28 md:pt-32">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent"></div>
      <div class="absolute left-1/2 top-0 h-[500px] w-[1000px] -translate-x-1/2 bg-primary/5 blur-[120px]"></div>
    </div>
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <Badge tone="primary" class="mb-6">Our Story</Badge>
        <Heading level={1} class="text-4xl font-black tracking-tight md:text-6xl">
          About <span class="text-primary">{SITE.name}</span>
        </Heading>
        <Text size="xl" tone="muted" class="mt-6 max-w-2xl mx-auto leading-relaxed">
          {SITE.description}
        </Text>
      </div>
    </Container>
  </Section>

  <Section class="pb-32">
    <Container size="prose">
      <div class="prose prose-premium max-w-none">
        <Heading level={2}>Our Mission</Heading>
        <Text tone="muted" class="mt-4 leading-relaxed">
          The VPN industry is awash in affiliate playbooks, recycled "best of" lists, and vanishingly little actual testing.
          FreeVPN4USA exists to change that. Every review on this site is based on hands-on measurement — speed tests
          from multiple locations, privacy policy verification against audit reports, and real-world streaming checks
          on every major platform.
        </Text>
        <Text tone="muted" class="mt-4 leading-relaxed">
          Our goal: help you choose a VPN with confidence, whether you need privacy, streaming access, torrenting support,
          or just the fastest connection for your dollar.
        </Text>

        <Heading level={2} class="mt-16">Editorial Independence</Heading>
        <Text tone="muted" class="mt-4 leading-relaxed">
          No VPN can pay for a favorable review, influence a ranking, or review content before publication. We purchase
          our own subscriptions and disclose affiliate relationships clearly. Those relationships never determine scores
          or editorial coverage — our methodology is published in full and open to scrutiny.
        </Text>

        <Heading level={2} class="mt-16">How We Test</Heading>
        <Text tone="muted" class="mt-4 leading-relaxed">
          Every VPN is tested against a standardized rubric: speed (WireGuard, OpenVPN, proprietary protocols),
          privacy (logging policy, audits, jurisdiction), security (encryption, kill switch, leak protection),
          streaming (Netflix, Prime Video, Disney+, HBO Max, Hulu, BBC iPlayer), torrenting, and ease of use.
          We purchase our own subscriptions — no free trials or review accounts.
        </Text>
        <div class="mt-8">
          <Button variant="glass" href="/methodology/" class="rounded-xl">
            Read our full methodology &rarr;
          </Button>
        </div>

        <Heading level={2} class="mt-16">Our Team</Heading>
        <Text tone="muted" class="mt-4 leading-relaxed">
          Built by a small team of privacy advocates, security researchers, and tech journalists — backgrounds in
          cybersecurity, networking, and digital rights. United by a commitment to honest, transparent VPN analysis.
        </Text>
      </div>
    </Container>
  </Section>

  <Section class="bg-glass-subtle/50 py-32 overflow-hidden">
    <div class="pointer-events-none absolute inset-0 bg-dot-grid opacity-[0.02]" aria-hidden="true" />
    <div class="pointer-events-none absolute inset-0 after-glass-shine" aria-hidden="true" />
    <Container>
      <Card variant="glass" padding="none" class="mx-auto max-w-3xl overflow-hidden">
        <div class="p-12 text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-glass-strong text-primary border border-glass-border shadow-glass-inner mx-auto mb-8 backdrop-blur-xl">
            <Icon name="mail" size={32} />
          </div>
          <Heading level={2} class="text-3xl font-black tracking-tight">Get in Touch</Heading>
          <Text size="lg" tone="muted" class="mt-6 leading-relaxed">
            Have a question, suggestion, or correction? We'd love to hear from you.
            Reach out to us at <span class="text-foreground font-bold">{SITE.contactEmail}</span>.
          </Text>
          <div class="mt-10">
            <Button variant="primary" href="/contact/" class="rounded-xl px-8">
              Contact Us
            </Button>
          </div>
        </div>
      </Card>
    </Container>
  </Section>
</SeoLayout>

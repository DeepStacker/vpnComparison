---
/**
 * DocumentationLayout — long-form reading layout for guides and explainers.
 *
 * Features a centered prose column with an optional sticky table-of-contents
 * sidebar (xl+), a "last updated" byline, and the breadcrumbs above the title.
 * The body is provided via the default slot (rendered MDX/markdown content).
 *
 * @prop seo - page SEO metadata.
 * @prop breadcrumbs - breadcrumb trail.
 * @prop toc - optional heading list for the sidebar TOC.
 * @prop updatedAt - ISO date shown in the byline.
 * @prop readingTime - optional reading-time label.
 * @prop jsonLd - extra structured data.
 */
import SeoLayout from "./SeoLayout.astro";
import Breadcrumbs from "@/components/ui/Breadcrumbs.astro";
import { formatDate } from "@/lib/utils/date";
import { cx } from "@/lib/utils/string";
import type { JsonLdNode, SeoMeta } from "@/types/seo";
import type { Breadcrumb } from "@/types/site";

interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  seo: SeoMeta;
  breadcrumbs?: Breadcrumb[];
  toc?: TocItem[];
  updatedAt?: string;
  readingTime?: string;
  jsonLd?: JsonLdNode | JsonLdNode[];
}

const { seo, breadcrumbs = [], toc = [], updatedAt, readingTime, jsonLd } = Astro.props;
const filteredToc = toc.filter((item) => item.depth >= 2 && item.depth <= 3);
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs} renderBreadcrumbs={false} container="full" jsonLd={jsonLd}>
  <div class="relative overflow-hidden pb-20 pt-24 md:pb-28 md:pt-32">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent"></div>
      <div class="absolute left-1/2 top-0 h-[500px] w-[1000px] -translate-x-1/2 bg-primary/5 blur-[120px]"></div>
    </div>
    <div class="container-page">
      {breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} class="mb-8" />}
      <slot name="header" />
    </div>
  </div>

  <div class="container-page pb-32">
    <div class="grid gap-16 xl:grid-cols-[minmax(0,1fr)_18rem]">
      <article class="container-prose max-w-none px-0">
        <div class="prose prose-premium max-w-none">
          <slot />
        </div>
        <slot name="footer" />
      </article>

      {
        filteredToc.length > 0 && (
          <aside class="hidden xl:block" aria-label="Table of contents">
            <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto">
              <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
                <p class="mb-4 text-xs font-bold uppercase tracking-widest text-foreground">
                  On this page
                </p>
                <nav class="flex flex-col gap-3 text-sm">
                  {filteredToc.map((item) => (
                    <a
                      href={`#${item.slug}`}
                      class={cx(
                        "no-underline font-medium text-muted-foreground hover:text-primary transition-colors",
                        item.depth === 3 && "pl-4 text-xs",
                      )}
                    >
                      {item.text}
                    </a>
                  ))}
                </nav>
                {(updatedAt || readingTime) && (
                  <div class="mt-8 space-y-4 border-t border-border pt-6">
                    {readingTime && (
                      <div class="flex items-center justify-between gap-4 text-xs">
                        <span class="font-bold uppercase tracking-widest text-muted-foreground">Reading time</span>
                        <span class="font-bold text-foreground">{readingTime}</span>
                      </div>
                    )}
                    {updatedAt && (
                      <div class="flex items-center justify-between gap-4 text-xs">
                        <span class="font-bold uppercase tracking-widest text-muted-foreground">Updated</span>
                        <span class="font-bold text-foreground">{formatDate(updatedAt)}</span>
                      </div>
                    )}
                  </div>
                )}
              </div>
            </div>
          </aside>
        )
      }
    </div>
  </div>
</SeoLayout>

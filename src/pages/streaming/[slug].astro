---
import { getCollection, getEntry } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Grid from "@/components/ui/Grid.astro";
import Icon from "@/components/ui/Icon.astro";
import { getProvidersByStreamingService, getRelatedGuidesForEntity } from "@/lib/content/explorer";
import { normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

export async function getStaticPaths() {
  const services = await getCollection("streaming-services");
  return services.map((s) => ({ params: { slug: s.data.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry("streaming-services", slug);
if (!entry) return Astro.redirect("/404");

const service = entry.data;
const matches = await getProvidersByStreamingService(service.id);
const relatedGuides = await getRelatedGuidesForEntity(service.slug);

const supportTone: Record<string, string> = {
  verified: "success",
  partial: "warning",
};

const seo = normalizeSeoMeta({
  title: `Best VPNs for ${service.name} — Verified Streaming Support`,
  description: `Find VPNs that work with ${service.name}. Our hands-on testing shows which providers reliably unblock ${service.name} and which have partial or no support.`,
  canonical: canonicalUrl(`/streaming/${slug}/`),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Streaming", href: "/streaming/" },
  { label: service.name, href: `/streaming/${slug}/` },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section background padding="loose">
    <Container>
      <div class="flex items-start gap-4">
        <Icon name={service.icon as any} size={40} class="mt-1 shrink-0 text-primary" />
        <div>
          <Heading level={1}>VPNs That Work with {service.name}</Heading>
          <Text size="lg" tone="muted" class="mt-2 max-w-2xl">
            Our team tests each VPN against {service.name} to verify real-world unblocking ability. Results are labeled as verified, partial, or unsupported.
          </Text>
        </div>
      </div>
    </Container>
  </Section>

  <Section>
    <Container>
      <Heading level={2}>
        Compatible VPNs
        <Text element="span" tone="muted" size="sm" class="ml-2">({matches.length})</Text>
      </Heading>
      {matches.length === 0 && (
        <div class="mt-6 flex flex-col items-center justify-center rounded-lg border border-dashed border-border bg-surface-sunken/40 px-6 py-12 text-center">
          <Icon name="tv-off" size={28} class="text-muted-foreground" />
          <Text tone="muted" class="mt-3">No VPNs currently verified to work with {service.name}.</Text>
        </div>
      )}
      <div class="mt-6 space-y-3">
        {matches
          .sort((a, _b) => (a.support === "verified" ? -1 : 1))
          .map(({ provider, support, verifiedAt }) => (
            <Card variant="raised" padding="md" class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <Heading level={3} size="lg">{provider.name}</Heading>
                  <Badge tone={supportTone[support] as any} size="sm">
                    {support.charAt(0).toUpperCase() + support.slice(1)}
                  </Badge>
                </div>
                <Text size="sm" tone="muted" class="mt-1">{provider.tagline}</Text>
                {verifiedAt && (
                  <Text size="xs" tone="muted" class="mt-1">
                    Last verified: {verifiedAt}
                  </Text>
                )}
              </div>
              <div class="flex shrink-0 gap-2">
                <Button variant="outline" size="sm" href={`/vpn/${provider.slug}/`}>
                  View Details
                </Button>
                {support === "verified" && (
                  <Button size="sm" href={provider.websiteUrl} target="_blank" rel="noopener noreferrer">
                    Try {provider.name}
                  </Button>
                )}
              </div>
            </Card>
          ))}
      </div>
    </Container>
  </Section>

  {relatedGuides.length > 0 && (
    <Section background>
      <Container>
        <Heading level={2}>Related Guides</Heading>
        <Grid cols={1} colsMd={2} colsLg={3} gap={4} class="mt-6">
          {relatedGuides.map((g) => (
            <Card>
              <Heading level={3} size="lg">{g.data.title}</Heading>
              <Text size="sm" tone="muted" class="mt-1">{g.data.summary}</Text>
              <Badge tone="neutral" size="sm" class="mt-2">{g.data.difficulty}</Badge>
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/guides/${g.id}/`}>Read Guide</Button>
              </div>
            </Card>
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  <Section>
    <Container>
      <Heading level={2}>Explore by Other Dimensions</Heading>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/features/" class="rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium no-underline text-foreground transition-colors hover:border-primary hover:text-primary">Browse Features</a>
        <a href="/protocols/" class="rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium no-underline text-foreground transition-colors hover:border-primary hover:text-primary">Browse Protocols</a>
        <a href="/platforms/" class="rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium no-underline text-foreground transition-colors hover:border-primary hover:text-primary">Browse Platforms</a>
        <a href="/countries/" class="rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium no-underline text-foreground transition-colors hover:border-primary hover:text-primary">Browse Countries</a>
      </div>
    </Container>
  </Section>
</SeoLayout>

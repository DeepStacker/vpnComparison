---
import SeoLayout from "@/layouts/SeoLayout.astro";
import Heading from "@/components/ui/Heading.astro";
import { normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";

const settingsTabs = [
  { id: "general", label: "General", icon: "settings" },
  { id: "tools", label: "Tools", icon: "wand-2" },
  { id: "notifications", label: "Notifications", icon: "bell" },
  { id: "privacy", label: "Privacy & Data", icon: "shield" },
  { id: "appearance", label: "Appearance", icon: "palette" },
  { id: "shortcuts", label: "Keyboard Shortcuts", icon: "keyboard" },
];

const seo = normalizeSeoMeta({
  title: "Settings — Preferences & Configuration",
  description: "Manage your FreeVPN4USA preferences, tool defaults, notification settings, and privacy controls.",
  canonical: canonicalUrl("/settings/"),
});
---

<SeoLayout seo={seo} container="page">
  <div class="py-8">
    <div class="mb-8">
      <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Settings</p>
      <Heading level={1} class="text-3xl font-black tracking-tight mt-1">Preferences</Heading>
      <p class="mt-1 text-sm text-muted-foreground">Customize your experience across all tools and views.</p>
    </div>

    <div class="grid gap-8 lg:grid-cols-4">
      <!-- Sidebar Navigation -->
      <div class="lg:col-span-1">
        <nav class="space-y-1 sticky top-28">
          {settingsTabs.map((tab) => `
            <a href="#${tab.id}" data-tab="${tab.id}" class="settings-tab flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-bold text-muted-foreground no-underline transition-all duration-200 hover:bg-surface-raised hover:text-foreground">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><use href="/icons/lucide.svg#${tab.icon}"/></svg>
              ${tab.label}
            </a>
          `).join('')}
          <script>
            (() => {
              const tabs = document.querySelectorAll('.settings-tab');
              const updateActive = () => {
                const hash = window.location.hash || '#general';
                tabs.forEach((t) => {
                  const isActive = t.getAttribute('href') === hash;
                  t.classList.toggle('text-foreground', isActive);
                  t.classList.toggle('bg-primary/5', isActive);
                  t.classList.toggle('text-primary', isActive);
                  t.classList.toggle('text-muted-foreground', !isActive);
                });
              };
              tabs.forEach((t) => t.addEventListener('click', () => setTimeout(updateActive, 50)));
              updateActive();
            })();
          </script>
        </nav>
      </div>

      <!-- Settings Content -->
      <div class="lg:col-span-3 space-y-8">

        <!-- General -->
        <section id="general" class="scroll-mt-28 rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <Heading level={2} class="text-lg font-black tracking-tight mb-1">General</Heading>
          <p class="text-sm text-muted-foreground mb-6">Default preferences for tools and views.</p>
          <div class="space-y-5">
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">Default tool page</p>
                <p class="text-xs text-muted-foreground mt-0.5">Which tool to show first on the tools page</p>
              </div>
              <select class="rounded-xl border border-border bg-surface px-3 py-2 text-sm font-bold text-foreground focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/20">
                <option>VPN Recommender</option>
                <option>Comparison Builder</option>
                <option>Speed Analyzer</option>
                <option>Privacy Audit</option>
              </select>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">Default comparison count</p>
                <p class="text-xs text-muted-foreground mt-0.5">Providers to compare by default</p>
              </div>
              <select class="rounded-xl border border-border bg-surface px-3 py-2 text-sm font-bold text-foreground focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/20">
                <option>2 providers</option>
                <option selected>3 providers</option>
                <option>4 providers</option>
              </select>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">Currency display</p>
                <p class="text-xs text-muted-foreground mt-0.5">How prices are shown across the application</p>
              </div>
              <select class="rounded-xl border border-border bg-surface px-3 py-2 text-sm font-bold text-foreground focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/20">
                <option>USD ($)</option>
                <option>EUR (€)</option>
                <option>GBP (£)</option>
                <option>CAD (C$)</option>
              </select>
            </div>
          </div>
        </section>

        <!-- Tools -->
        <section id="tools" class="scroll-mt-28 rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <Heading level={2} class="text-lg font-black tracking-tight mb-1">Tools</Heading>
          <p class="text-sm text-muted-foreground mb-6">Configure how interactive tools behave.</p>
          <div class="space-y-5">
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">Show detailed breakdowns</p>
                <p class="text-xs text-muted-foreground mt-0.5">Display full category scores in tool results</p>
              </div>
              <label class="relative inline-flex h-6 w-11 cursor-pointer items-center">
                <input type="checkbox" class="peer sr-only" checked />
                <span class="absolute inset-0 rounded-full bg-primary transition-colors peer-checked:bg-primary after:absolute after:top-0.5 after:left-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-5"></span>
              </label>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">Include benchmarks</p>
                <p class="text-xs text-muted-foreground mt-0.5">Show industry benchmark comparisons in reports</p>
              </div>
              <label class="relative inline-flex h-6 w-11 cursor-pointer items-center">
                <input type="checkbox" class="peer sr-only" checked />
                <span class="absolute inset-0 rounded-full bg-primary transition-colors peer-checked:bg-primary after:absolute after:top-0.5 after:left-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-5"></span>
              </label>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">Show risk analysis</p>
                <p class="text-xs text-muted-foreground mt-0.5">Display potential risks alongside recommendations</p>
              </div>
              <label class="relative inline-flex h-6 w-11 cursor-pointer items-center">
                <input type="checkbox" class="peer sr-only" checked />
                <span class="absolute inset-0 rounded-full bg-primary transition-colors peer-checked:bg-primary after:absolute after:top-0.5 after:left-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-5"></span>
              </label>
            </div>
          </div>
        </section>

        <!-- Notifications -->
        <section id="notifications" class="scroll-mt-28 rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <Heading level={2} class="text-lg font-black tracking-tight mb-1">Notifications</Heading>
          <p class="text-sm text-muted-foreground mb-6">Choose which updates you want to see.</p>
          <div class="space-y-5">
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">New reviews</p>
                <p class="text-xs text-muted-foreground mt-0.5">When new provider reviews are published</p>
              </div>
              <label class="relative inline-flex h-6 w-11 cursor-pointer items-center">
                <input type="checkbox" class="peer sr-only" checked />
                <span class="absolute inset-0 rounded-full bg-primary transition-colors peer-checked:bg-primary after:absolute after:top-0.5 after:left-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-5"></span>
              </label>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">Comparison updates</p>
                <p class="text-xs text-muted-foreground mt-0.5">When comparisons are updated with new data</p>
              </div>
              <label class="relative inline-flex h-6 w-11 cursor-pointer items-center">
                <input type="checkbox" class="peer sr-only" checked />
                <span class="absolute inset-0 rounded-full bg-primary transition-colors peer-checked:bg-primary after:absolute after:top-0.5 after:left-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-5"></span>
              </label>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">Security alerts</p>
                <p class="text-xs text-muted-foreground mt-0.5">Provider security incidents and audit results</p>
              </div>
              <label class="relative inline-flex h-6 w-11 cursor-pointer items-center">
                <input type="checkbox" class="peer sr-only" checked />
                <span class="absolute inset-0 rounded-full bg-primary transition-colors peer-checked:bg-primary after:absolute after:top-0.5 after:left-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-5"></span>
              </label>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">Product updates</p>
                <p class="text-xs text-muted-foreground mt-0.5">New features and improvements to the platform</p>
              </div>
              <label class="relative inline-flex h-6 w-11 cursor-pointer items-center">
                <input type="checkbox" class="peer sr-only" checked />
                <span class="absolute inset-0 rounded-full bg-primary transition-colors peer-checked:bg-primary after:absolute after:top-0.5 after:left-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-5"></span>
              </label>
            </div>
          </div>
        </section>

        <!-- Privacy & Data -->
        <section id="privacy" class="scroll-mt-28 rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <Heading level={2} class="text-lg font-black tracking-tight mb-1">Privacy & Data</Heading>
          <p class="text-sm text-muted-foreground mb-6">Your privacy preferences and data controls.</p>
          <div class="space-y-5">
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">Store recent searches</p>
                <p class="text-xs text-muted-foreground mt-0.5">Save search history locally for faster access</p>
              </div>
              <label class="relative inline-flex h-6 w-11 cursor-pointer items-center">
                <input type="checkbox" class="peer sr-only" checked />
                <span class="absolute inset-0 rounded-full bg-primary transition-colors peer-checked:bg-primary after:absolute after:top-0.5 after:left-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-5"></span>
              </label>
            </div>
            <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
              <div>
                <p class="text-sm font-bold text-foreground">Analytics consent</p>
                <p class="text-xs text-muted-foreground mt-0.5">Help us improve by allowing anonymous usage data</p>
              </div>
              <label class="relative inline-flex h-6 w-11 cursor-pointer items-center">
                <input type="checkbox" class="peer sr-only" />
                <span class="absolute inset-0 rounded-full bg-border transition-colors peer-checked:bg-primary after:absolute after:top-0.5 after:left-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-5"></span>
              </label>
            </div>
            <div class="pt-4 border-t border-border">
              <button type="button" class="rounded-xl border border-border bg-surface px-4 py-2 text-sm font-bold text-foreground transition-all hover:bg-surface-raised hover:border-border-strong">
                Clear local data
              </button>
              <p class="text-xs text-muted-foreground mt-2">Removes saved searches, preferences, and cached data from this browser.</p>
            </div>
          </div>
        </section>

        <!-- Appearance -->
        <section id="appearance" class="scroll-mt-28 rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <Heading level={2} class="text-lg font-black tracking-tight mb-1">Appearance</Heading>
          <p class="text-sm text-muted-foreground mb-6">Customize the look and feel.</p>
          <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 p-4">
            <div>
              <p class="text-sm font-bold text-foreground">Theme</p>
              <p class="text-xs text-muted-foreground mt-0.5">Toggle between light, dark, and system preference</p>
            </div>
            <div class="flex gap-2">
              {['system', 'light', 'dark'].map((t) => `
                <button type="button" class="theme-btn rounded-xl border px-4 py-2 text-xs font-bold uppercase tracking-widest transition-all ${t === 'system' ? 'border-primary bg-primary/10 text-primary' : 'border-border bg-surface text-muted-foreground hover:border-primary/30'}" data-theme="${t}">${t}</button>
              `).join('')}
            </div>
          </div>
        </section>

        <!-- Keyboard Shortcuts -->
        <section id="shortcuts" class="scroll-mt-28 rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <Heading level={2} class="text-lg font-black tracking-tight mb-1">Keyboard Shortcuts</Heading>
          <p class="text-sm text-muted-foreground mb-6">Quick navigation and actions.</p>
          <div class="space-y-3">
            {[
              { keys: ["⌘", "K"], action: "Open search / command palette" },
              { keys: ["Esc"], action: "Close dialog / cancel" },
              { keys: ["↑", "↓"], action: "Navigate search results" },
              { keys: ["⏎"], action: "Open selected result" },
              { keys: ["⌘", "⇧", "D"], action: "Go to Dashboard" },
            ].map((s) => `
              <div class="flex items-center justify-between rounded-xl border border-border/50 bg-surface-sunken/40 px-4 py-3">
                <span class="text-sm text-foreground font-medium">${s.action}</span>
                <div class="flex gap-1">
                  ${s.keys.map((k) => `<kbd class="inline-flex items-center justify-center rounded-md border border-border bg-surface px-2 py-0.5 text-[11px] font-black min-w-[24px] shadow-sm">${k}</kbd>`).join('')}
                </div>
              </div>
            `).join('')}
          </div>
        </section>

        <!-- Save Button -->
        <div class="flex items-center gap-4 pt-4 border-t border-border">
          <span class="text-xs font-bold text-success flex items-center gap-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-success"></span>
            All preferences saved locally
          </span>
          <button type="button" class="rounded-xl bg-primary px-6 py-2.5 text-sm font-black uppercase tracking-widest text-primary-foreground transition-all duration-200 hover:brightness-110 shadow-lg">
            Save Preferences
          </button>
        </div>

      </div>
    </div>
  </div>
</SeoLayout>

<script>
  (() => {
    document.querySelectorAll('.theme-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.theme-btn').forEach((b) => {
          b.className = b.className.replace(/border-primary bg-primary\/10 text-primary/g, 'border-border bg-surface text-muted-foreground');
        });
        btn.className = 'theme-btn rounded-xl border px-4 py-2 text-xs font-bold uppercase tracking-widest transition-all border-primary bg-primary/10 text-primary';
      });
    });
  })();
</script>

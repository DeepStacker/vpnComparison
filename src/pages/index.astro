---
import { getCollection } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import Rating from "@/components/ui/Rating.astro";
import Grid from "@/components/ui/Grid.astro";
import { SITE } from "@/constants/site";
import { canonicalUrl, normalizeSeoMeta } from "@/lib/seo/meta";

const allProviders = await getCollection("providers");
const allReviews = await getCollection("reviews");
const allBestLists = await getCollection("best-lists");
const allGuides = await getCollection("guides");
const allComparisons = await getCollection("comparisons");

const providers = allProviders.map((e) => e.data).slice(0, 5);
const reviewMap = new Map(allReviews.map((r) => [r.data.provider.id, r.data]));
const seo = normalizeSeoMeta({ title: SITE.tagline, description: SITE.description, canonical: canonicalUrl("/") });
---

<SeoLayout seo={seo}>
  <Section background>
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <Badge tone="primary">Independent VPN Reviews Since 2025</Badge>
        <Heading level={1} class="mt-4 text-balance">{SITE.name}</Heading>
        <Text tone="muted" size="lg" class="mt-3 max-w-prose mx-auto">{SITE.description}</Text>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <Button href="/best-lists/">Browse Best VPNs</Button>
          <Button variant="outline" href="/comparisons/">Compare Services</Button>
        </div>
      </div>
    </Container>
  </Section>

  <Section id="providers">
    <Container>
      <Heading level={2}>Reviewed VPN Services</Heading>
      <Text tone="muted" class="mt-2">Hands-on testing with real data — not just marketing claims.</Text>
      <Grid cols={3} class="mt-6">
        {providers.map((p) => {
          const review = reviewMap.get(p.id);
          const score = review?.scores.overall;
          return (
            <Card>
              <Heading level={3}>{p.name}</Heading>
              <Text size="sm" tone="muted" class="mt-1">{p.tagline}</Text>
              {score != null && (
                <div class="mt-3">
                  <Rating value={score} label="Overall score" />
                </div>
              )}
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/vpn/${p.slug}/`}>Read Review</Button>
              </div>
            </Card>
          );
        })}
      </Grid>
    </Container>
  </Section>

  <Section background>
    <Container>
      <Heading level={2}>Best VPN Lists</Heading>
      <Text tone="muted" class="mt-2">Curated shortlists for every need — streaming, privacy, speed, and budget.</Text>
      <Grid cols={3} class="mt-6">
        {allBestLists.slice(0, 6).map((bl) => (
          <Card>
            <Heading level={3}>{bl.data.title}</Heading>
            <Text size="sm" tone="muted" class="mt-1">{bl.data.summary}</Text>
            <div class="mt-4">
              <Button variant="outline" size="sm" href={`/best-lists/${bl.id}/`}>View List</Button>
            </div>
          </Card>
        ))}
      </Grid>
    </Container>
  </Section>

  <Section>
    <Container>
      <Heading level={2}>Latest Guides</Heading>
      <Text tone="muted" class="mt-2">Learn how VPNs work, how to choose one, and how to set it up.</Text>
      <Grid cols={3} class="mt-6">
        {allGuides.slice(0, 6).map((g) => (
          <Card>
            <Heading level={3}>{g.data.title}</Heading>
            <Text size="sm" tone="muted" class="mt-1">{g.data.summary}</Text>
            <Badge tone="neutral" class="mt-2">{g.data.difficulty}</Badge>
            <div class="mt-4">
              <Button variant="outline" size="sm" href={`/guides/${g.id}/`}>Read Guide</Button>
            </div>
          </Card>
        ))}
      </Grid>
    </Container>
  </Section>

  <Section background>
    <Container>
      <Heading level={2}>VPN Comparisons</Heading>
      <Text tone="muted" class="mt-2">Head-to-head matchups to help you decide between top services.</Text>
      <Grid cols={3} class="mt-6">
        {allComparisons.map((c) => (
          <Card>
            <Heading level={3}>{c.data.title}</Heading>
            <Text size="sm" tone="muted" class="mt-1">{c.data.summary}</Text>
            <div class="mt-4">
              <Button variant="outline" size="sm" href={`/comparisons/${c.id}/`}>Read Comparison</Button>
            </div>
          </Card>
        ))}
      </Grid>
    </Container>
  </Section>
</SeoLayout>

---
import SeoLayout from "@/layouts/SeoLayout.astro";
import Heading from "@/components/ui/Heading.astro";
import Badge from "@/components/ui/Badge.astro";
import Icon from "@/components/ui/Icon.astro";
import { normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";

const seo = normalizeSeoMeta({
  title: "Activity — Recent Changes & Updates",
  description: "Track all recent activity across provider reviews, comparisons, audits, and tools.",
  canonical: canonicalUrl("/activity/"),
});

const activityGroups = [
  {
    date: "Today",
    items: [
      { icon: "shield-check", iconBg: "bg-success/10 text-success", label: "Mullvad passed Cure53 audit (Q3)", detail: "Independent security audit completed with zero critical findings.", time: "2 hours ago", badge: "Audit", badgeTone: "success" },
      { icon: "play", iconBg: "bg-info/10 text-info", label: "BBC iPlayer now verified on ExpressVPN", detail: "Streaming test confirmed working across all regions.", time: "5 hours ago", badge: "Streaming", badgeTone: "info" },
      { icon: "refresh-cw", iconBg: "bg-primary/10 text-primary", label: "Review data refreshed for NordVPN", detail: "Performance scores updated based on latest speed tests.", time: "8 hours ago", badge: "Data", badgeTone: "primary" },
    ]
  },
  {
    date: "Yesterday",
    items: [
      { icon: "lock", iconBg: "bg-warning/10 text-warning", label: "Surfshark quantum-resistant WireGuard update", detail: "Post-quantum cryptography support added to WireGuard implementation.", time: "1 day ago", badge: "Security", badgeTone: "warning" },
      { icon: "git-compare", iconBg: "bg-primary/10 text-primary", label: "NordVPN vs ExpressVPN comparison updated", detail: "Pricing and feature comparison refreshed with latest plan data.", time: "1 day ago", badge: "Content", badgeTone: "primary" },
      { icon: "file-text", iconBg: "bg-info/10 text-info", label: "New guide: 'VPN Protocols Explained' published", detail: "Comprehensive guide covering WireGuard, OpenVPN, IKEv2, and more.", time: "1 day ago", badge: "Content", badgeTone: "info" },
    ]
  },
  {
    date: "3 days ago",
    items: [
      { icon: "bar-chart", iconBg: "bg-success/10 text-success", label: "Speed test benchmark data refreshed", detail: "Latency and throughput measurements updated across all providers.", time: "3 days ago", badge: "Data", badgeTone: "success" },
      { icon: "users", iconBg: "bg-primary/10 text-primary", label: "New provider added: Windscribe", detail: "Full review and comparison data now available for Windscribe.", time: "3 days ago", badge: "Provider", badgeTone: "primary" },
      { icon: "globe", iconBg: "bg-info/10 text-info", label: "Server network map updated", detail: "New server locations added for ExpressVPN and CyberGhost.", time: "3 days ago", badge: "Data", badgeTone: "info" },
    ]
  },
  {
    date: "1 week ago",
    items: [
      { icon: "shield", iconBg: "bg-warning/10 text-warning", label: "CyberGhost jurisdiction review republished", detail: "Updated analysis of CyberGhost's legal and regulatory exposure.", time: "1 week ago", badge: "Policy", badgeTone: "warning" },
      { icon: "tool", iconBg: "bg-primary/10 text-primary", label: "VPN Recommender tool updated", detail: "New scoring algorithm with improved accuracy for streaming use cases.", time: "1 week ago", badge: "Product", badgeTone: "primary" },
    ]
  },
];
---

<SeoLayout seo={seo} container="page">
  <div class="py-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-8">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Activity</p>
        <Heading level={1} class="text-3xl font-black tracking-tight mt-1">Recent Activity</Heading>
        <p class="mt-1 text-sm text-muted-foreground">Track all changes, updates, and additions across the platform.</p>
      </div>
      <div class="flex items-center gap-3">
        <Badge tone="neutral" size="md" class="rounded-full gap-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
          {activityGroups.reduce((s, g) => s + g.items.length, 0)} events
        </Badge>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-4">
      <div class="lg:col-span-3 space-y-8">
        {activityGroups.map((group) => `
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xs font-black uppercase tracking-widest text-muted-foreground">${group.date}</span>
              <span class="flex-1 h-px bg-border/50"></span>
            </div>
            <div class="space-y-4">
              ${group.items.map((item) => `
                <div class="rounded-2xl border border-border bg-surface p-5 shadow-sm transition-all duration-200 hover:shadow-md hover:border-primary/20">
                  <div class="flex items-start gap-4">
                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl ${item.iconBg}">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><use href="/icons/lucide.svg#${item.icon}"/></svg>
                    </span>
                    <div class="min-w-0 flex-1">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <p class="text-base font-bold text-foreground">${item.label}</p>
                          <p class="mt-1 text-sm text-muted-foreground leading-relaxed">${item.detail}</p>
                        </div>
                        <Badge tone="${item.badgeTone}" size="sm">${item.badge}</Badge>
                      </div>
                      <p class="mt-2 text-xs text-muted-foreground">${item.time}</p>
                    </div>
                  </div>
                </div>
              `).join('')}
            </div>
          </div>
        `).join('')}
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <div class="flex items-center gap-2 mb-5">
            <Icon name="filter" size={16} class="text-primary" />
            <Heading level={2} class="text-base font-black uppercase tracking-widest">Filters</Heading>
          </div>
          <div class="space-y-3">
            {[
              { label: "All activity", count: activityGroups.reduce((s, g) => s + g.items.length, 0), active: true },
              { label: "Audits", count: 3 },
              { label: "Content updates", count: 5 },
              { label: "Data refreshes", count: 4 },
              { label: "Security", count: 2 },
              { label: "Product updates", count: 1 },
            ].map((f) => `
              <button type="button" class="filter-btn flex w-full items-center justify-between rounded-xl px-4 py-2.5 text-sm font-bold text-left transition-all duration-200 ${f.active ? 'bg-primary/10 text-primary border border-primary/20' : 'text-muted-foreground hover:text-foreground hover:bg-surface-raised border border-transparent'}">
                <span>${f.label}</span>
                <span class="text-xs font-bold text-muted-foreground bg-surface-sunken/50 rounded-full px-2 py-0.5">${f.count}</span>
              </button>
            `).join('')}
          </div>
          <script>
            (() => {
              document.querySelectorAll('.filter-btn').forEach((btn) => {
                btn.addEventListener('click', () => {
                  document.querySelectorAll('.filter-btn').forEach((b) => {
                    b.className = 'filter-btn flex w-full items-center justify-between rounded-xl px-4 py-2.5 text-sm font-bold text-left transition-all duration-200 text-muted-foreground hover:text-foreground hover:bg-surface-raised border border-transparent';
                  });
                  btn.className = 'filter-btn flex w-full items-center justify-between rounded-xl px-4 py-2.5 text-sm font-bold text-left transition-all duration-200 bg-primary/10 text-primary border border-primary/20';
                });
              });
            })();
          </script>
        </div>
      </div>
    </div>
  </div>
</SeoLayout>

---
import { getCollection, getEntry } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Grid from "@/components/ui/Grid.astro";
import Icon from "@/components/ui/Icon.astro";
import { getProvidersByCountry, getRelatedGuidesForEntity } from "@/lib/content/explorer";
import { normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

export async function getStaticPaths() {
  const countries = await getCollection("countries");
  return countries.map((c) => ({ params: { slug: c.data.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry("countries", slug);
if (!entry) return Astro.redirect("/404");

const country = entry.data;
const matches = await getProvidersByCountry(country.code);
const relatedGuides = await getRelatedGuidesForEntity(country.slug);

const regionLabels: Record<string, string> = {
  "north-america": "North America", "south-america": "South America",
  europe: "Europe", asia: "Asia", africa: "Africa",
  oceania: "Oceania", "middle-east": "Middle East",
};

const censorshipTone: Record<string, "success" | "warning" | "danger" | "neutral"> = {
  low: "success", moderate: "warning", high: "danger", extreme: "danger", unknown: "neutral",
};

const allianceNote: Record<string, string> = {
  "five-eyes": "Member of Five Eyes intelligence alliance",
  "nine-eyes": "Member of Nine Eyes intelligence alliance",
  "fourteen-eyes": "Member of 14 Eyes intelligence alliance",
  none: "Not part of any surveillance alliance",
  unknown: "Alliance status unknown",
};

const seo = normalizeSeoMeta({
  title: `VPNs with Servers in ${country.name} — Providers & Privacy Info`,
  description: `Find VPN providers with servers in ${country.name}. Compare ${matches.length} VPNs available in ${country.name}.`,
  canonical: canonicalUrl(`/countries/${slug}/`),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Countries", href: "/countries/" },
  { label: country.name, href: `/countries/${slug}/` },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section background padding="loose">
    <Container>
      <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <div class="flex items-center gap-3">
            <span class="flex h-12 w-12 items-center justify-center rounded-full bg-surface-sunken text-2xl leading-none">
              {country.flagEmoji}
            </span>
            <div>
              <Heading level={1}>{country.name}</Heading>
              <div class="flex items-center gap-2 mt-1">
                {regionLabels[country.region] && (
                  <Badge tone="neutral" size="sm">{regionLabels[country.region]}</Badge>
                )}
                {country.privacyFriendly ? (
                  <Badge tone="success" size="sm">
                    <Icon name="shield-check" size={11} class="mr-1" />Privacy-Friendly
                  </Badge>
                ) : (
                  <Badge tone="warning" size="sm">
                    <Icon name="alert-triangle" size={11} class="mr-1" />Surveillance Risk
                  </Badge>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  {country.censorshipLevel && (
    <Section>
      <Container>
        <Heading level={2}>Privacy & Internet Profile</Heading>
        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-lg border border-border bg-surface p-4">
            <Text size="xs" tone="muted" class="uppercase tracking-wide font-semibold">Censorship Level</Text>
            <div class="mt-1">
              <Badge tone={censorshipTone[country.censorshipLevel] ?? "neutral"}>
                {country.censorshipLevel.charAt(0).toUpperCase() + country.censorshipLevel.slice(1)}
              </Badge>
            </div>
          </div>
          <div class="rounded-lg border border-border bg-surface p-4">
            <Text size="xs" tone="muted" class="uppercase tracking-wide font-semibold">Surveillance</Text>
            <Text size="sm" tone="muted" class="mt-1">{allianceNote[country.surveillanceAlliance ?? "unknown"]}</Text>
          </div>
          <div class="rounded-lg border border-border bg-surface p-4">
            <Text size="xs" tone="muted" class="uppercase tracking-wide font-semibold">Data Retention Law</Text>
            <Text weight="semibold" class="mt-1">
              {country.dataRetentionLaw == null ? "Unknown" : country.dataRetentionLaw ? "Yes" : "No"}
            </Text>
          </div>
          {country.internetPenetration != null && (
            <div class="rounded-lg border border-border bg-surface p-4">
              <Text size="xs" tone="muted" class="uppercase tracking-wide font-semibold">Internet Penetration</Text>
              <Text weight="semibold" class="mt-1">{country.internetPenetration}%</Text>
            </div>
          )}
        </div>

        {country.recommendedProtocols && country.recommendedProtocols.length > 0 && (
          <div class="mt-4">
            <Text size="sm" weight="semibold" class="flex items-center gap-2">
              <Icon name="terminal" size={14} class="text-primary" /> Recommended Protocols
            </Text>
            <div class="mt-2 flex flex-wrap gap-2">
              {country.recommendedProtocols.map((p) => (
                <Badge tone="info" size="sm">{p}</Badge>
              ))}
            </div>
          </div>
        )}
      </Container>
    </Section>
  )}

  <Section background>
    <Container>
      <Heading level={2}>
        VPNs with Servers in {country.name}
        <Text element="span" tone="muted" size="sm" class="ml-2">({matches.length})</Text>
      </Heading>
      {matches.length === 0 && (
        <div class="mt-6 flex flex-col items-center justify-center rounded-lg border border-dashed border-border bg-surface-sunken/40 px-6 py-12 text-center">
          <Text tone="muted">No VPN providers currently have servers in {country.name}.</Text>
        </div>
      )}
      <Grid cols={1} colsMd={2} colsLg={3} gap={4} class="mt-6">
        {matches.map(({ provider }) => (
          <Card variant="raised" class="flex flex-col">
            <div class="flex items-start justify-between">
              <Heading level={3} size="lg">{provider.name}</Heading>
              <Badge tone="neutral" size="sm">
                {provider.serverNetwork.serverCount.toLocaleString()} servers
              </Badge>
            </div>
            <Text size="sm" tone="muted" class="mt-1">{provider.tagline}</Text>
            <div class="mt-2 flex flex-wrap gap-1.5">
              <Badge tone="info" size="sm">{provider.jurisdiction} jurisdiction</Badge>
              <Badge tone={provider.loggingPolicy === "no-logs" ? "success" : "warning"} size="sm">
                {provider.loggingPolicy.replace(/-/g, " ")}
              </Badge>
            </div>
            <div class="mt-auto pt-4">
              <Button variant="outline" size="sm" href={`/vpn/${provider.slug}/`}>View Details</Button>
            </div>
          </Card>
        ))}
      </Grid>
    </Container>
  </Section>

  {relatedGuides.length > 0 && (
    <Section>
      <Container>
        <Heading level={2}>Related Guides</Heading>
        <Grid cols={1} colsMd={2} colsLg={3} gap={4} class="mt-6">
          {relatedGuides.map((g) => (
            <Card>
              <Heading level={3} size="lg">{g.data.title}</Heading>
              <Text size="sm" tone="muted" class="mt-1">{g.data.summary}</Text>
              <Badge tone="neutral" size="sm" class="mt-2">{g.data.difficulty}</Badge>
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/guides/${g.id}/`}>Read Guide</Button>
              </div>
            </Card>
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  <Section background padding="tight">
    <Container>
      <Heading level={2} class="text-center">Explore by Other Dimensions</Heading>
      <div class="mt-4 flex flex-wrap justify-center gap-3">
        <Button variant="outline" size="sm" href="/features/">Browse Features</Button>
        <Button variant="outline" size="sm" href="/protocols/">Browse Protocols</Button>
        <Button variant="outline" size="sm" href="/platforms/">Browse Platforms</Button>
        <Button variant="outline" size="sm" href="/streaming/">Browse Streaming</Button>
        <Button variant="outline" size="sm" href="/comparisons/">Compare Providers</Button>
      </div>
    </Container>
  </Section>
</SeoLayout>

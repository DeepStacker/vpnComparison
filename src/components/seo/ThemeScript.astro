---
/**
 * ThemeScript — inline, no-flash theme resolver placed in <head>.
 * Sets `class="dark"` on <html> before first paint using (in order):
 *   1. the user's saved preference in localStorage("nh-theme")
 *   2. the OS `prefers-color-scheme` media query
 * The script is inlined (no module wait) so there is no flash of wrong theme.
 * @prop defaultTheme - fallback when no stored preference exists.
 */
import type { ThemePreference } from "@/types/site";

interface Props {
  defaultTheme?: ThemePreference;
}

const { defaultTheme = "system" } = Astro.props;
const defaultThemeJson = JSON.stringify(defaultTheme);

const script = `
(function () {
  try {
    var stored = localStorage.getItem("nh-theme");
    var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    var fallback = prefersDark ? "dark" : "light";
    var theme = stored || (${defaultThemeJson} === "system" ? fallback : ${defaultThemeJson});
    if (theme === "dark") document.documentElement.classList.add("dark");
    else document.documentElement.classList.remove("dark");
    document.documentElement.style.colorScheme = theme;
  } catch (e) {}
})();
`;
---

<script is:inline set:html={script} />

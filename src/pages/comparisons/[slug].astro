---
import { getCollection, getEntry, render } from "astro:content";
import ComparisonLayout from "@/layouts/ComparisonLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Rating from "@/components/ui/Rating.astro";
import Icon from "@/components/ui/Icon.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

export async function getStaticPaths() {
  const comparisons = await getCollection("comparisons");
  return comparisons.map((c) => ({ params: { slug: c.id } }));
}

const { slug } = Astro.params;
const comparisonEntry = await getEntry("comparisons", slug);
if (!comparisonEntry) return Astro.redirect("/404");

const comparison = comparisonEntry.data;
const { Content } = await render(comparisonEntry);

const providerEntries = await Promise.all(
  comparison.providers.map((ref) => getEntry("providers", ref.id)),
);
const providers = providerEntries.filter(Boolean).map((e) => e!.data);

const providerMap = new Map(providers.map((p) => [p.id, p]));

const allReviews = await getCollection("reviews");
const reviewMap = new Map(allReviews.map((r) => [r.data.provider.id, r.data]));

const winnerEntry = comparison.winner ? providerMap.get(comparison.winner.id) : null;

const seo = normalizeSeoMeta({
  title: buildTitle(comparison.title),
  description: comparison.summary,
  canonical: canonicalUrl(`/comparisons/${slug}/`),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "VPN Comparisons", href: "/comparisons/" },
  { label: comparison.title, href: `/comparisons/${slug}/` },
];
---

<ComparisonLayout seo={seo} breadcrumbs={breadcrumbs}>
  <div slot="summary" class="max-w-4xl">
    {winnerEntry && (
      <Badge tone="success" size="md" class="mb-6 shadow-sm">
        <Icon name="trophy" size={14} class="mr-2" />
        Winner: {winnerEntry.name}
      </Badge>
    )}
    <Heading level={1} class="text-4xl font-black tracking-tight md:text-6xl">
      {comparison.title}
    </Heading>
    <Text size="xl" tone="muted" class="mt-6 leading-relaxed">
      {comparison.summary}
    </Text>
    <div class="mt-8 flex flex-wrap items-center gap-6">
      {comparison.publishedAt && (
        <div class="flex items-center gap-2 text-sm font-bold text-muted-foreground uppercase tracking-widest">
          <Icon name="calendar" size={16} />
          Published {comparison.publishedAt}
        </div>
      )}
      {comparison.updatedAt && (
        <div class="flex items-center gap-2 text-sm font-bold text-primary uppercase tracking-widest">
          <Icon name="refresh-cw" size={16} />
          Updated {comparison.updatedAt}
        </div>
      )}
    </div>
  </div>

  <Section class="mt-12">
    <Container>
      <div class="grid gap-12 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <div class="prose prose-premium max-w-none">
            <Content />
          </div>
        </div>
        
        <aside class="space-y-8">
          {providers.map((p) => {
            const review = reviewMap.get(p.id);
            return (
              <Card variant="raised" padding="none" class="overflow-hidden">
                <div class="p-6">
                  <div class="flex items-center gap-4 mb-6">
                    <div class="h-12 w-12 rounded-2xl bg-surface-sunken border border-border flex items-center justify-center p-2 shadow-sm">
                      <img src={`/logos/${p.id}.svg`} alt={p.name} class="h-full w-full object-contain" />
                    </div>
                    <div>
                      <Heading level={3} class="text-xl font-bold">{p.name}</Heading>
                      {review && <Rating value={review.scores.overall} max={10} size={14} class="mt-1" />}
                    </div>
                  </div>
                  
                  <div class="space-y-4">
                    <div class="flex items-center justify-between text-sm">
                      <span class="text-muted-foreground font-medium">Starting Price</span>
                      <span class="font-bold text-foreground">${p.pricing.plans.find((pl) => pl.featured)?.effectiveMonthly ?? p.pricing.plans[0]?.effectiveMonthly ?? 0}/mo</span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                      <span class="text-muted-foreground font-medium">Money Back</span>
                      <span class="font-bold text-foreground">{p.pricing.moneyBackGuaranteeDays} Days</span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                      <span class="text-muted-foreground font-medium">Simultaneous</span>
                      <span class="font-bold text-foreground">{p.simultaneousConnections} Devices</span>
                    </div>
                  </div>
                  
                  <div class="mt-8 grid grid-cols-2 gap-3">
                    <Button variant="primary" size="sm" href={p.affiliateUrl} target="_blank" rel="sponsored" class="w-full">
                      Visit Site
                    </Button>
                    {review && (
                      <Button variant="outline" size="sm" href={`/vpn/${p.id}/`} class="w-full">
                        Review
                      </Button>
                    )}
                  </div>
                </div>
              </Card>
            );
          })}
        </aside>
      </div>
    </Container>
  </Section>
</ComparisonLayout>


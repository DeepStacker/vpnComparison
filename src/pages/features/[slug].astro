---
import { getCollection, getEntry } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Grid from "@/components/ui/Grid.astro";
import Icon from "@/components/ui/Icon.astro";
import { getProvidersByFeature, getRelatedGuidesForEntity } from "@/lib/content/explorer";
import { normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

export async function getStaticPaths() {
  const features = await getCollection("features");
  return features.map((f) => ({ params: { slug: f.data.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry("features", slug);
if (!entry) return Astro.redirect("/404");

const feature = entry.data;
const matches = await getProvidersByFeature(feature.id);
const relatedGuides = await getRelatedGuidesForEntity(feature.slug);

const categoryLabels: Record<string, string> = {
  security: "Security", privacy: "Privacy", performance: "Performance",
  streaming: "Streaming", torrenting: "Torrenting", usability: "Usability",
  advanced: "Advanced", pricing: "Pricing",
};

const importanceTone: Record<string, string> = {
  essential: "danger", important: "warning", "nice-to-have": "neutral", specialized: "info",
};

const seo = normalizeSeoMeta({
  title: `VPNs with ${feature.name} — Provider Comparison`,
  description: `Find VPN providers that offer ${feature.name.toLowerCase()}. ${feature.description} Compare ${matches.length} VPNs with this feature.`,
  canonical: canonicalUrl(`/features/${slug}/`),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Features", href: "/features/" },
  { label: feature.name, href: `/features/${slug}/` },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section background padding="loose">
    <Container>
      <div class="flex flex-col items-start gap-4">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <Badge>{categoryLabels[feature.category] ?? feature.category}</Badge>
            {feature.importance && (
              <Badge tone={importanceTone[feature.importance] as any} size="sm">
                {feature.importance.replace(/-/g, " ")}
              </Badge>
            )}
          </div>
          <Heading level={1}>{feature.name}</Heading>
          <Text size="lg" tone="muted" class="mt-2 max-w-2xl">{feature.description}</Text>
        </div>
      </div>
    </Container>
  </Section>

  {feature.technicalExplanation && (
    <Section>
      <Container>
        <Heading level={2}>How It Works</Heading>
        <Text tone="muted" class="mt-3 leading-relaxed max-w-3xl">{feature.technicalExplanation}</Text>

        {(feature.advantages || feature.disadvantages) && (
          <Grid cols={1} colsMd={2} gap={6} class="mt-6">
            {feature.advantages && feature.advantages.length > 0 && (
              <Card variant="raised" padding="lg" class="border-t-4 border-success">
                <Heading level={3}>
                  <span class="flex items-center gap-2 text-success">
                    <Icon name="circle-check" size={18} /> Advantages
                  </span>
                </Heading>
                <ul class="mt-3 space-y-2">
                  {feature.advantages.map((a) => (
                    <li class="flex items-start gap-2 text-sm text-foreground">
                      <Icon name="check" size={14} class="mt-0.5 shrink-0 text-success" />
                      <span>{a}</span>
                    </li>
                  ))}
                </ul>
              </Card>
            )}
            {feature.disadvantages && feature.disadvantages.length > 0 && (
              <Card variant="raised" padding="lg" class="border-t-4 border-danger">
                <Heading level={3}>
                  <span class="flex items-center gap-2 text-danger">
                    <Icon name="circle-x" size={18} /> Disadvantages
                  </span>
                </Heading>
                <ul class="mt-3 space-y-2">
                  {feature.disadvantages.map((d) => (
                    <li class="flex items-start gap-2 text-sm text-foreground">
                      <Icon name="x" size={14} class="mt-0.5 shrink-0 text-danger" />
                      <span>{d}</span>
                    </li>
                  ))}
                </ul>
              </Card>
            )}
          </Grid>
        )}

        {(feature.securityImpact || feature.performanceImpact) && (
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            {feature.securityImpact && (
              <div class="rounded-lg border border-border bg-surface p-4">
                <Heading level={4} class="text-sm font-semibold flex items-center gap-2">
                  <Icon name="shield" size={14} class="text-primary" /> Security Impact
                </Heading>
                <Text size="sm" tone="muted" class="mt-1 leading-relaxed">{feature.securityImpact}</Text>
              </div>
            )}
            {feature.performanceImpact && (
              <div class="rounded-lg border border-border bg-surface p-4">
                <Heading level={4} class="text-sm font-semibold flex items-center gap-2">
                  <Icon name="zap" size={14} class="text-primary" /> Performance Impact
                </Heading>
                <Text size="sm" tone="muted" class="mt-1 leading-relaxed">{feature.performanceImpact}</Text>
              </div>
            )}
          </div>
        )}

        {feature.idealUsers && feature.idealUsers.length > 0 && (
          <div class="mt-6">
            <Heading level={3} class="text-base">Ideal For</Heading>
            <div class="mt-2 flex flex-wrap gap-2">
              {feature.idealUsers.map((u) => (
                <Badge tone="info" size="sm">{u}</Badge>
              ))}
            </div>
          </div>
        )}
      </Container>
    </Section>
  )}

  <Section background>
    <Container>
      <Heading level={2}>
        Providers with {feature.name}
        <Text element="span" tone="muted" size="sm" class="ml-2">({matches.length})</Text>
      </Heading>
      {matches.length === 0 && (
        <div class="mt-6 flex flex-col items-center justify-center rounded-lg border border-dashed border-border bg-surface-sunken/40 px-6 py-12 text-center">
          <Text tone="muted">No VPN providers currently offer {feature.name.toLowerCase()}.</Text>
        </div>
      )}
      <Grid cols={1} colsMd={2} colsLg={3} gap={4} class="mt-6">
        {matches.map(({ provider }) => (
          <Card variant="raised" class="flex flex-col">
            <Heading level={3} size="lg">{provider.name}</Heading>
            <Text size="sm" tone="muted" class="mt-1">{provider.tagline}</Text>
            <div class="mt-2 flex flex-wrap gap-1.5">
              <Badge tone="neutral" size="sm">{provider.serverNetwork.serverCount.toLocaleString()} servers</Badge>
              <Badge tone="success" size="sm">{provider.simultaneousConnections === 0 ? "Unlimited" : `${provider.simultaneousConnections} devices`}</Badge>
            </div>
            <div class="mt-auto pt-4">
              <Button variant="outline" size="sm" href={`/vpn/${provider.slug}/`}>View Details</Button>
            </div>
          </Card>
        ))}
      </Grid>
    </Container>
  </Section>

  {relatedGuides.length > 0 && (
    <Section>
      <Container>
        <Heading level={2}>Related Guides</Heading>
        <Grid cols={1} colsMd={2} colsLg={3} gap={4} class="mt-6">
          {relatedGuides.map((g) => (
            <Card>
              <Heading level={3} size="lg">{g.data.title}</Heading>
              <Text size="sm" tone="muted" class="mt-1">{g.data.summary}</Text>
              <Badge tone="neutral" size="sm" class="mt-2">{g.data.difficulty}</Badge>
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/guides/${g.id}/`}>Read Guide</Button>
              </div>
            </Card>
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  <Section background padding="tight">
    <Container>
      <Heading level={2} class="text-center">Explore by Other Dimensions</Heading>
      <div class="mt-4 flex flex-wrap justify-center gap-3">
        <Button variant="outline" size="sm" href="/protocols/">Browse Protocols</Button>
        <Button variant="outline" size="sm" href="/platforms/">Browse Platforms</Button>
        <Button variant="outline" size="sm" href="/countries/">Browse Countries</Button>
        <Button variant="outline" size="sm" href="/streaming/">Browse Streaming</Button>
      </div>
    </Container>
  </Section>
</SeoLayout>

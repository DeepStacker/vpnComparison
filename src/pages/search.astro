---
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import SearchBar from "@/components/search/SearchBar.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

const seo = normalizeSeoMeta({
  title: buildTitle("Search — Find VPN Reviews, Guides & Comparisons"),
  description: "Search FreeVPN4USA for VPN reviews, comparisons, guides, and FAQs.",
  canonical: canonicalUrl("/search/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Search", href: "/search/" },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section background>
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <Heading level={1}>Search</Heading>
        <Text tone="muted" size="lg" class="mt-3 max-w-prose mx-auto">
          Find VPN reviews, comparisons, guides, and FAQs.
        </Text>
        <div class="mt-6">
          <SearchBar />
        </div>
        <Text size="sm" tone="muted" class="mt-3">
          Search results will appear below. This page requires JavaScript for full search functionality.
        </Text>
      </div>
    </Container>
  </Section>
</SeoLayout>

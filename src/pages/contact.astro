---
import SeoLayout from "@/layouts/SeoLayout.astro";
import Heading from "@/components/ui/Heading.astro";
import Icon from "@/components/ui/Icon.astro";
import { SITE } from "@/constants/site";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

const seo = normalizeSeoMeta({
  title: buildTitle("Contact Us — Get in Touch"),
  description: `Get in touch with the ${SITE.name} team. Review inquiries, feedback, or press: we'd love to hear from you.`,
  canonical: canonicalUrl("/contact/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Contact", href: "/contact/" },
];

const contacts = [
  { title: "General Inquiries", email: "hello@freevpn4usa.com", icon: "mail", desc: "Questions about our reviews, methodology, or the site." },
  { title: "Review Requests", email: "reviews@freevpn4usa.com", icon: "file-text", desc: "VPN providers interested in having their service reviewed." },
  { title: "Press & Media", email: "press@freevpn4usa.com", icon: "mic", desc: "Interview requests, data citations, or expert commentary." },
  { title: "Corrections", email: "corrections@freevpn4usa.com", icon: "alert-triangle", desc: "Spotted an error? Send us the page URL and the correction needed." },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <div class="py-8">
    <div class="mb-8">
      <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Contact</p>
      <Heading level={1} class="text-3xl font-black tracking-tight mt-1">Get in Touch</Heading>
      <p class="mt-1 text-sm text-muted-foreground max-w-xl">Have a question, feedback, or press inquiry? We'd love to hear from you.</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 mb-10">
      {contacts.map((c) => `
        <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm transition-all duration-200 hover:shadow-md hover:border-primary/20 group">
          <div class="flex items-start gap-4">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/5 text-primary border border-primary/10 group-hover:bg-primary group-hover:text-primary-foreground transition-all">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><use href="/icons/lucide.svg#${c.icon}"/></svg>
            </span>
            <div class="min-w-0">
              <Heading level={2} class="text-base font-bold">${c.title}</Heading>
              <p class="mt-1 text-sm text-muted-foreground">${c.desc}</p>
              <a href="mailto:${c.email}" class="mt-2 inline-block text-sm font-bold text-primary no-underline hover:underline">${c.email}</a>
            </div>
          </div>
        </div>
      `).join('')}
    </div>

    <div class="rounded-2xl border border-border bg-surface-sunken/30 p-6">
      <div class="flex items-center gap-2 mb-4">
        <Icon name="info" size={16} class="text-primary" />
        <Heading level={2} class="text-sm font-black uppercase tracking-widest">Response Time</Heading>
      </div>
      <p class="text-sm text-muted-foreground leading-relaxed">We typically respond to all inquiries within 48 hours during business days. For urgent matters, please include "URGENT" in your subject line and we'll prioritize your message.</p>
    </div>
  </div>
</SeoLayout>

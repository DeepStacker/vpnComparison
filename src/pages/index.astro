---
import { getCollection } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import Grid from "@/components/ui/Grid.astro";
import Icon from "@/components/ui/Icon.astro";
import { SITE } from "@/constants/site";
import { canonicalUrl, normalizeSeoMeta } from "@/lib/seo/meta";

const allProviders = await getCollection("providers");
const allReviews = await getCollection("reviews");
const allBestLists = await getCollection("best-lists");
const allGuides = await getCollection("guides");
const allComparisons = await getCollection("comparisons");

const providers = allProviders.map((e) => e.data).slice(0, 5);
const reviewMap = new Map(allReviews.map((r) => [r.data.provider.id, r.data]));

const avgScore =
  allReviews.reduce((sum, r) => sum + r.data.scores.overall, 0) / allReviews.length;

const seo = normalizeSeoMeta({ title: SITE.tagline, description: SITE.description, canonical: canonicalUrl("/") });
---

<SeoLayout seo={seo}>
  <Section background>
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <Badge tone="primary">Independent VPN Reviews Since 2025</Badge>
        <Heading level={1} class="mt-5 text-balance leading-tight">{SITE.name}</Heading>
        <Text tone="muted" size="lg" class="mt-3 max-w-prose mx-auto leading-relaxed">{SITE.description}</Text>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <Button href="/best-lists/">Browse Best VPNs</Button>
          <Button variant="outline" href="/comparisons/">Compare Services</Button>
        </div>
      </div>
    </Container>
  </Section>

  <Section id="providers">
    <Container>
      <div class="mb-2">
        <Badge tone="primary" size="sm">Hands-on testing</Badge>
      </div>
      <Heading level={2}>Reviewed VPN Services</Heading>
      <Text tone="muted" class="mt-2 max-w-xl">
        Every VPN on this site has been independently tested. We measure speed, verify privacy claims, and assess real-world streaming performance.
      </Text>
      <Grid cols={3} class="mt-8">
        {providers.map((p) => {
          const review = reviewMap.get(p.id);
          const score = review?.scores.overall;
          return (
            <Card class="flex flex-col">
              <div class="flex items-start justify-between">
                <Heading level={3}>{p.name}</Heading>
                {score != null && (
                  <Badge tone={score >= 9 ? "success" : score >= 8 ? "primary" : "neutral"} size="sm">
                    {score.toFixed(1)}
                  </Badge>
                )}
              </div>
              <Text size="sm" tone="muted" class="mt-1 leading-relaxed">{p.tagline}</Text>
              <div class="mt-auto pt-4">
                <Button variant="outline" size="sm" href={`/vpn/${p.slug}/`}>
                  Read Review <Icon name="arrow-right" size={14} class="ml-1" />
                </Button>
              </div>
            </Card>
          );
        })}
      </Grid>
    </Container>
  </Section>

  <Section background>
    <Container>
      <div class="mb-2">
        <Badge tone="primary" size="sm">Curated recommendations</Badge>
      </div>
      <Heading level={2}>Best VPN Lists</Heading>
      <Text tone="muted" class="mt-2 max-w-xl">Shortlists for every need — streaming, privacy, speed, and budget — ranked by transparent criteria.</Text>
      <Grid cols={3} class="mt-8">
        {allBestLists.slice(0, 6).map((bl) => (
          <Card class="flex flex-col">
            <Heading level={3}>{bl.data.title}</Heading>
            <Text size="sm" tone="muted" class="mt-1 leading-relaxed">{bl.data.summary}</Text>
            <div class="mt-2 flex items-center gap-2">
              <Badge tone="neutral" size="sm">{bl.data.entries.length} entries</Badge>
            </div>
            <div class="mt-auto pt-4">
              <Button variant="outline" size="sm" href={`/best-lists/${bl.id}/`}>
                View List <Icon name="arrow-right" size={14} class="ml-1" />
              </Button>
            </div>
          </Card>
        ))}
      </Grid>
    </Container>
  </Section>

  <Section>
    <Container>
      <div class="mb-2">
        <Badge tone="primary" size="sm">Educational resources</Badge>
      </div>
      <Heading level={2}>Latest Guides</Heading>
      <Text tone="muted" class="mt-2 max-w-xl">Learn how VPNs work, how to choose one, and how to set it up — written for beginners and experts alike.</Text>
      <Grid cols={3} class="mt-8">
        {allGuides.slice(0, 6).map((g) => (
          <Card class="flex flex-col">
            <Heading level={3}>{g.data.title}</Heading>
            <Text size="sm" tone="muted" class="mt-1 leading-relaxed">{g.data.summary}</Text>
            <div class="mt-2 flex items-center gap-2">
              <Badge
                tone={g.data.difficulty === "beginner" ? "success" : g.data.difficulty === "intermediate" ? "primary" : "warning"}
                size="sm"
              >
                {g.data.difficulty}
              </Badge>
            </div>
            <div class="mt-auto pt-4">
              <Button variant="outline" size="sm" href={`/guides/${g.id}/`}>
                Read Guide <Icon name="arrow-right" size={14} class="ml-1" />
              </Button>
            </div>
          </Card>
        ))}
      </Grid>
    </Container>
  </Section>

  <Section background>
    <Container>
      <div class="mb-2">
        <Badge tone="primary" size="sm">Head-to-head</Badge>
      </div>
      <Heading level={2}>VPN Comparisons</Heading>
      <Text tone="muted" class="mt-2 max-w-xl">Side-by-side matchups across speed, privacy, features, and value to help you make an informed choice.</Text>
      <Grid cols={3} class="mt-8">
        {allComparisons.map((c) => (
          <Card class="flex flex-col">
            {c.data.winner && (
              <Badge tone="success" size="sm" class="mb-2 self-start">
                <Icon name="trophy" size={12} class="mr-1" />
                Winner
              </Badge>
            )}
            <Heading level={3}>{c.data.title}</Heading>
            <Text size="sm" tone="muted" class="mt-1 leading-relaxed">{c.data.summary}</Text>
            <div class="mt-auto pt-4">
              <Button variant="outline" size="sm" href={`/comparisons/${c.id}/`}>
                Read Comparison <Icon name="arrow-right" size={14} class="ml-1" />
              </Button>
            </div>
          </Card>
        ))}
      </Grid>
    </Container>
  </Section>

  <Section padding="loose">
    <Container>
      <div class="mx-auto max-w-xl text-center">
        <Icon name="shield-check" size={32} class="mx-auto text-primary" />
        <Heading level={2} class="mt-4">Why Trust Our Reviews?</Heading>
        <Text tone="muted" class="mt-3 leading-relaxed">
          Every VPN is tested using a consistent methodology. We measure speeds from multiple locations, verify privacy claims against audit reports, and test streaming unblocking on every major platform. Our editorial team maintains full independence — no payment or partnership influences our scores or recommendations.
        </Text>
        <div class="mt-6 flex flex-wrap justify-center gap-6">
          <div class="text-center">
            <Text size="xl" weight="semibold">{providers.length}</Text>
            <Text size="sm" tone="muted">VPNs tested</Text>
          </div>
          <div class="text-center">
            <Text size="xl" weight="semibold">{avgScore.toFixed(1)}</Text>
            <Text size="sm" tone="muted">Avg. score</Text>
          </div>
          <div class="text-center">
            <Text size="xl" weight="semibold">{allGuides.length}</Text>
            <Text size="sm" tone="muted">Guides published</Text>
          </div>
        </div>
        <div class="mt-8">
          <Button variant="outline" href="/methodology/">View Methodology</Button>
        </div>
      </div>
    </Container>
  </Section>
</SeoLayout>

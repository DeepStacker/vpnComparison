---
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import { SITE, copyrightYears } from "@/constants/site";
import type { Breadcrumb } from "@/types/site";

const seo = normalizeSeoMeta({
  title: buildTitle("Terms of Service"),
  description: `FreeVPN4USA terms of service — rules and guidelines for using our website and services.`,
  canonical: canonicalUrl("/terms/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Terms of Service", href: "/terms/" },
];

const yearRange = copyrightYears();
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section background>
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <Heading level={1}>Terms of Service</Heading>
        <Text tone="muted" size="lg" class="mt-3 max-w-prose mx-auto">
          Last updated: January 1, 2025
        </Text>
      </div>
    </Container>
  </Section>

  <Section>
    <Container size="prose">
      <Heading level={2}>Introduction</Heading>
      <Text tone="muted" class="mt-2">
        Welcome to {SITE.name}. By accessing or using our website at {SITE.url}, you agree to comply with
        and be bound by these Terms of Service. If you do not agree with any part of these terms, you must
        not use our website.
      </Text>

      <Heading level={2} class="mt-10">Use of the Website</Heading>
      <Text tone="muted" class="mt-2">
        By using our website, you represent and warrant that:
      </Text>
      <ul class="mt-2 space-y-1 text-sm text-muted-foreground">
        <li>You are at least 18 years of age or accessing the website under the supervision of a parent or guardian.</li>
        <li>You will not use the website for any unlawful purpose or in violation of any applicable laws or regulations.</li>
        <li>You will not attempt to interfere with the proper functioning of the website.</li>
        <li>You will not reproduce, distribute, modify, or create derivative works from our content without prior written consent.</li>
      </ul>

      <Heading level={2} class="mt-10">Intellectual Property</Heading>
      <Text tone="muted" class="mt-2">
        All content on this website — including reviews, comparisons, guides, ratings, images, logos, and
        software — is the property of {SITE.name} or its content suppliers and is protected by applicable
        copyright and intellectual property laws. You may not reproduce, distribute, or create derivative
        works from our content without our express written permission.
      </Text>

      <Heading level={2} class="mt-10">Affiliate Disclosure</Heading>
      <Text tone="muted" class="mt-2">
        {SITE.name} participates in affiliate marketing programs. This means we may earn commissions when
        you click on certain links to VPN provider websites and make a purchase. These affiliate relationships
        do not influence our editorial content, rankings, or reviews.
      </Text>
      <Text tone="muted" class="mt-3">
        Our reviews and comparisons are based on independent testing and analysis. We maintain strict editorial
        independence and do not accept payment for favorable coverage.
      </Text>

      <Heading level={2} class="mt-10">Accuracy of Information</Heading>
      <Text tone="muted" class="mt-2">
        While we strive to provide accurate and up-to-date information, we make no representations or warranties
        of any kind regarding the completeness, accuracy, reliability, suitability, or availability of the
        information on our website. VPN services change frequently, and readers should verify critical details
        (such as pricing, features, and privacy policies) directly with the provider.
      </Text>

      <Heading level={2} class="mt-10">Third-Party Links</Heading>
      <Text tone="muted" class="mt-2">
        Our website contains links to third-party websites, including VPN provider sites and affiliate partners.
        We have no control over the content, privacy policies, or practices of these third-party sites and
        assume no responsibility for them. We encourage you to review the terms and privacy policies of any
        third-party sites you visit.
      </Text>

      <Heading level={2} class="mt-10">Limitation of Liability</Heading>
      <Text tone="muted" class="mt-2">
        In no event shall {SITE.name}, its affiliates, or its contributors be liable for any indirect,
        incidental, special, consequential, or punitive damages arising out of or related to your use of
        the website or the information provided herein. This includes, but is not limited to, damages for
        loss of profits, data, or goodwill.
      </Text>

      <Heading level={2} class="mt-10">Disclaimer</Heading>
      <Text tone="muted" class="mt-2">
        The information provided on {SITE.name} is for general informational purposes only. It does not
        constitute professional advice (legal, financial, or otherwise). You should consult with appropriate
        professionals for advice specific to your situation.
      </Text>
      <Text tone="muted" class="mt-3">
        We make no guarantees regarding the effectiveness of any VPN service for specific purposes such as
        bypassing geo-restrictions, preventing tracking, or securing data. Results may vary based on your
        location, device, network configuration, and the specific VPN provider's current capabilities.
      </Text>

      <Heading level={2} class="mt-10">Changes to Terms</Heading>
      <Text tone="muted" class="mt-2">
        We reserve the right to modify these Terms of Service at any time. Changes will be effective immediately
        upon posting to this page. Your continued use of the website after any modifications constitutes your
        acceptance of the updated terms.
      </Text>

      <Heading level={2} class="mt-10">Governing Law</Heading>
      <Text tone="muted" class="mt-2">
        These Terms of Service shall be governed by and construed in accordance with the laws of the United States
        and the State of California, without regard to its conflict of law provisions.
      </Text>

      <Heading level={2} class="mt-10">Contact</Heading>
      <Text tone="muted" class="mt-2">
        If you have any questions about these Terms of Service, please contact us at {SITE.contactEmail}.
      </Text>

      <div class="mt-10 border-t border-border pt-6">
        <Text size="sm" tone="muted">&copy; {yearRange} {SITE.name}. All rights reserved.</Text>
      </div>
    </Container>
  </Section>
</SeoLayout>

---
import { getCollection } from "astro:content";
import ToolLayout from "@/layouts/ToolLayout.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Badge from "@/components/ui/Badge.astro";
import { normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import VpnHealth from "@/components/tools/VpnHealth.astro";
import type { Breadcrumb } from "@/types/site";

const allProviders = await getCollection("providers");
const allReviews = await getCollection("reviews");

const providers = allProviders.map((e) => e.data);
const reviews = allReviews.map((e) => ({
  providerId: e.data.provider.id,
  scores: e.data.scores,
  verdict: e.data.verdict,
}));

const seo = normalizeSeoMeta({
  title: "Health Check — Comprehensive Provider Health Assessment",
  description: "Score a VPN provider across 8 health dimensions including privacy, security, streaming, usability, and business viability.",
  canonical: canonicalUrl("/tools/health/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "VPN Tools", href: "/tools/" },
  { label: "Health Check", href: "/tools/health/" },
];
---

<ToolLayout seo={seo} breadcrumbs={breadcrumbs}>
  <div class="mb-8 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <Badge tone="success" class="mb-3">Health assessment</Badge>
      <Heading level={1} class="text-3xl font-black tracking-tight md:text-4xl">Provider Health Check</Heading>
      <Text size="base" tone="muted" class="mt-2 max-w-2xl leading-relaxed">
        Multi-dimensional health assessment across privacy, security, performance, streaming, and business viability. Get a comprehensive health score with strengths, weaknesses, and recommendations.
      </Text>
    </div>
    <a href="/tools/" class="text-sm font-bold uppercase tracking-widest text-primary no-underline">← Back to tools</a>
  </div>

  <VpnHealth providers={providers} reviews={reviews} />
</ToolLayout>

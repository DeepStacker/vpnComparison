---
/**
 * Tag — bordered keyword label, typically used for content taxonomy.
 * @prop tone - "neutral" | "primary" | "success" | "warning" | "danger" | "info".
 * @prop href - render as a link instead of a span.
 */
import { cx } from "@/lib/utils/string";

interface Props {
  tone?: "neutral" | "primary" | "success" | "warning" | "danger" | "info";
  href?: string;
  class?: string;
}

const { tone = "neutral", href, class: className } = Astro.props;
const Tag = href ? "a" : "span";

const toneClass: Record<string, string> = {
  neutral: "border-border text-muted-foreground hover:bg-surface-raised hover:border-border-strong",
  primary: "border-primary/30 text-primary bg-primary/5 hover:bg-primary/10 hover:border-primary/50",
  success: "border-success/30 text-success bg-success/5 hover:bg-success/10 hover:border-success/50",
  warning: "border-warning/30 text-warning bg-warning/5 hover:bg-warning/10 hover:border-warning/50",
  danger: "border-danger/30 text-danger bg-danger/5 hover:bg-danger/10 hover:border-danger/50",
  info: "border-info/30 text-info bg-info/5 hover:bg-info/10 hover:border-info/50",
};

const classes = cx(
  "inline-flex items-center gap-1.5 rounded-lg border bg-surface px-2.5 py-1 text-xs font-bold uppercase tracking-wider transition-all duration-200 shadow-sm",
  toneClass[tone],
  href && "no-underline",
  className,
);
---

<Tag href={href} class={classes}>
  <slot />
</Tag>

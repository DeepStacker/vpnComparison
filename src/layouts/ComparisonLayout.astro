---
/**
 * ComparisonLayout — wide, data-dense layout for head-to-head comparison
 * pages. Uses the full page container so multi-column comparison tables have
 * horizontal room. The comparison matrix and narrative are provided via slots.
 *
 * @prop seo - page SEO metadata.
 * @prop breadcrumbs - breadcrumb trail.
 * @prop jsonLd - extra structured data.
 * Slots: "summary" (above the matrix), default (matrix + narrative).
 */
import SeoLayout from "./SeoLayout.astro";
import Breadcrumbs from "@/components/ui/Breadcrumbs.astro";
import type { JsonLdNode, SeoMeta } from "@/types/seo";
import type { Breadcrumb } from "@/types/site";

interface Props {
  seo: SeoMeta;
  breadcrumbs?: Breadcrumb[];
  jsonLd?: JsonLdNode | JsonLdNode[];
}

const { seo, breadcrumbs = [], jsonLd } = Astro.props;
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs} renderBreadcrumbs={false} container="full" jsonLd={jsonLd}>
  <div class="container-page">
    {breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} class="mb-6" />}
    <slot name="summary" />
    <div class="mt-8">
      <slot />
    </div>
  </div>
</SeoLayout>

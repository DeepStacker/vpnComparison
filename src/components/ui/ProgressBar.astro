---
/**
 * ProgressBar — determinate progress indicator.
 * @prop value - current value (or percentage if `max` omitted).
 * @prop max - maximum; when omitted, `value` is treated as a percentage.
 * @prop tone - "primary" | "success" | "warning" | "danger".
 * @prop label - accessible label.
 * @prop showValue - render the numeric value beside the bar.
 */
import { cx } from "@/lib/utils/string";

interface Props {
  value: number;
  max?: number;
  tone?: "primary" | "success" | "warning" | "danger";
  label?: string;
  showValue?: boolean;
  class?: string;
}

const { value, max, tone = "primary", label, showValue = false, class: className } = Astro.props;
const percent = max ? Math.max(0, Math.min((value / max) * 100, 100)) : Math.max(0, Math.min(value, 100));

const toneClass: Record<string, string> = {
  primary: "bg-primary",
  success: "bg-success",
  warning: "bg-warning",
  danger: "bg-danger",
};

const barId = `pb-${Math.random().toString(36).slice(2, 8)}`;
---

<div class={cx("w-full", className)}>
  {(label || showValue) && (
    <div class="mb-1 flex items-center justify-between text-sm">
      {label && <span class="font-medium text-foreground">{label}</span>}
      {showValue && <span class="text-muted-foreground">{Math.round(percent)}%</span>}
    </div>
  )}
  <div
    class="h-2 w-full overflow-hidden rounded-full bg-surface-sunken"
    role="progressbar"
    aria-valuenow={Math.round(percent)}
    aria-valuemin={0}
    aria-valuemax={100}
    aria-label={label}
  >
    <div
      id={barId}
      class={cx("h-full rounded-full transition-[width] duration-slow ease-out", toneClass[tone])}
      style={`width:${percent}%`}
    />
  </div>
</div>

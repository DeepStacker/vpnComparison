---
/**
 * Tag — bordered keyword label, typically used for content taxonomy.
 * @prop tone - "neutral" | "primary" | "success" | "warning" | "danger" | "info".
 * @prop href - render as a link instead of a span.
 */
import { cx } from "@/lib/utils/string";

interface Props {
  tone?: "neutral" | "primary" | "success" | "warning" | "danger" | "info";
  href?: string;
  class?: string;
}

const { tone = "neutral", href, class: className } = Astro.props;
const Tag = href ? "a" : "span";

const toneClass: Record<string, string> = {
  neutral: "border-border text-muted-foreground hover:bg-surface-raised",
  primary: "border-primary/40 text-primary hover:bg-accent",
  success: "border-success/40 text-success hover:bg-success-surface",
  warning: "border-warning/40 text-warning hover:bg-warning-surface",
  danger: "border-danger/40 text-danger hover:bg-danger-surface",
  info: "border-info/40 text-info hover:bg-info-surface",
};

const classes = cx(
  "inline-flex items-center gap-1 rounded-md border bg-surface px-2 py-0.5 text-xs font-medium transition-colors",
  toneClass[tone],
  href && "no-underline",
  className,
);
---

<Tag href={href} class={classes}>
  <slot />
</Tag>

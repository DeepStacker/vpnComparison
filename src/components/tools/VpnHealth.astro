---
interface VpnHealthProvider {
  id: string; slug: string; name: string; tagline: string;
  serverNetwork: { serverCount: number; countryCount: number };
  protocols: string[]; platforms: string[]; features: string[];
  streaming: Array<{ service: string; support: string }>;
  torrenting: { supported: boolean; labeledServers: boolean };
  loggingPolicy: string; jurisdiction: string;
  pricing: { currency: string; plans: Array<{ cycle: string; price: number; effectiveMonthly: number }>; moneyBackGuaranteeDays: number; freeTier: boolean };
  audits: Array<{ auditor: string; independent: boolean }>;
  killSwitch: boolean; multiHop: boolean; splitTunneling: boolean;
  adBlocker: boolean; dedicatedIp: boolean; simultaneousConnections: number;
}

interface VpnHealthReview {
  providerId: string;
  scores: { privacy: number; security: number; performance: number; streaming: number; torrenting: number; easeOfUse: number; value: number; overall: number };
  verdict: { headline: string; summary: string; recommendation: string };
}

interface Props {
  providers: VpnHealthProvider[];
  reviews: VpnHealthReview[];
}

const { providers, reviews } = Astro.props;
---

<div id="vpn-health-root" class="grid gap-8 lg:grid-cols-5">
  <div class="lg:col-span-2 rounded-2xl border border-border bg-surface p-6 shadow-sm">
    <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Health Check</p>
    <h2 class="mt-2 text-xl font-black tracking-tight">Select a Provider</h2>
    <p class="mt-2 text-sm text-muted-foreground leading-relaxed">Comprehensive health assessment across 8 dimensions.</p>

    <div class="mt-6">
      <label for="health-provider" class="block text-xs font-bold uppercase tracking-widest text-muted-foreground">Provider</label>
      <select id="health-provider" class="mt-2 w-full rounded-xl border border-border bg-surface-sunken/40 px-4 py-2.5 text-sm font-bold text-foreground focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/20">
        {providers.map((p) => `<option value="${p.id}">${p.name}</option>`)}
      </select>
    </div>

    <button id="health-run" type="button" class="mt-6 w-full rounded-xl bg-primary px-6 py-3 text-sm font-black uppercase tracking-widest text-primary-foreground transition-all duration-200 hover:brightness-110 shadow-lg">Run Health Check</button>

    <div class="mt-6 rounded-xl border border-border bg-surface-sunken/40 p-4 text-xs text-muted-foreground leading-relaxed">
      The health check evaluates vendor posture across privacy, security, performance, streaming, and business viability dimensions using structured provider data.
    </div>
  </div>

  <div class="lg:col-span-3 space-y-6" id="health-results">
    <div class="rounded-2xl border border-border bg-surface p-8 shadow-sm text-center">
      <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Ready</p>
      <h3 class="mt-3 text-2xl font-black tracking-tight">Run a health check to begin</h3>
      <p class="mt-3 text-sm text-muted-foreground max-w-md mx-auto leading-relaxed">Select a provider and receive a comprehensive 8-dimension health assessment with scores, risks, and recommendations.</p>
    </div>
  </div>
</div>

<script is:inline type="application/json" id="health-data" set:html={JSON.stringify(providers)}></script>
<script is:inline type="application/json" id="health-reviews-data" set:html={JSON.stringify(reviews)}></script>

<script>
  interface Provider {
    id: string; slug: string; name: string; tagline: string;
    serverNetwork: { serverCount: number; countryCount: number };
    protocols: string[]; platforms: string[]; features: string[];
    streaming: Array<{ service: string; support: string }>;
    torrenting: { supported: boolean; labeledServers: boolean };
    loggingPolicy: string; jurisdiction: string;
    pricing: { plans: Array<{ effectiveMonthly: number }>; moneyBackGuaranteeDays: number; freeTier: boolean };
    audits: Array<{ auditor: string; independent: boolean }>;
    killSwitch: boolean; multiHop: boolean; splitTunneling: boolean;
    adBlocker: boolean; dedicatedIp: boolean; simultaneousConnections: number;
  }
  interface ReviewData {
    providerId: string;
    scores: { privacy: number; security: number; performance: number; streaming: number; torrenting: number; easeOfUse: number; value: number; overall: number };
    verdict: { headline: string; summary: string; recommendation: string };
  }

  const allProviders: Provider[] = JSON.parse(document.getElementById("health-data")!.textContent);
  const allReviews: ReviewData[] = JSON.parse(document.getElementById("health-reviews-data")!.textContent);
  const reviewMap = new Map(allReviews.map((r) => [r.providerId, r]));
  const providerMap = new Map(allProviders.map((p) => [p.id, p]));

  const results = document.getElementById("health-results")!;
  const runBtn = document.getElementById("health-run") as HTMLButtonElement;
  const providerSel = document.getElementById("health-provider") as HTMLSelectElement;

  const healthDimensions = [
    { id: "privacy", label: "Privacy", weight: 1.2 },
    { id: "security", label: "Security", weight: 1.2 },
    { id: "performance", label: "Performance", weight: 1.0 },
    { id: "streaming", label: "Streaming", weight: 0.9 },
    { id: "torrenting", label: "Torrenting", weight: 0.7 },
    { id: "usability", label: "Usability", weight: 0.8 },
    { id: "value", label: "Value", weight: 0.9 },
    { id: "viability", label: "Business Viability", weight: 0.5 },
  ];

  function escapeHtml(str: string): string {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function computeHealth(p: Provider, review?: ReviewData) {
    const privacy = review ? review.scores.privacy * 10 : 50;
    const security = review ? review.scores.security * 10 : 50;
    const performance = review ? review.scores.performance * 10 : 50;
    const streaming = review ? review.scores.streaming * 10 : (p.streaming.filter(s => s.support === "verified").length * 15);
    const torrenting = review ? review.scores.torrenting * 10 : (p.torrenting.supported ? 70 : 0);
    const usability = review ? review.scores.easeOfUse * 10 : 50;
    const value = review ? review.scores.value * 10 : 50;
    const auditScore = Math.min(100, p.audits.filter(a => a.independent).length * 25 + (p.loggingPolicy === "no-logs" ? 30 : 0));
    void auditScore;
    const viability = Math.min(100, 40 + (p.pricing.moneyBackGuaranteeDays > 0 ? 15 : 0) + (p.pricing.freeTier ? 10 : 0) + (p.audits.length > 0 ? 20 : 0) + Math.min(15, p.serverNetwork.countryCount));

    return { privacy, security, performance, streaming, torrenting, usability, value, viability };
  }

  function computeOverallHealth(scores: Record<string, number>): { score: number; status: "Excellent" | "Good" | "Fair" | "Poor" } {
    const values = Object.values(scores);
    const avg = values.reduce((s, v) => s + v, 0) / values.length;
    return {
      score: Math.round(avg),
      status: avg >= 80 ? "Excellent" : avg >= 65 ? "Good" : avg >= 45 ? "Fair" : "Poor",
    };
  }

  function renderReport(providerId: string) {
    const p = providerMap.get(providerId);
    if (!p) return;
    const review = reviewMap.get(providerId);
    const scores = computeHealth(p, review);
    const overall = computeOverallHealth(scores);
    const tone = overall.status === "Excellent" ? "success" : overall.status === "Good" ? "primary" : overall.status === "Fair" ? "warning" : "danger";
    const overallColor = `var(--color-${tone})`;
    const overallPct = `${overall.score}%`;
    void overallPct;

    const dims = healthDimensions.map((d) => ({
      ...d,
      score: scores[d.id as keyof typeof scores],
    }));

    results.innerHTML = `
      <div class="rounded-3xl border border-${tone}/30 bg-${tone}/5 p-8 shadow-sm">
        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
          <div class="min-w-0">
            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Health Report</p>
            <h3 class="mt-2 text-2xl font-black tracking-tight">${escapeHtml(p.name)}</h3>
            <p class="mt-2 text-sm text-muted-foreground leading-relaxed max-w-xl">${review ? escapeHtml(review.verdict.headline) : "Comprehensive multi-dimension health assessment."}</p>
          </div>
          <div class="shrink-0 text-center">
            <div class="relative inline-flex items-center justify-center" style="width:100px;height:100px">
              <svg class="-rotate-90" width="100" height="100" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="42" fill="none" stroke="var(--color-border)" stroke-width="8" />
                <circle cx="50" cy="50" r="42" fill="none" stroke="${overallColor}" stroke-width="8" stroke-dasharray="${2 * Math.PI * 42}" stroke-dashoffset="${2 * Math.PI * 42 * (1 - overall.score / 100)}" stroke-linecap="round" class="transition-all duration-1000" />
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span class="text-2xl font-black tracking-tighter" style="color:${overallColor}">${overall.score}</span>
                <span class="text-[8px] font-bold text-muted-foreground uppercase tracking-widest">/100</span>
              </div>
            </div>
            <p class="mt-2 text-xs font-black uppercase tracking-widest" style="color:${overallColor}">${overall.status}</p>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
        <h3 class="text-lg font-black tracking-tight mb-6">Dimension Scores</h3>
        <div class="grid gap-6 sm:grid-cols-2">
          ${dims.map((d) => {
            const dimScore = d.score;
            const dimColor = dimScore >= 80 ? 'var(--color-success)' : dimScore >= 60 ? 'var(--color-primary)' : dimScore >= 40 ? 'var(--color-warning)' : 'var(--color-danger)';
            return `<div>
              <div class="flex items-center justify-between text-sm mb-1.5">
                <span class="font-bold text-foreground">${escapeHtml(d.label)}</span>
                <span class="font-black" style="color:${dimColor}">${Math.round(dimScore)}</span>
              </div>
              <div class="h-2.5 w-full rounded-full bg-surface-sunken border border-border/50 overflow-hidden shadow-inner">
                <div class="h-full rounded-full transition-all duration-700" style="width:${dimScore}%;background:${dimColor}"></div>
              </div>
            </div>`;
          }).join('')}
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <h3 class="text-base font-black uppercase tracking-widest mb-4">Strengths</h3>
          <ul class="space-y-3 text-sm">
            ${Object.entries(scores).filter(([, v]) => v >= 70).slice(0, 3).map(([key]) => {
              const dim = healthDimensions.find(d => d.id === key);
              return `<li class="flex gap-3"><span class="mt-0.5 h-5 w-5 shrink-0 rounded-full bg-success/10 border border-success/30 flex items-center justify-center text-[10px] font-black text-success">+</span><span class="text-foreground/90"><strong class="text-foreground">${escapeHtml(dim?.label ?? key)}</strong> — Above average performance in this dimension.</span></li>`;
            }).join('<li class="border-t border-border/50 my-2"></li>')}
          </ul>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <h3 class="text-base font-black uppercase tracking-widest mb-4">Areas to Watch</h3>
          <ul class="space-y-3 text-sm">
            ${Object.entries(scores).filter(([, v]) => v < 60).slice(0, 3).map(([key, val]) => {
              const dim = healthDimensions.find(d => d.id === key);
              return `<li class="flex gap-3"><span class="mt-0.5 h-5 w-5 shrink-0 rounded-full bg-warning/10 border border-warning/30 flex items-center justify-center text-[10px] font-black text-warning">!</span><span class="text-foreground/90"><strong class="text-foreground">${escapeHtml(dim?.label ?? key)}</strong> — Score of ${Math.round(val)}/100. Review improvement opportunities.</span></li>`;
            }).join('<li class="border-t border-border/50 my-2"></li>')}
            ${Object.values(scores).filter(v => v < 60).length === 0 ? '<li class="text-muted-foreground">No significant concerns detected across all dimensions.</li>' : ''}
          </ul>
        </div>
      </div>

      <div class="rounded-2xl border border-border bg-surface-sunken/30 p-6">
        <h3 class="text-base font-black uppercase tracking-widest">Recommended Actions</h3>
        <ul class="mt-4 space-y-3 text-sm text-foreground/90">
          <li class="flex gap-3"><span class="mt-0.5 h-5 w-5 shrink-0 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center text-[10px] font-black text-primary">1</span><span>Run a follow-up health check after policy changes or new audit publications.</span></li>
          <li class="flex gap-3"><span class="mt-0.5 h-5 w-5 shrink-0 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center text-[10px] font-black text-primary">2</span><span>Cross-reference with the Privacy Audit tool for a deeper control-level review.</span></li>
          <li class="flex gap-3"><span class="mt-0.5 h-5 w-5 shrink-0 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center text-[10px] font-black text-primary">3</span><span>Combine this report with the Speed Analyzer for a complete performance picture.</span></li>
        </ul>
      </div>
    `;
  }

  runBtn.addEventListener("click", () => {
    renderReport(providerSel.value);
  });
</script>

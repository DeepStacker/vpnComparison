---
import { getCollection, getEntry, render } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import ScoreBar from "@/components/ui/ScoreBar.astro";
import ScoreRing from "@/components/ui/ScoreRing.astro";
import PriceTag from "@/components/ui/PriceTag.astro";
import StreamingMatrix from "@/components/ui/StreamingMatrix.astro";
import Grid from "@/components/ui/Grid.astro";
import Chip from "@/components/ui/Chip.astro";
import Icon from "@/components/ui/Icon.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import { cx } from "@/lib/utils/string";
import { featureHref, protocolHref, platformHref, countryHref } from "@/lib/content/links";
import type { Breadcrumb } from "@/types/site";
import type { ISODateString } from "@/types/common";

export async function getStaticPaths() {
  const providers = await getCollection("providers");
  return providers.map((p) => ({ params: { slug: p.data.slug } }));
}

const { slug } = Astro.params;
const providerEntry = await getEntry("providers", slug);
if (!providerEntry) return Astro.redirect("/404");

const provider = providerEntry.data;
const overviewEntry = await getEntry("provider-overviews", slug);
const OverviewContent = overviewEntry ? (await render(overviewEntry)).Content : null;

const allReviews = await getCollection("reviews");
const review = allReviews.find((r) => r.data.provider.id === slug);
const reviewData = review?.data;

const [allFeatures, allProtocols, allPlatforms, allStreamingSvcs, allCountries, allComparisons, allGuides] =
  await Promise.all([
    getCollection("features"),
    getCollection("protocols"),
    getCollection("platforms"),
    getCollection("streaming-services"),
    getCollection("countries"),
    getCollection("comparisons"),
    getCollection("guides"),
  ]);

const featureNameMap = new Map(allFeatures.map((f) => [f.data.id, f.data.name]));
const featureSlugMap = new Map(allFeatures.map((f) => [f.data.id, f.data.slug]));
const protocolNameMap = new Map(allProtocols.map((p) => [p.data.id, p.data.name]));
const protocolSlugMap = new Map(allProtocols.map((p) => [p.data.id, p.data.slug]));
const platformNameMap = new Map(allPlatforms.map((p) => [p.data.id, p.data.name]));
const platformSlugMap = new Map(allPlatforms.map((p) => [p.data.id, p.data.slug]));
const streamingNameMap = new Map(allStreamingSvcs.map((s) => [s.data.id, s.data.name]));
const countryNameMap = new Map(allCountries.map((c) => [c.data.code, c.data.name]));
const countrySlugMap = new Map(allCountries.map((c) => [c.data.code, c.data.slug]));

const allScores = reviewData?.scores;

const relatedComparisons = allComparisons.filter((c) =>
  c.data.providers.some((ref) => ref.id === provider.id),
);
const relatedGuides = allGuides.filter((g) =>
  g.data.relatedProviders?.some((ref) => ref.id === provider.id),
);

const reviewAuthorEntry = review?.data?.reviewer?.id
  ? await getEntry("authors", review.data.reviewer.id)
  : null;
const authorName = reviewAuthorEntry?.data?.name;

const pageTitle = reviewData?.title
  ? buildTitle(reviewData.title)
  : buildTitle(`${provider.name} Review`);
const seo = normalizeSeoMeta({
  title: pageTitle,
  description: reviewData?.summary ?? `${provider.name} overview with specs, features, pricing, and scores.`,
  canonical: canonicalUrl(`/vpn/${slug}/`),
  publishedAt: reviewData?.publishedAt as ISODateString | undefined,
  author: authorName,
});

const breadcrumbs: Breadcrumb[] = [
  { label: "VPN Reviews", href: "/vpn/" },
  { label: provider.name, href: `/vpn/${slug}/` },
];

const jurisdictionCountrySlug = countrySlugMap.get(provider.jurisdiction);

const cheapest = provider.pricing.plans.find((p) => p.featured) ?? provider.pricing.plans[0];

/** Simple capitalize helper */
function capitalize(s: string): string {
  return s.charAt(0).toUpperCase() + s.slice(1);
}
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>

  <!-- ============================================================
       PROVIDER HERO
       ============================================================ -->
  <Section class="relative overflow-hidden bg-gradient-hero" padding="none">
    <div class="pointer-events-none absolute inset-0 bg-dot-grid opacity-[0.04]" aria-hidden="true" />
    <div class="pointer-events-none absolute -left-20 -top-20 h-64 w-64 rounded-full bg-brand-400/8 blur-3xl" aria-hidden="true" />
    <div class="pointer-events-none absolute -bottom-16 -right-16 h-48 w-48 rounded-full bg-brand-300/6 blur-3xl" aria-hidden="true" />
    <Container>
      <div class="flex flex-col gap-8 py-12 lg:flex-row lg:items-center lg:justify-between lg:py-16">
        <!-- Left: identity + meta -->
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-4 mb-4">
            <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-white/10 ring-1 ring-white/10">
              <img src={`/logos/${slug}.svg`} alt={`${provider.name} logo`} class="h-9 w-9 object-contain" width={36} height={36} loading="eager" />
            </div>
            <div>
              <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{provider.name} Review</h1>
              {reviewData && (
                <div class="mt-1.5 flex items-center gap-3">
                  {reviewData.verdict.recommendation === "recommended" && (
                    <Badge tone="success" size="sm" class="border border-white/10">Editor's Choice</Badge>
                  )}
                  <Text size="xs" class="text-white/50">
                    Updated {reviewData.updatedAt ?? provider.updatedAt}
                  </Text>
                </div>
              )}
            </div>
          </div>

          <!-- Verdict headline -->
          {reviewData?.verdict && (
            <p class="max-w-2xl text-lg leading-relaxed text-white/85 font-medium">
              {reviewData.verdict.headline}
            </p>
          )}
          <p class="mt-2 max-w-2xl text-base leading-relaxed text-white/65">
            {provider.tagline}
          </p>

          <!-- CTA row -->
          <div class="mt-6 flex flex-wrap items-center gap-3">
            {cheapest && (
              <div class="flex items-center gap-3 rounded-lg bg-white/10 px-4 py-2.5">
                <div class="flex items-baseline gap-0.5 text-white">
                  <span class="text-2xl font-bold tracking-tight">${cheapest.effectiveMonthly.toFixed(2)}</span>
                  <span class="text-sm text-white/60">/mo</span>
                </div>
                <div class="text-xs text-white/50">
                  {cheapest.cycle === "monthly" ? "Monthly" : cheapest.cycle === "yearly" ? "Annual" : "2-year"} plan
                </div>
              </div>
            )}
            <Button href={provider.websiteUrl} variant="outline" size="lg" target="_blank" rel="noopener noreferrer" class="border-white/20 text-white hover:bg-white/10">
              Visit Website <Icon name="external-link" size={14} />
            </Button>
            {review && (
              <Button href="#scores" size="lg" class="shadow-glow">
                Read Review
              </Button>
            )}
          </div>
        </div>

        <!-- Right: score ring -->
        {allScores && (
          <a href="#scores" class="flex shrink-0 flex-col items-center gap-2 no-underline group/score">
            <svg width="140" height="140" viewBox="0 0 140 140" role="img" aria-label={`Overall score ${allScores.overall.toFixed(1)} out of 10`}>
              <circle cx="70" cy="70" r="60" fill="none" stroke="rgb(255 255 255 / 0.12)" stroke-width="8" />
              <circle cx="70" cy="70" r="60" fill="none" stroke="rgb(255 255 255 / 0.9)" stroke-width="8"
                stroke-dasharray={`${2 * Math.PI * 60}`}
                stroke-dashoffset={`${2 * Math.PI * 60 * (1 - allScores.overall / 10)}`}
                stroke-linecap="round" transform="rotate(-90 70 70)"
                class="transition-all motion-safe:duration-700 motion-safe:ease-emphasized" />
              <text x="50%" y="44%" text-anchor="middle" dominant-baseline="central" font-size="36" font-weight="700" fill="white">
                {allScores.overall.toFixed(1)}
              </text>
              <text x="50%" y="62%" text-anchor="middle" dominant-baseline="central" font-size="12" font-weight="500" fill="rgb(255 255 255 / 0.55)">
                OUT OF 10
              </text>
            </svg>
          </a>
        )}
      </div>
    </Container>
  </Section>

  <!-- ============================================================
       KEY STATS ROW
       ============================================================ -->
  <Section padding="tight">
    <Container>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
        <div class="flex items-center gap-3 rounded-lg border border-border bg-surface p-3">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-accent text-accent-foreground">
            <Icon name="server" size={16} />
          </div>
          <div class="min-w-0">
            <Text size="sm" weight="semibold" class="tabular-nums">{provider.serverNetwork.serverCount.toLocaleString()}</Text>
            <Text size="xs" tone="muted">Servers</Text>
          </div>
        </div>

        <div class="flex items-center gap-3 rounded-lg border border-border bg-surface p-3">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-accent text-accent-foreground">
            <Icon name="globe" size={16} />
          </div>
          <div class="min-w-0">
            <Text size="sm" weight="semibold" class="tabular-nums">{provider.serverNetwork.countryCount}</Text>
            <Text size="xs" tone="muted">Countries</Text>
          </div>
        </div>

        <div class="flex items-center gap-3 rounded-lg border border-border bg-surface p-3">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-accent text-accent-foreground">
            <Icon name="monitor-smartphone" size={16} />
          </div>
          <div class="min-w-0">
            <Text size="sm" weight="semibold" class="tabular-nums">{provider.simultaneousConnections === 0 ? "∞" : provider.simultaneousConnections}</Text>
            <Text size="xs" tone="muted">Devices</Text>
          </div>
        </div>

        <div class="flex items-center gap-3 rounded-lg border border-border bg-surface p-3">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-accent text-accent-foreground">
            <Icon name="shield" size={16} />
          </div>
          <div class="min-w-0">
            <Text size="sm" weight="semibold">{provider.loggingPolicy === "no-logs" ? "No-logs" : capitalize(provider.loggingPolicy)}</Text>
            <Text size="xs" tone="muted">Logging</Text>
          </div>
        </div>

        <div class="flex items-center gap-3 rounded-lg border border-border bg-surface p-3">
          <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-accent text-accent-foreground">
            <Icon name="landmark" size={16} />
          </div>
          <div class="min-w-0">
            {jurisdictionCountrySlug
              ? <a href={countryHref(jurisdictionCountrySlug)} class="no-underline"><Text size="sm" weight="semibold" class="text-primary hover:underline">{countryNameMap.get(provider.jurisdiction) ?? provider.jurisdiction}</Text></a>
              : <Text size="sm" weight="semibold">{countryNameMap.get(provider.jurisdiction) ?? provider.jurisdiction}</Text>
            }
            <Text size="xs" tone="muted">Jurisdiction</Text>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- ============================================================
       SCORE BREAKDOWN
       ============================================================ -->
  {allScores && (
    <Section background id="scores">
      <Container>
        <div class="flex items-center justify-between">
          <div>
            <Badge tone="primary" size="sm">Review scores</Badge>
            <Heading level={2} class="mt-2">Score Breakdown — {allScores.overall.toFixed(1)} / 10</Heading>
            {reviewData?.testDate && <Text size="sm" tone="muted">Tested {reviewData.testDate}</Text>}
          </div>
        </div>
        <div class="mt-6 grid gap-6 lg:grid-cols-3">
          <div class="lg:col-span-2 space-y-4">
            <ScoreBar value={allScores.performance} label="Performance" />
            <ScoreBar value={allScores.privacy} label="Privacy" />
            <ScoreBar value={allScores.security} label="Security" />
            <ScoreBar value={allScores.streaming} label="Streaming" />
            <ScoreBar value={allScores.torrenting} label="Torrenting" />
            <ScoreBar value={allScores.easeOfUse} label="Ease of Use" />
            <ScoreBar value={allScores.value} label="Value" />
          </div>
          <div>
            {reviewData?.verdict && reviewData?.methodology && (
              <Card variant="raised" padding="lg" class="h-full flex flex-col">
                <div class="flex items-center gap-2 mb-3">
                  <div class="flex h-8 w-8 items-center justify-center rounded-full"
                    class:list={{
                      "bg-success-surface text-success": reviewData.verdict.recommendation === "recommended",
                      "bg-warning-surface text-warning": reviewData.verdict.recommendation === "conditional",
                      "bg-danger-surface text-danger": reviewData.verdict.recommendation === "not-recommended",
                    }}
                  >
                    <Icon name={reviewData.verdict.recommendation === "recommended" ? "circle-check" : "alert-circle"} size={18} />
                  </div>
                  <Badge
                    tone={reviewData.verdict.recommendation === "recommended" ? "success" : reviewData.verdict.recommendation === "conditional" ? "warning" : "danger"}>
                    {reviewData.verdict.recommendation === "recommended" ? "Recommended" : capitalize(reviewData.verdict.recommendation)}
                  </Badge>
                </div>
                <Heading level={3} class="text-lg">{reviewData.verdict.headline}</Heading>
                <Text size="sm" tone="muted" class="mt-2 leading-relaxed flex-1">{reviewData.verdict.summary}</Text>
                <Text size="xs" tone="muted" class="mt-3 leading-relaxed border-t border-border pt-3">{reviewData.methodology}</Text>
                <Button variant="outline" size="sm" href="/methodology/" class="mt-3">Full methodology</Button>
              </Card>
            )}
          </div>
        </div>
      </Container>
    </Section>
  )}

  <!-- ============================================================
       PROS & CONS
       ============================================================ -->
  {reviewData && (reviewData.pros.length > 0 || reviewData.cons.length > 0) ? (
    <Section>
      <Container>
        <Heading level={2}>Pros & Cons</Heading>
        <Text tone="muted" class="mt-2">What sets {provider.name} apart — and where it falls short.</Text>
        <Grid cols={1} colsMd={2} gap={6} class="mt-6">
          {reviewData.pros.length > 0 && (
            <Card variant="raised" padding="lg" class="border-t-4 border-success">
              <Heading level={3}>
                <span class="flex items-center gap-2 text-success">
                  <Icon name="circle-check" size={20} />
                  Pros
                </span>
              </Heading>
              <ul class="mt-4 space-y-3">
                {reviewData.pros.map((pro) => (
                  <li class="flex items-start gap-3">
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-success-surface text-success">
                      <Icon name="check" size={12} />
                    </span>
                    <Text size="sm" class="leading-relaxed">{pro}</Text>
                  </li>
                ))}
              </ul>
            </Card>
          )}
          {reviewData.cons.length > 0 && (
            <Card variant="raised" padding="lg" class="border-t-4 border-danger">
              <Heading level={3}>
                <span class="flex items-center gap-2 text-danger">
                  <Icon name="circle-x" size={20} />
                  Cons
                </span>
              </Heading>
              <ul class="mt-4 space-y-3">
                {reviewData.cons.map((con) => (
                  <li class="flex items-start gap-3">
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-danger-surface text-danger">
                      <Icon name="x" size={12} />
                    </span>
                    <Text size="sm" class="leading-relaxed">{con}</Text>
                  </li>
                ))}
              </ul>
            </Card>
          )}
        </Grid>
      </Container>
    </Section>
  ) : null}

  <!-- ============================================================
       PRICING
       ============================================================ -->
  <Section background>
    <Container>
      <div class="flex items-center justify-between">
        <div>
          <Badge tone="primary" size="sm">Pricing</Badge>
          <Heading level={2} class="mt-2">Plans &amp; Pricing</Heading>
        </div>
        {provider.pricing.moneyBackGuaranteeDays > 0 && (
          <Badge tone="success" size="sm">{provider.pricing.moneyBackGuaranteeDays}-day guarantee</Badge>
        )}
      </div>
      <Text tone="muted" class="mt-2">
        {provider.pricing.freeTier ? "Free tier available" : ""}
      </Text>
      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        {provider.pricing.plans.map((plan) => (
          <Card padding="lg" variant={plan.featured ? "raised" : "default"} class={cx(plan.featured && "border-primary/50 ring-1 ring-primary/20")}>
            <Badge tone={plan.featured ? "primary" : "neutral"} size="sm">{capitalize(plan.cycle)}</Badge>
            <div class="mt-3">
              <PriceTag price={plan.effectiveMonthly} cycle={plan.cycle} featured={plan.featured} />
              <Text size="sm" tone="muted" class="mt-1">${plan.price.toFixed(2)} billed {plan.cycle === "monthly" ? "monthly" : plan.cycle === "yearly" ? "annually" : "every 2 years"}</Text>
            </div>
          </Card>
        ))}
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        <Text size="sm" tone="muted" element="span" class="mr-1">Payment: </Text>
        {provider.pricing.paymentMethods.map((m) => (
          <Badge tone="neutral" size="sm">{m}</Badge>
        ))}
      </div>
      {provider.pricing.freeTierNotes && (
        <Text size="sm" tone="info" class="mt-2">{provider.pricing.freeTierNotes}</Text>
      )}
    </Container>
  </Section>

  <!-- ============================================================
       GROUPED SPECIFICATION PANEL
       ============================================================ -->
  <Section>
    <Container>
      <div class="flex items-center justify-between">
        <div>
          <Badge tone="primary" size="sm">Specifications</Badge>
          <Heading level={2} class="mt-2">Features & Compatibility</Heading>
        </div>
      </div>

      <!-- Single grouped panel with labeled sections -->
      <Card variant="raised" padding="lg" class="mt-6">
        <div class="grid gap-8 lg:grid-cols-2">
          <!-- Left column: Features + Protocols + Platforms -->
          <div class="space-y-6">
            <!-- Features -->
            <div>
              <Heading level={3} class="text-sm font-semibold flex items-center gap-2 mb-3">
                <span class="flex h-6 w-6 items-center justify-center rounded bg-primary/10 text-primary">
                  <Icon name="list-checks" size={13} />
                </span>
                Features
              </Heading>
              <div class="flex flex-wrap gap-1.5">
                {provider.features.map((fid) => {
                  const name = featureNameMap.get(fid);
                  const fslug = featureSlugMap.get(fid);
                  if (!name || !fslug) return null;
                  return <a href={featureHref(fslug)} class="no-underline"><Badge tone="neutral" size="sm">{name}</Badge></a>;
                })}
              </div>
            </div>

            <!-- Protocols -->
            <div>
              <Heading level={3} class="text-sm font-semibold flex items-center gap-2 mb-3">
                <span class="flex h-6 w-6 items-center justify-center rounded bg-primary/10 text-primary">
                  <Icon name="terminal" size={13} />
                </span>
                Protocols
              </Heading>
              <div class="flex flex-wrap gap-1.5">
                {provider.protocols.map((pid) => {
                  const name = protocolNameMap.get(pid);
                  const pslug = protocolSlugMap.get(pid);
                  if (!name || !pslug) return null;
                  return <a href={protocolHref(pslug)} class="no-underline"><Badge tone="neutral" size="sm">{name}</Badge></a>;
                })}
              </div>
            </div>

            <!-- Platforms -->
            <div>
              <Heading level={3} class="text-sm font-semibold flex items-center gap-2 mb-3">
                <span class="flex h-6 w-6 items-center justify-center rounded bg-primary/10 text-primary">
                  <Icon name="monitor-smartphone" size={13} />
                </span>
                Platforms
              </Heading>
              <div class="flex flex-wrap gap-1.5">
                {provider.platforms.map((pid) => {
                  const name = platformNameMap.get(pid);
                  const pslug = platformSlugMap.get(pid);
                  if (!name || !pslug) return null;
                  return <a href={platformHref(pslug)} class="no-underline"><Chip>{name}</Chip></a>;
                })}
              </div>
            </div>
          </div>

          <!-- Right column: Server locations + DNS/Leak/Obfuscation -->
          <div class="space-y-6">
            <!-- Server locations -->
            <div>
              <Heading level={3} class="text-sm font-semibold flex items-center gap-2 mb-3">
                <span class="flex h-6 w-6 items-center justify-center rounded bg-primary/10 text-primary">
                  <Icon name="globe" size={13} />
                </span>
                Server Locations ({provider.serverNetwork.countries.length})
              </Heading>
              <div class="flex flex-wrap gap-1.5">
                {provider.serverNetwork.countries.map((code) => {
                  const cslug = countrySlugMap.get(code);
                  if (!cslug) return <Chip>{code}</Chip>;
                  return <a href={countryHref(cslug)} class="no-underline"><Chip>{code}</Chip></a>;
                })}
              </div>
            </div>

            <!-- DNS / Leak / Obfuscation details inline -->
            <div class="space-y-3">
              {provider.dnsHandling && (
                <div class="rounded-lg border border-border bg-surface-sunken/50 p-3">
                  <Heading level={4} class="text-xs font-semibold flex items-center gap-1.5">
                    <Icon name="search" size={12} class="text-primary" /> DNS Handling
                  </Heading>
                  <Text size="xs" tone="muted" class="mt-1 leading-relaxed">{provider.dnsHandling}</Text>
                </div>
              )}
              {provider.leakProtection && (
                <div class="rounded-lg border border-border bg-surface-sunken/50 p-3">
                  <Heading level={4} class="text-xs font-semibold flex items-center gap-1.5">
                    <Icon name="shield" size={12} class="text-primary" /> Leak Protection
                  </Heading>
                  <Text size="xs" tone="muted" class="mt-1 leading-relaxed">{provider.leakProtection}</Text>
                </div>
              )}
              {provider.obfuscationType && provider.obfuscationType !== "none" && (
                <div class="rounded-lg border border-border bg-surface-sunken/50 p-3">
                  <Heading level={4} class="text-xs font-semibold flex items-center gap-1.5">
                    <Icon name="eye-off" size={12} class="text-primary" /> Obfuscation
                  </Heading>
                  <Text size="xs" tone="muted" class="mt-1 leading-relaxed">
                    Type: {capitalize(provider.obfuscationType)}{provider.postQuantum ? ' · Post-quantum ready' : ''}
                  </Text>
                </div>
              )}
            </div>
          </div>
        </div>
      </Card>
    </Container>
  </Section>

  <!-- ============================================================
       STREAMING
       ============================================================ -->
  {provider.streaming.length > 0 && (
    <Section background>
      <Container>
        <div class="flex items-center justify-between">
          <div>
            <Badge tone="primary" size="sm">Streaming</Badge>
            <Heading level={2} class="mt-2">Streaming Support</Heading>
          </div>
        </div>
        <Text tone="muted" class="mt-2">Verified compatibility with major streaming platforms</Text>
        <div class="mt-6">
          <StreamingMatrix items={provider.streaming} serviceNames={Object.fromEntries(streamingNameMap)} />
        </div>
      </Container>
    </Section>
  )}

  <!-- ============================================================
       TORRENTING
       ============================================================ -->
  {provider.torrenting.supported && (
    <Section>
      <Container>
        <div class="flex items-center justify-between">
          <div>
            <Badge tone="primary" size="sm">Torrenting</Badge>
            <Heading level={2} class="mt-2">P2P & Torrenting</Heading>
          </div>
          {provider.torrenting.rating != null && (
            <ScoreRing value={provider.torrenting.rating} size={56} strokeWidth={4} label="Rating" />
          )}
        </div>
        <div class="mt-4 flex flex-wrap gap-3">
          <Badge tone="success">P2P Supported</Badge>
          {provider.torrenting.labeledServers && <Badge tone="info">Labeled P2P Servers</Badge>}
          {provider.torrenting.portForwarding && <Badge tone="primary">Port Forwarding</Badge>}
        </div>
        {provider.torrenting.notes && (
          <Text size="sm" tone="muted" class="mt-3 leading-relaxed max-w-2xl">{provider.torrenting.notes}</Text>
        )}
      </Container>
    </Section>
  )}

  <!-- ============================================================
       OVERVIEW (factual MDX)
       ============================================================ -->
  {OverviewContent && (
    <Section background>
      <Container size="prose">
        <div class="flex items-center justify-between">
          <div>
            <Badge tone="primary" size="sm">Factual overview</Badge>
            <Heading level={2} class="mt-2">In-Depth Overview</Heading>
          </div>
        </div>
        <div class="mt-6">
          <OverviewContent />
        </div>
      </Container>
    </Section>
  )}

  <!-- ============================================================
       RELATED CONTENT
       ============================================================ -->
  <Section>
    <Container>
      <Heading level={2}>Explore More</Heading>
      <Text tone="muted" class="mt-2">Browse VPNs by feature, protocol, platform, country, or streaming service.</Text>
      <div class="mt-4 flex flex-wrap gap-3">
        <Button variant="outline" size="sm" href="/features/">Browse Features</Button>
        <Button variant="outline" size="sm" href="/protocols/">Browse Protocols</Button>
        <Button variant="outline" size="sm" href="/platforms/">Browse Platforms</Button>
        <Button variant="outline" size="sm" href="/countries/">Browse Countries</Button>
        <Button variant="outline" size="sm" href="/streaming/">Browse Streaming Services</Button>
        <Button variant="outline" size="sm" href="/comparisons/">Compare Providers</Button>
      </div>
    </Container>
  </Section>

  {(relatedComparisons.length > 0 || relatedGuides.length > 0) && (
    <Section background>
      <Container>
        <Heading level={2}>Related Content</Heading>
        <Grid cols={1} colsMd={2} gap={6} class="mt-6">
          {relatedComparisons.map((c) => (
            <Card>
              <Heading level={3}>{c.data.title}</Heading>
              <Text size="sm" tone="muted" class="mt-1">{c.data.summary}</Text>
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/comparisons/${c.id}/`}>Read Comparison</Button>
              </div>
            </Card>
          ))}
          {relatedGuides.map((g) => (
            <Card>
              <Heading level={3}>{g.data.title}</Heading>
              <Text size="sm" tone="muted" class="mt-1">{g.data.summary}</Text>
              <Badge tone="neutral" class="mt-2">{capitalize(g.data.difficulty)}</Badge>
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/guides/${g.id}/`}>Read Guide</Button>
              </div>
            </Card>
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  <!-- ============================================================
       FOOTNOTES
       ============================================================ -->
  <Section padding="tight">
    <Container>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-muted-foreground">
        <span>Founded: {provider.foundedYear}</span>
        <span>·</span>
        <span>Updated: {provider.updatedAt}</span>
        {provider.audits.length > 0 && (
          <>
            <span>·</span>
            <span>{provider.audits.length} independent audit{provider.audits.length !== 1 ? "s" : ""}</span>
          </>
        )}
        {provider.ramOnlyServers && (
          <>
            <span>·</span>
            <span>RAM-only servers</span>
          </>
        )}
      </div>
    </Container>
  </Section>

</SeoLayout>




---
import { getCollection, getEntry } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Grid from "@/components/ui/Grid.astro";
import Chip from "@/components/ui/Chip.astro";
import Icon from "@/components/ui/Icon.astro";
import { getProvidersByProtocol, getRelatedGuidesForEntity } from "@/lib/content/explorer";
import { normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

export async function getStaticPaths() {
  const protocols = await getCollection("protocols");
  return protocols.map((p) => ({ params: { slug: p.data.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry("protocols", slug);
if (!entry) return Astro.redirect("/404");

const protocol = entry.data;
const matches = await getProvidersByProtocol(protocol.id);
const relatedGuides = await getRelatedGuidesForEntity(protocol.slug);

const speedTone: Record<string, "success" | "primary" | "warning" | "danger"> = {
  "very-fast": "success", fast: "primary", moderate: "warning", slow: "danger",
};
const securityTone: Record<string, "success" | "primary" | "warning" | "danger"> = {
  "very-strong": "success", strong: "primary", adequate: "warning", weak: "danger",
};

const seo = normalizeSeoMeta({
  title: `VPNs with ${protocol.name} Protocol — Provider Support`,
  description: `Find VPN providers that support the ${protocol.name} protocol. ${protocol.description} Compare ${matches.length} VPNs with ${protocol.name} support.`,
  canonical: canonicalUrl(`/protocols/${slug}/`),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Protocols", href: "/protocols/" },
  { label: protocol.name, href: `/protocols/${slug}/` },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section background padding="loose">
    <Container>
      <div class="flex flex-col items-start gap-4">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <Badge>{protocol.category.charAt(0).toUpperCase() + protocol.category.slice(1)}</Badge>
            {protocol.speedRating && (
              <Badge tone={speedTone[protocol.speedRating] ?? "neutral"} size="sm">
                <Icon name="zap" size={12} class="mr-1" />{protocol.speedRating.replace("-", " ")}
              </Badge>
            )}
            {protocol.securityRating && (
              <Badge tone={securityTone[protocol.securityRating] ?? "neutral"} size="sm">
                <Icon name="shield" size={12} class="mr-1" />{protocol.securityRating.replace("-", " ")}
              </Badge>
            )}
          </div>
          <Heading level={1}>{protocol.name}</Heading>
          <Text size="lg" tone="muted" class="mt-2 max-w-2xl">{protocol.description}</Text>
          <div class="mt-4 flex flex-wrap gap-2">
            {protocol.encryption && <Chip>{protocol.encryption}</Chip>}
            {protocol.transport && <Chip>{protocol.transport.toUpperCase()}</Chip>}
            {protocol.port && <Chip>Port {protocol.port}</Chip>}
            {protocol.openSource && (
              <Badge tone="success">
                <Icon name="github" size={12} class="mr-1" />Open Source
              </Badge>
            )}
          </div>
        </div>
      </div>
    </Container>
  </Section>

  {(protocol.weaknesses || protocol.creator || protocol.releaseYear) && (
    <Section>
      <Container>
        <Heading level={2}>Technical Details</Heading>
        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {protocol.creator && (
            <div class="rounded-lg border border-border bg-surface p-4">
              <Text size="xs" tone="muted" class="uppercase tracking-wide font-semibold">Creator</Text>
              <Text weight="semibold" class="mt-1">{protocol.creator}</Text>
            </div>
          )}
          {protocol.releaseYear && (
            <div class="rounded-lg border border-border bg-surface p-4">
              <Text size="xs" tone="muted" class="uppercase tracking-wide font-semibold">Release Year</Text>
              <Text weight="semibold" class="mt-1">{protocol.releaseYear}</Text>
            </div>
          )}
          {protocol.speedRating && (
            <div class="rounded-lg border border-border bg-surface p-4">
              <Text size="xs" tone="muted" class="uppercase tracking-wide font-semibold">Speed</Text>
              <Text weight="semibold" class="mt-1 capitalize">{protocol.speedRating.replace("-", " ")}</Text>
            </div>
          )}
          {protocol.securityRating && (
            <div class="rounded-lg border border-border bg-surface p-4">
              <Text size="xs" tone="muted" class="uppercase tracking-wide font-semibold">Security</Text>
              <Text weight="semibold" class="mt-1 capitalize">{protocol.securityRating.replace("-", " ")}</Text>
            </div>
          )}
        </div>

        <div class="mt-6 grid gap-6 lg:grid-cols-2">
          {protocol.strengths.length > 0 && (
            <Card variant="raised" padding="lg" class="border-t-4 border-success">
              <Heading level={3}>
                <span class="flex items-center gap-2 text-success">
                  <Icon name="circle-check" size={18} /> Strengths
                </span>
              </Heading>
              <ul class="mt-3 space-y-2">
                {protocol.strengths.map((s) => (
                  <li class="flex items-start gap-2 text-sm text-foreground">
                    <Icon name="check" size={14} class="mt-0.5 shrink-0 text-success" />
                    <span>{s}</span>
                  </li>
                ))}
              </ul>
            </Card>
          )}
          {protocol.weaknesses && protocol.weaknesses.length > 0 && (
            <Card variant="raised" padding="lg" class="border-t-4 border-danger">
              <Heading level={3}>
                <span class="flex items-center gap-2 text-danger">
                  <Icon name="circle-x" size={18} /> Weaknesses
                </span>
              </Heading>
              <ul class="mt-3 space-y-2">
                {protocol.weaknesses.map((w) => (
                  <li class="flex items-start gap-2 text-sm text-foreground">
                    <Icon name="x" size={14} class="mt-0.5 shrink-0 text-danger" />
                    <span>{w}</span>
                  </li>
                ))}
              </ul>
            </Card>
          )}
        </div>

        {protocol.platformSupport && protocol.platformSupport.length > 0 && (
          <div class="mt-6">
            <Heading level={3} class="text-base">Platform Support</Heading>
            <div class="mt-2 flex flex-wrap gap-2">
              {protocol.platformSupport.map((p) => (
                <Badge tone="neutral" size="sm">{p}</Badge>
              ))}
            </div>
          </div>
        )}
      </Container>
    </Section>
  )}

  <Section background>
    <Container>
      <Heading level={2}>
        Providers Supporting {protocol.name}
        <Text element="span" tone="muted" size="sm" class="ml-2">({matches.length})</Text>
      </Heading>
      {matches.length === 0 && (
        <div class="mt-6 flex flex-col items-center justify-center rounded-lg border border-dashed border-border bg-surface-sunken/40 px-6 py-12 text-center">
          <Text tone="muted">No VPN providers currently support {protocol.name}.</Text>
        </div>
      )}
      <Grid cols={1} colsMd={2} colsLg={3} gap={4} class="mt-6">
        {matches.map(({ provider }) => (
          <Card variant="raised" class="flex flex-col">
            <Heading level={3} size="lg">{provider.name}</Heading>
            <Text size="sm" tone="muted" class="mt-1">{provider.tagline}</Text>
            <div class="mt-2 flex flex-wrap gap-1.5">
              <Badge tone="neutral" size="sm">{provider.serverNetwork.serverCount.toLocaleString()} servers</Badge>
              <Badge tone={provider.loggingPolicy === "no-logs" ? "success" : "warning"} size="sm">
                {provider.loggingPolicy.replace(/-/g, " ")}
              </Badge>
            </div>
            <div class="mt-auto pt-4">
              <Button variant="outline" size="sm" href={`/vpn/${provider.slug}/`}>View Details</Button>
            </div>
          </Card>
        ))}
      </Grid>
    </Container>
  </Section>

  {relatedGuides.length > 0 && (
    <Section>
      <Container>
        <Heading level={2}>Related Guides</Heading>
        <Grid cols={1} colsMd={2} colsLg={3} gap={4} class="mt-6">
          {relatedGuides.map((g) => (
            <Card>
              <Heading level={3} size="lg">{g.data.title}</Heading>
              <Text size="sm" tone="muted" class="mt-1">{g.data.summary}</Text>
              <Badge tone="neutral" size="sm" class="mt-2">{g.data.difficulty}</Badge>
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/guides/${g.id}/`}>Read Guide</Button>
              </div>
            </Card>
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  <Section background padding="tight">
    <Container>
      <Heading level={2} class="text-center">Explore by Other Dimensions</Heading>
      <div class="mt-4 flex flex-wrap justify-center gap-3">
        <Button variant="outline" size="sm" href="/features/">Browse Features</Button>
        <Button variant="outline" size="sm" href="/platforms/">Browse Platforms</Button>
        <Button variant="outline" size="sm" href="/countries/">Browse Countries</Button>
        <Button variant="outline" size="sm" href="/streaming/">Browse Streaming</Button>
      </div>
    </Container>
  </Section>
</SeoLayout>

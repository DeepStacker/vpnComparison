---
import { getCollection, getEntry, render } from "astro:content";
import ComparisonLayout from "@/layouts/ComparisonLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Rating from "@/components/ui/Rating.astro";
import Grid from "@/components/ui/Grid.astro";
import Chip from "@/components/ui/Chip.astro";
import Icon from "@/components/ui/Icon.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

export async function getStaticPaths() {
  const comparisons = await getCollection("comparisons");
  return comparisons.map((c) => ({ params: { slug: c.id } }));
}

const { slug } = Astro.params;
const comparisonEntry = await getEntry("comparisons", slug);
if (!comparisonEntry) return Astro.redirect("/404");

const comparison = comparisonEntry.data;
const { Content } = await render(comparisonEntry);

const providerEntries = await Promise.all(
  comparison.providers.map((ref) => getEntry("providers", ref.id)),
);
const providers = providerEntries.filter(Boolean).map((e) => e!.data);

const providerMap = new Map(providers.map((p) => [p.id, p]));

const allReviews = await getCollection("reviews");
const reviewMap = new Map(allReviews.map((r) => [r.data.provider.id, r.data]));

const [allCountries] = await Promise.all([
  getCollection("countries"),
]);
const countryMap = new Map(allCountries.map((c) => [c.data.code, c.data.name]));

const allBestLists = await getCollection("best-lists");
const relatedBestLists = allBestLists.filter((bl) =>
  bl.data.entries.some((e) => comparison.providers.some((ref) => ref.id === e.provider.id)),
);

const allGuides = await getCollection("guides");
const relatedGuides = allGuides.filter((g) =>
  g.data.relatedProviders?.some((ref) =>
    comparison.providers.some((cp) => cp.id === ref.id),
  ),
);

const winnerEntry = comparison.winner ? providerMap.get(comparison.winner.id) : null;

const seo = normalizeSeoMeta({
  title: buildTitle(comparison.title),
  description: comparison.summary,
  canonical: canonicalUrl(`/comparisons/${slug}/`),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "VPN Comparisons", href: "/comparisons/" },
  { label: comparison.title, href: `/comparisons/${slug}/` },
];

function capitalize(s: string): string {
  return s.charAt(0).toUpperCase() + s.slice(1);
}

function humanizeAttr(key: string): string {
  return key.replace(/([A-Z])/g, " $1").replace(/^./, (c) => c.toUpperCase());
}
---

<ComparisonLayout seo={seo} breadcrumbs={breadcrumbs}>
  <div slot="summary">
    {winnerEntry && (
      <Badge tone="success" size="md" class="mb-3">
        <Icon name="trophy" size={14} class="mr-1" />
        Winner: {winnerEntry.name}
      </Badge>
    )}
    <Heading level={1}>{comparison.title}</Heading>
    <Text size="lg" tone="muted" class="mt-2 max-w-2xl">{comparison.summary}</Text>
    <div class="mt-4 flex flex-wrap gap-3">
      {comparison.publishedAt && (
        <Text size="sm" tone="muted" element="span">Published {comparison.publishedAt}</Text>
      )}
      {comparison.updatedAt && (
        <Text size="sm" tone="muted" element="span">· Updated {comparison.updatedAt}</Text>
      )}
    </div>
  </div>

  <Section>
    <Container>
      <Grid cols={1} colsMd={comparison.providers.length} gap={6}>
        {providers.map((p) => {
          const score = reviewMap.get(p.id)?.scores.overall;
          return (
            <Card variant="raised" class="flex flex-col">
              <Heading level={3}>{p.name}</Heading>
              <Text size="sm" tone="muted" class="mt-1">{p.tagline}</Text>
              {score != null && (
                <Rating value={score} label={`${p.name} overall score`} size={14} class="mt-2" />
              )}
              <div class="mt-2 flex flex-wrap gap-1.5">
                <Chip>{countryMap.get(p.jurisdiction) ?? p.jurisdiction}</Chip>
                <Chip>{p.serverNetwork.serverCount.toLocaleString()} servers</Chip>
                <Chip>{p.pricing.plans.find((pl) => pl.featured)?.effectiveMonthly ?? p.pricing.plans[0]?.effectiveMonthly ?? "?"}/mo</Chip>
              </div>
              <div class="mt-auto pt-4">
                <Button variant="outline" size="sm" href={`/vpn/${p.slug}/`}>View Details</Button>
              </div>
            </Card>
          );
        })}
      </Grid>
    </Container>
  </Section>

  {comparison.sections.length > 0 && (
    <Section>
      <Container>
        <Heading level={2}>Comparison Overview</Heading>
        <nav class="sticky top-16 z-sticky -mx-4 mt-6 overflow-x-auto border-y border-border bg-background/95 px-4 py-3 backdrop-blur-md motion-safe:transition-shadow" aria-label="Section quick navigation">
          <div class="flex gap-2">
            {comparison.sections.map((section) => (
              <a
                href={`#section-${section.id}`}
                class="whitespace-nowrap rounded-full border border-border px-3 py-1.5 text-sm font-medium text-muted-foreground transition-colors motion-safe:duration-150 hover:border-primary hover:text-primary"
              >
                {section.title}
              </a>
            ))}
          </div>
        </nav>
        <div class="mt-8 space-y-6">
          {comparison.sections.map((section) => (
            <div id={`section-${section.id}`}>
              <Card padding="md">
                <Heading level={3}>{section.title}</Heading>
                {section.attributes && section.attributes.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {section.attributes.map((attr) => (
                      <Badge tone="neutral" size="sm">{humanizeAttr(attr)}</Badge>
                    ))}
                  </div>
                )}
              </Card>
            </div>
          ))}
        </div>
      </Container>
    </Section>
  )}

  {winnerEntry && (
    <Section background>
      <Container>
        <div class="relative overflow-hidden rounded-xl bg-gradient-to-br from-success-surface to-background border border-success/20">
          <div class="relative p-8 sm:p-10">
            <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:text-left">
              <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl bg-success text-success-foreground shadow-lg">
                <Icon name="trophy" size={36} />
              </div>
              <div class="min-w-0">
                <Badge tone="success" size="md">Winner</Badge>
                <Heading level={2} class="mt-3 text-2xl sm:text-3xl">{winnerEntry.name}</Heading>
                <Text tone="muted" class="mt-2 max-w-xl leading-relaxed">
                  {reviewMap.get(winnerEntry.id)?.verdict.headline ?? `${winnerEntry.name} wins this comparison based on our analysis.`}
                </Text>
                <div class="mt-6 flex flex-wrap gap-3">
                  <Button href={`/vpn/${winnerEntry.slug}/`}>Read Full Review</Button>
                  {comparison.winner && (
                    <Button variant="outline" href={`/vpn/${winnerEntry.slug}/`}>
                      View Pricing
                    </Button>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      </Container>
    </Section>
  )}

  <Section>
    <Container size="prose">
      <Heading level={2}>Full Analysis</Heading>
      <div class="prose max-w-none mt-4">
        <Content />
      </div>
    </Container>
  </Section>

  <Section>
    <Container>
      <Heading level={2}>Explore More</Heading>
      <Text tone="muted" class="mt-2">Browse VPNs by feature, protocol, platform, or streaming service.</Text>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/features/" class="rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium no-underline text-foreground transition-colors hover:border-primary hover:text-primary">Browse Features</a>
        <a href="/protocols/" class="rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium no-underline text-foreground transition-colors hover:border-primary hover:text-primary">Browse Protocols</a>
        <a href="/platforms/" class="rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium no-underline text-foreground transition-colors hover:border-primary hover:text-primary">Browse Platforms</a>
        <a href="/countries/" class="rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium no-underline text-foreground transition-colors hover:border-primary hover:text-primary">Browse Countries</a>
        <a href="/streaming/" class="rounded-lg border border-border bg-surface px-4 py-2 text-sm font-medium no-underline text-foreground transition-colors hover:border-primary hover:text-primary">Browse Streaming</a>
      </div>
    </Container>
  </Section>

  {(relatedBestLists.length > 0 || relatedGuides.length > 0) && (
    <Section>
      <Container>
        <Heading level={2}>Related Content</Heading>
        <Grid cols={1} colsMd={2} gap={6} class="mt-6">
          {relatedBestLists.map((bl) => (
            <Card>
              <Heading level={3}>{bl.data.title}</Heading>
              <Text size="sm" tone="muted" class="mt-1">{bl.data.summary}</Text>
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/best-lists/${bl.id}/`}>View List</Button>
              </div>
            </Card>
          ))}
          {relatedGuides.map((g) => (
            <Card>
              <Heading level={3}>{g.data.title}</Heading>
              <Text size="sm" tone="muted" class="mt-1">{g.data.summary}</Text>
              <Badge tone="neutral" class="mt-2">{capitalize(g.data.difficulty)}</Badge>
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/guides/${g.id}/`}>Read Guide</Button>
              </div>
            </Card>
          ))}
        </Grid>
      </Container>
    </Section>
  )}
</ComparisonLayout>

---
interface VpnLeakProvider {
  id: string; slug: string; name: string;
  features: string[];
  protocols: string[];
  killSwitch: boolean;
  splitTunneling: boolean;
  loggingPolicy: string;
}

interface VpnLeakReview {
  providerId: string;
  scores: { privacy: number; security: number };
}

interface Props {
  providers: VpnLeakProvider[];
  reviews: VpnLeakReview[];
}

const { providers, reviews } = Astro.props;
---

<div id="vpn-leak-root" class="grid gap-8 lg:grid-cols-5">
  <div class="lg:col-span-2 rounded-2xl border border-border bg-surface p-6 shadow-sm">
    <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Leak Test</p>
    <h2 class="mt-2 text-xl font-black tracking-tight">Configure Test</h2>
    <p class="mt-2 text-sm text-muted-foreground leading-relaxed">Simulate leak testing scenarios across providers.</p>

    <div class="mt-6 space-y-5">
      <div>
        <label for="leak-provider" class="block text-xs font-bold uppercase tracking-widest text-muted-foreground">Provider</label>
        <select id="leak-provider" class="mt-2 w-full rounded-xl border border-border bg-surface-sunken/40 px-4 py-2.5 text-sm font-bold text-foreground focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/20">
          {providers.map((p) => `<option value="${p.id}">${p.name}</option>`)}
        </select>
      </div>
      <div>
        <label class="block text-xs font-bold uppercase tracking-widest text-muted-foreground mb-2">Test Type</label>
        <div class="space-y-2">
          {[
            { id: "dns", label: "DNS Leak Test", desc: "Detect if DNS queries bypass the VPN tunnel" },
            { id: "ipv6", label: "IPv6 Leak Test", desc: "Check if IPv6 traffic leaks outside the tunnel" },
            { id: "webrtc", label: "WebRTC Leak Test", desc: "Identify WebRTC-based IP exposure" },
            { id: "all", label: "Full Suite", desc: "Run all leak tests in sequence" },
          ].map((t) => `
            <label class="group flex cursor-pointer items-center gap-3 rounded-xl border border-border bg-surface-sunken/40 p-3.5 transition-all duration-200 hover:border-primary/30 has-[:checked]:border-primary has-[:checked]:bg-primary/5">
              <input type="radio" name="leak-type" value="${t.id}" class="h-4 w-4 accent-primary shrink-0" ${t.id === "all" ? "checked" : ""} />
              <div class="min-w-0">
                <p class="text-sm font-bold text-foreground">${t.label}</p>
                <p class="text-xs text-muted-foreground">${t.desc}</p>
              </div>
            </label>
          `).join('')}
        </div>
      </div>
      <button id="leak-run" type="button" class="w-full rounded-xl bg-primary px-6 py-3 text-sm font-black uppercase tracking-widest text-primary-foreground transition-all duration-200 hover:brightness-110 shadow-lg">Run Test</button>
    </div>

    <div class="mt-6 rounded-xl border border-border bg-surface-sunken/40 p-4 text-xs text-muted-foreground leading-relaxed">
      Leak test results are simulated based on provider features and security controls. Actual performance depends on network conditions and device configuration.
    </div>
  </div>

  <div class="lg:col-span-3 space-y-6" id="leak-results">
    <div class="rounded-2xl border border-border bg-surface p-8 shadow-sm text-center">
      <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Ready</p>
      <h3 class="mt-3 text-2xl font-black tracking-tight">Run a leak test to begin</h3>
      <p class="mt-3 text-sm text-muted-foreground max-w-md mx-auto leading-relaxed">Select a provider and test type to simulate leak protection capabilities. Results include risk assessment and recommended mitigations.</p>
    </div>
  </div>
</div>

<script is:inline type="application/json" id="leak-data" set:html={JSON.stringify(providers)}></script>
<script is:inline type="application/json" id="leak-reviews-data" set:html={JSON.stringify(reviews)}></script>

<script>
  interface Provider {
    id: string; slug: string; name: string;
    features: string[];
    protocols: string[];
    killSwitch: boolean;
    splitTunneling: boolean;
    loggingPolicy: string;
  }
  interface ReviewData { providerId: string; scores: { privacy: number; security: number } }

  const allProviders: Provider[] = JSON.parse(document.getElementById("leak-data")!.textContent);
  const allReviews: ReviewData[] = JSON.parse(document.getElementById("leak-reviews-data")!.textContent);
  const reviewMap = new Map(allReviews.map((r) => [r.providerId, r]));
  const providerMap = new Map(allProviders.map((p) => [p.id, p]));

  const results = document.getElementById("leak-results")!;
  const runBtn = document.getElementById("leak-run") as HTMLButtonElement;
  const providerSel = document.getElementById("leak-provider") as HTMLSelectElement;

  function escapeHtml(str: string): string {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function getSelectedTest(): string {
    const selected = document.querySelector('input[name="leak-type"]:checked') as HTMLInputElement;
    return selected?.value ?? "all";
  }

  interface LeakResult {
    test: string;
    label: string;
    passed: boolean;
    severity: "Low" | "Medium" | "High";
    detail: string;
    mitigation: string;
  }

  function runLeakTests(p: Provider): LeakResult[] {
    const hasKillSwitch = p.killSwitch;
    const hasDnsProtection = p.features.includes("dns-leak-protection");
    const hasIpv6Support = p.protocols.includes("wireguard") || p.features.includes("ipv6-leak-protection");
    const hasWebRtcHandling = p.features.includes("webrtc-leak-protection") || p.killSwitch;
    const hasSplitTunneling = p.splitTunneling;
    const review = reviewMap.get(p.id);
    void review;

    const results: LeakResult[] = [
      {
        test: "dns", label: "DNS Leak Protection",
        passed: hasDnsProtection || hasKillSwitch,
        severity: (!hasDnsProtection && !hasKillSwitch) ? "High" : "Low",
        detail: hasDnsProtection ? "DNS leak protection is explicitly supported." : hasKillSwitch ? "Kill switch provides implicit DNS leak protection." : "No DNS leak protection detected.",
        mitigation: "Enable kill switch and verify with dnsleaktest.com after connecting.",
      },
      {
        test: "ipv6", label: "IPv6 Leak Protection",
        passed: hasIpv6Support,
        severity: hasIpv6Support ? "Low" : "Medium",
        detail: hasIpv6Support ? "IPv6 leak protection is supported." : "IPv6 leak protection not explicitly advertised.",
        mitigation: "Disable IPv6 on your device or use a provider with explicit IPv6 protection.",
      },
      {
        test: "webrtc", label: "WebRTC Leak Protection",
        passed: hasWebRtcHandling,
        severity: hasWebRtcHandling ? "Low" : "Medium",
        detail: hasWebRtcHandling ? "WebRTC leak protection is supported." : "No explicit WebRTC leak protection detected.",
        mitigation: "Use a browser extension to disable WebRTC, or choose a provider with built-in protection.",
      },
      {
        test: "split", label: "Split Tunneling Safety",
        passed: hasSplitTunneling,
        severity: hasSplitTunneling ? "Low" : "Low",
        detail: hasSplitTunneling ? "Split tunneling is available for selective routing." : "Split tunneling not available — all traffic routes through VPN.",
        mitigation: hasSplitTunneling ? "Use split tunneling cautiously — misconfigured rules can expose traffic." : "All traffic is protected by default when VPN is connected.",
      },
    ];

    return results;
  }

  function renderResults(providerId: string, testType: string) {
    const p = providerMap.get(providerId);
    if (!p) return;

    const allResults = runLeakTests(p);
    const filtered = testType === "all" ? allResults : allResults.filter((r) => r.test === testType);
    const passed = filtered.filter((r) => r.passed);
    const failed = filtered.filter((r) => !r.passed);
    const securityScore = Math.round((passed.length / filtered.length) * 100);
    const scoreColor = securityScore >= 80 ? "var(--color-success)" : securityScore >= 50 ? "var(--color-primary)" : "var(--color-danger)";

    results.innerHTML = `
      <div class="rounded-3xl border border-${securityScore >= 80 ? 'success' : securityScore >= 50 ? 'primary' : 'danger'}/30 bg-${securityScore >= 80 ? 'success' : securityScore >= 50 ? 'primary' : 'danger'}/5 p-8 shadow-sm">
        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
          <div class="min-w-0">
            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Leak Test Report</p>
            <h3 class="mt-2 text-2xl font-black tracking-tight">${escapeHtml(p.name)} · ${testType === "all" ? "Full Suite" : filtered[0]?.label ?? testType}</h3>
            <p class="mt-2 text-sm text-muted-foreground leading-relaxed max-w-xl">${filtered.length} test${filtered.length !== 1 ? "s" : ""} completed. ${failed.length === 0 ? "All tests passed — no leaks detected." : `${failed.length} ${failed.length === 1 ? "potential leak" : "potential leaks"} detected.`}</p>
          </div>
          <div class="shrink-0 text-center">
            <div class="relative inline-flex items-center justify-center" style="width:90px;height:90px">
              <svg class="-rotate-90" width="90" height="90" viewBox="0 0 90 90">
                <circle cx="45" cy="45" r="37" fill="none" stroke="var(--color-border)" stroke-width="7" />
                <circle cx="45" cy="45" r="37" fill="none" stroke="${scoreColor}" stroke-width="7" stroke-dasharray="${2 * Math.PI * 37}" stroke-dashoffset="${2 * Math.PI * 37 * (1 - securityScore / 100)}" stroke-linecap="round" class="transition-all duration-1000" />
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span class="text-xl font-black tracking-tighter" style="color:${scoreColor}">${securityScore}%</span>
                <span class="text-[8px] font-bold text-muted-foreground uppercase tracking-widest">secure</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
        <h3 class="text-lg font-black tracking-tight mb-6">Test Results</h3>
        <div class="space-y-4">
          ${filtered.map((r) => {
            const statusColor = r.passed ? 'text-success border-success/20 bg-success/10' : 'text-danger border-danger/20 bg-danger/10';
            const sevColor = r.severity === "High" ? 'text-danger' : r.severity === "Medium" ? 'text-warning' : 'text-success';
            return `<div class="rounded-xl border border-border/50 bg-surface-sunken/40 p-5">
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <div class="flex items-center gap-2">
                    <p class="text-sm font-black text-foreground">${escapeHtml(r.label)}</p>
                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-black uppercase tracking-widest ${statusColor}">${r.passed ? 'Pass' : 'Fail'}</span>
                  </div>
                  <p class="mt-2 text-sm text-muted-foreground leading-relaxed">${escapeHtml(r.detail)}</p>
                  ${!r.passed ? `<div class="mt-3 rounded-lg border border-border/30 bg-surface p-3">
                    <p class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground">Mitigation</p>
                    <p class="mt-1 text-sm text-foreground/90 leading-relaxed">${escapeHtml(r.mitigation)}</p>
                  </div>` : ''}
                </div>
                <span class="shrink-0 text-xs font-bold uppercase tracking-widest ${sevColor}">${r.severity}</span>
              </div>
            </div>`;
          }).join('')}
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        ${failed.length > 0 ? `<div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <h3 class="text-base font-black uppercase tracking-widest mb-4">Risk Summary</h3>
          <ul class="space-y-3 text-sm">
            ${failed.map((r) => `<li class="flex gap-3"><span class="mt-0.5 h-5 w-5 shrink-0 rounded-full bg-danger/10 border border-danger/30 flex items-center justify-center text-[10px] font-black text-danger">!</span><span class="text-foreground/90"><strong>${escapeHtml(r.label)}</strong>: ${escapeHtml(r.mitigation)}</span></li>`).join('')}
          </ul>
        </div>` : `<div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <h3 class="text-base font-black uppercase tracking-widest mb-4">Clean Report</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">No leak risks detected. The provider's security controls appear adequate for the tested scenarios.</p>
        </div>`}
        <div class="rounded-2xl border border-border bg-surface p-6 shadow-sm">
          <h3 class="text-base font-black uppercase tracking-widest mb-4">Recommended Next Steps</h3>
          <ul class="space-y-3 text-sm text-foreground/90">
            <li class="flex gap-3"><span class="mt-0.5 h-5 w-5 shrink-0 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center text-[10px] font-black text-primary">1</span><span>Run a real leak test from your device after connecting to the VPN.</span></li>
            <li class="flex gap-3"><span class="mt-0.5 h-5 w-5 shrink-0 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center text-[10px] font-black text-primary">2</span><span>Enable kill switch on all devices for an additional layer of protection.</span></li>
            <li class="flex gap-3"><span class="mt-0.5 h-5 w-5 shrink-0 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center text-[10px] font-black text-primary">3</span><span>Re-run this test after provider updates or configuration changes.</span></li>
          </ul>
        </div>
      </div>
    `;
  }

  runBtn.addEventListener("click", () => {
    renderResults(providerSel.value, getSelectedTest());
  });
</script>

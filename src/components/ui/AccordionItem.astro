---
/**
 * AccordionItem — a single collapsible row using native <details>/<summary>.
 * @prop summary - heading text (or use the "summary" slot for rich content).
 * @prop open - default open on load.
 * @prop id - optional anchor id (lets deep links open the item via :target).
 */
import Icon from "./Icon.astro";
import { cx } from "@/lib/utils/string";

interface Props {
  summary?: string;
  open?: boolean;
  id?: string;
  class?: string;
}

const { summary, open = false, id, class: className } = Astro.props;
---

<details id={id} open={open} class={cx("group", className)}>
  <summary
    class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 text-sm font-medium text-foreground hover:bg-surface-raised transition-colors focus-visible:outline-none [&::-webkit-details-marker]:hidden"
  >
    <span>
      {summary}
      <slot name="summary" />
    </span>
    <Icon
      name="chevron-down"
      size={18}
      class="text-muted-foreground transition-transform duration-base ease-standard group-open:rotate-180"
    />
  </summary>
  <div class="px-4 py-3 text-sm text-muted-foreground [&_a]:text-primary [&_a]:underline">
    <slot />
  </div>
</details>

---
import { getCollection } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import Icon from "@/components/ui/Icon.astro";
import ScoreRing from "@/components/ui/ScoreRing.astro";
import { SITE } from "@/constants/site";
import { canonicalUrl, normalizeSeoMeta } from "@/lib/seo/meta";

const allProviders = await getCollection("providers");
const allReviews = await getCollection("reviews");
const allBestLists = await getCollection("best-lists");
const allGuides = await getCollection("guides");
const allComparisons = await getCollection("comparisons");
const allFeatures = await getCollection("features");
const allProtocols = await getCollection("protocols");
const allPlatforms = await getCollection("platforms");
const allCountries = await getCollection("countries");
const allStreaming = await getCollection("streaming-services");

const reviewMap = new Map(allReviews.map((r) => [r.data.provider.id, r.data]));
const avgScore = allReviews.reduce((sum, r) => sum + r.data.scores.overall, 0) / allReviews.length;

const sortedByScore = allProviders
  .map((p) => ({ entry: p, review: reviewMap.get(p.id) }))
  .sort((a, b) => (b.review?.scores.overall ?? 0) - (a.review?.scores.overall ?? 0));

const editorChoice = sortedByScore.find((s) => s.review?.verdict.recommendation === "recommended");

const seo = normalizeSeoMeta({ title: SITE.tagline, description: SITE.description, canonical: canonicalUrl("/") });

const explorerLinks = [
  { href: "/countries/", icon: "globe", label: "Countries", count: allCountries.length },
  { href: "/features/", icon: "list-checks", label: "Features", count: allFeatures.length },
  { href: "/protocols/", icon: "terminal", label: "Protocols", count: allProtocols.length },
  { href: "/platforms/", icon: "monitor-smartphone", label: "Platforms", count: allPlatforms.length },
  { href: "/streaming/", icon: "play", label: "Streaming", count: allStreaming.length },
  { href: "/comparisons/", icon: "arrow-left-right", label: "Comparisons", count: allComparisons.length },
  { href: "/best-lists/", icon: "list-checks", label: "Best Lists", count: allBestLists.length },
  { href: "/guides/", icon: "book-open", label: "Guides", count: allGuides.length },
];
---

<SeoLayout seo={seo}>
  <!-- ============ HERO ============ -->
  <Section class="relative overflow-hidden pt-20 pb-12" padding="none">
    <div class="pointer-events-none absolute inset-0 bg-dot-grid opacity-[0.05]" aria-hidden="true" />
    <div class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[500px] w-[500px] rounded-full bg-primary/5 blur-[120px]" aria-hidden="true" />
    <Container>
      <div class="relative mx-auto max-w-3xl text-center">
        <Badge tone="primary" class="mb-6 border border-primary/20 bg-primary/5 text-primary backdrop-blur-md px-4 py-1.5 rounded-full">
          FreeVPN4USA — VPN Intelligence Platform
        </Badge>
        <h1 class="text-5xl font-bold tracking-tight text-balance leading-[1.1] text-foreground sm:text-6xl md:text-7xl">
          Find the Right VPN, <br class="hidden sm:inline" /> <span class="text-primary">Not the Right Ad</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-muted-foreground max-w-2xl mx-auto">
          We test every VPN with the same methodology, present the data transparently, and never let affiliate commissions influence our recommendations.
        </p>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <Button href="/tools/finder/" size="lg" class="rounded-full px-8">Find Your VPN</Button>
          <Button variant="secondary" href="/vpn/" size="lg" class="rounded-full px-8">Browse Reviews</Button>
        </div>
      </div>
    </Container>
  </Section>

  <!-- ============ TRUST STATS BAND ============ -->
  <Section padding="tight">
    <Container>
      <div class="grid grid-cols-2 gap-y-8 rounded-3xl bg-glass-subtle border border-glass-subtle-border shadow-glass-inner shadow-xl p-8 divide-y divide-glass-subtle-border backdrop-blur-xl sm:grid-cols-4 sm:divide-y-0 sm:divide-x after-glass-shine">
        <div class="px-4 text-center">
          <div class="text-3xl font-bold text-foreground">{allProviders.length}</div>
          <div class="text-xs font-bold uppercase tracking-widest text-muted-foreground mt-1">VPNs tested</div>
        </div>
        <div class="px-4 text-center">
          <div class="text-3xl font-bold text-foreground">{avgScore.toFixed(1)}</div>
          <div class="text-xs font-bold uppercase tracking-widest text-muted-foreground mt-1">Avg score</div>
        </div>
        <div class="px-4 text-center">
          <div class="text-3xl font-bold text-foreground">{allCountries.length}</div>
          <div class="text-xs font-bold uppercase tracking-widest text-muted-foreground mt-1">Countries</div>
        </div>
        <div class="px-4 text-center border-t-0!">
          <div class="text-3xl font-bold text-foreground">{allFeatures.length}</div>
          <div class="text-xs font-bold uppercase tracking-widest text-muted-foreground mt-1">Features</div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- ============ EDITOR'S CHOICE / TOP PICK ============ -->
  {editorChoice && (
    <Section background>
      <Container>
        <div class="mx-auto mb-4 max-w-xl text-center">
          <Badge tone="primary" size="md" class="rounded-full">Editor's Choice</Badge>
        </div>
        <Heading level={2} class="text-center text-3xl font-bold">Our Top-Rated VPN</Heading>
        <div class="mt-8 mx-auto max-w-3xl">
          <a href={`/vpn/${editorChoice.entry.data.slug}/`} class="group block rounded-3xl bg-glass-subtle border border-glass-subtle-border backdrop-blur-xl p-6 md:p-8 no-underline transition-all duration-300 hover:bg-glass hover:border-glass-border hover:shadow-xl hover:-translate-y-1 after-glass-shine">
            <div class="flex flex-col md:flex-row items-center md:justify-between gap-8 text-center md:text-left">
              <div class="flex flex-col md:flex-row items-center gap-6">
                <div class="h-20 w-20 flex items-center justify-center rounded-2xl bg-surface-raised border border-border p-3 shadow-sm group-hover:shadow-md transition-all">
                  <img src={`/logos/${editorChoice.entry.data.slug}.svg`} alt="" class="h-full w-full object-contain" width={80} height={80} loading="eager" />
                </div>
                <div>
                  <Heading level={3} class="text-xl font-bold">{editorChoice.entry.data.name}</Heading>
                  <p class="mt-1 text-sm text-muted-foreground leading-relaxed max-w-md">{editorChoice.entry.data.tagline}</p>
                  {editorChoice.review?.verdict && (
                    <div class="mt-3 inline-flex items-center gap-2 text-sm font-bold text-primary">
                      <Icon name="award" size={16} />
                      {editorChoice.review.verdict.headline}
                    </div>
                  )}
                </div>
              </div>
              <div class="flex flex-col md:flex-row items-center shrink-0 gap-6 border-t md:border-t-0 md:border-l border-border pt-6 md:pt-0 md:pl-8 w-full md:w-auto">
                {editorChoice.review && (
                  <ScoreRing value={editorChoice.review.scores.overall} size={64} strokeWidth={5} label="Overall score" />
                )}
                <div class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-2.5 text-sm font-bold text-primary-foreground transition-all duration-200 group-hover:bg-primary-hover shadow-sm">
                  Read Review <Icon name="arrow-right" size={16} />
                </div>
              </div>
            </div>
          </a>
        </div>
      </Container>
    </Section>
  )}

  <!-- ============ TOOLS ============ -->
  <Section>
    <Container>
      <div class="mx-auto mb-4 max-w-xl text-center">
        <Badge tone="primary" size="md" class="rounded-full">Interactive tools</Badge>
      </div>
      <Heading level={2} class="text-center text-3xl font-bold">Know Which VPN to Pick</Heading>
      <p class="mx-auto mt-4 max-w-xl text-center text-lg text-muted-foreground">
        Not sure where to start? Our tools turn data into decisions — no guesswork.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 max-w-4xl mx-auto">
        <a href="/tools/finder/" class="group rounded-3xl bg-glass-subtle border border-glass-subtle-border backdrop-blur-xl p-8 no-underline transition-all duration-300 hover:-translate-y-1 hover:bg-glass hover:border-glass-border hover:shadow-xl after-glass-shine">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-all duration-300 group-hover:bg-primary group-hover:text-primary-foreground shadow-sm">
            <Icon name="wand-2" size={24} />
          </div>
          <Heading level={3} class="mt-6 text-xl font-bold">VPN Recommender</Heading>
          <p class="mt-2 text-sm text-muted-foreground leading-relaxed">Answer a few questions and get a personalized recommendation with full transparency.</p>
        </a>
        <a href="/tools/compare/" class="group rounded-3xl bg-glass-subtle border border-glass-subtle-border backdrop-blur-xl p-8 no-underline transition-all duration-300 hover:-translate-y-1 hover:bg-glass hover:border-glass-border hover:shadow-xl after-glass-shine">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-all duration-300 group-hover:bg-primary group-hover:text-primary-foreground shadow-sm">
            <Icon name="arrow-left-right" size={24} />
          </div>
          <Heading level={3} class="mt-6 text-xl font-bold">Comparison Builder</Heading>
          <p class="mt-2 text-sm text-muted-foreground leading-relaxed">Select any providers and compare side by side across pricing, privacy, features, and more.</p>
        </a>
      </div>
    </Container>
  </Section>

  <!-- ============ EXPLORER LINKS ============ -->
  <Section background>
    <Container>
      <div class="mx-auto mb-4 max-w-xl text-center">
        <Badge tone="primary" size="md" class="rounded-full">Browse by category</Badge>
      </div>
      <Heading level={2} class="text-center text-3xl font-bold">Explore Our Database</Heading>
      <p class="mx-auto mt-4 max-w-xl text-center text-lg text-muted-foreground">
        Dive into any dimension of our VPN intelligence — every page is cross-linked and data-rich.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        {explorerLinks.map((link) => (
          <a
            href={link.href}
            class="inline-flex items-center gap-2 rounded-xl bg-glass-subtle border border-glass-subtle-border backdrop-blur-lg px-5 py-3 text-sm font-bold no-underline text-foreground transition-all duration-300 hover:-translate-y-1 hover:bg-glass hover:border-glass-border hover:text-primary hover:shadow-lg"
          >
            <Icon name={link.icon} size={18} class="text-primary shrink-0" />
            {link.label}
            <Badge tone="neutral" size="sm" class="ml-2 !px-2 rounded-full">{link.count}</Badge>
          </a>
        ))}
      </div>
    </Container>
  </Section>

  <!-- ============ BEST LISTS + GUIDES ============ -->
  <Section>
    <Container>
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <div class="flex items-center justify-between mb-6">
            <div>
              <Heading level={2} class="text-2xl font-bold">Best VPN Lists</Heading>
              <p class="mt-1 text-sm text-muted-foreground">Curated by use case with transparent criteria</p>
            </div>
            <Button variant="ghost" size="sm" href="/best-lists/" class="rounded-full">View all</Button>
          </div>
          <div class="space-y-3">
            {allBestLists.slice(0, 4).map((bl) => (
              <a href={`/best-lists/${bl.id}/`} class="group flex items-center justify-between rounded-2xl bg-surface border border-border p-4 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
                <div class="min-w-0">
                  <div class="text-base font-bold text-foreground group-hover:text-primary transition-colors">{bl.data.title}</div>
                  <div class="text-xs text-muted-foreground mt-1">{bl.data.entries.length} providers reviewed</div>
                </div>
                <div class="h-8 w-8 flex items-center justify-center rounded-full bg-surface-raised border border-border group-hover:bg-primary group-hover:text-primary-foreground transition-all">
                  <Icon name="arrow-right" size={14} />
                </div>
              </a>
            ))}
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-6">
            <div>
              <Heading level={2} class="text-2xl font-bold">Popular Guides</Heading>
              <p class="mt-1 text-sm text-muted-foreground">Learn how VPNs work and how to choose one</p>
            </div>
            <Button variant="ghost" size="sm" href="/guides/" class="rounded-full">View all</Button>
          </div>
          <div class="space-y-3">
            {allGuides.slice(0, 4).map((g) => (
              <a href={`/guides/${g.id}/`} class="group flex items-center justify-between rounded-2xl bg-surface border border-border p-4 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
                <div class="min-w-0">
                  <div class="text-base font-bold text-foreground group-hover:text-primary transition-colors">{g.data.title}</div>
                  <div class="text-xs text-muted-foreground mt-1 capitalize">{g.data.difficulty} level</div>
                </div>
                <div class="h-8 w-8 flex items-center justify-center rounded-full bg-surface-raised border border-border group-hover:bg-primary group-hover:text-primary-foreground transition-all">
                  <Icon name="arrow-right" size={14} />
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <!-- ============ TRUST / METHODOLOGY ============ -->
  <Section background padding="loose">
    <Container>
      <div class="mx-auto max-w-3xl bg-surface border border-border rounded-3xl p-8 md:p-12 shadow-xl text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary/20 via-primary to-primary/20" />
        <div class="relative z-10">
          <div class="h-16 w-16 mx-auto flex items-center justify-center rounded-2xl bg-primary/10 text-primary mb-6">
            <Icon name="shield-check" size={32} />
          </div>
          <Heading level={2} class="text-3xl font-bold">Independent, Methodical, Transparent</Heading>
          <p class="mt-4 text-lg text-muted-foreground leading-relaxed max-w-2xl mx-auto">
            Every VPN is tested using a consistent methodology across five critical dimensions. We don't just review; we audit.
          </p>
          <div class="mt-10 flex flex-wrap justify-center gap-x-8 gap-y-4">
            <span class="flex items-center gap-2 text-sm font-bold text-foreground"><Icon name="zap" size={18} class="text-success" /> Speed</span>
            <span class="flex items-center gap-2 text-sm font-bold text-foreground"><Icon name="shield" size={18} class="text-success" /> Privacy</span>
            <span class="flex items-center gap-2 text-sm font-bold text-foreground"><Icon name="lock" size={18} class="text-success" /> Security</span>
            <span class="flex items-center gap-2 text-sm font-bold text-foreground"><Icon name="play" size={18} class="text-success" /> Streaming</span>
            <span class="flex items-center gap-2 text-sm font-bold text-foreground"><Icon name="download" size={18} class="text-success" /> Torrenting</span>
          </div>
          <div class="mt-12 flex flex-wrap justify-center gap-4">
            <Button href="/methodology/" size="lg" class="rounded-full px-8">Our Methodology</Button>
            <Button variant="secondary" href="/tools/finder/" size="lg" class="rounded-full px-8">Try VPN Finder</Button>
          </div>
        </div>
      </div>
    </Container>
  </Section>
</SeoLayout>

---
import { getCollection, getEntry } from "astro:content";
import SeoLayout from "@/layouts/SeoLayout.astro";
import Section from "@/components/ui/Section.astro";
import Container from "@/components/ui/Container.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Grid from "@/components/ui/Grid.astro";
import Icon from "@/components/ui/Icon.astro";
import { getProvidersByPlatform, getRelatedGuidesForEntity } from "@/lib/content/explorer";
import { normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import type { Breadcrumb } from "@/types/site";

export async function getStaticPaths() {
  const platforms = await getCollection("platforms");
  return platforms.map((p) => ({ params: { slug: p.data.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry("platforms", slug);
if (!entry) return Astro.redirect("/404");

const platform = entry.data;
const matches = await getProvidersByPlatform(platform.id);
const relatedGuides = await getRelatedGuidesForEntity(platform.slug);

const seo = normalizeSeoMeta({
  title: `Best VPNs for ${platform.name} — ${platform.official ? "Official App Support" : "Compatible Providers"}`,
  description: `Find VPN providers with ${platform.official ? "official apps" : "compatible setup"} for ${platform.name}. Compare ${matches.length} VPNs that work on ${platform.name}.`,
  canonical: canonicalUrl(`/platforms/${slug}/`),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "Platforms", href: "/platforms/" },
  { label: platform.name, href: `/platforms/${slug}/` },
];
---

<SeoLayout seo={seo} breadcrumbs={breadcrumbs}>
  <Section background padding="loose">
    <Container>
      <div class="flex items-start gap-4">
        <Icon name={platform.icon as any} size={40} class="mt-1 shrink-0 text-primary" />
        <div>
          <div class="flex items-center gap-2 mb-2">
            <Badge>{platform.official ? "Official app" : "Compatible"}</Badge>
            {platform.category && (
              <Badge tone="neutral" size="sm">{platform.category}</Badge>
            )}
          </div>
          <Heading level={1}>{platform.name} VPN</Heading>
          <Text size="lg" tone="muted" class="mt-2 max-w-2xl">
            {platform.official
              ? `VPN providers with official ${platform.name} apps for seamless protection.`
              : `VPN providers compatible with ${platform.name} setup.`}
          </Text>
          {platform.minOsVersion && (
            <Badge tone="info" size="sm" class="mt-3">
              <Icon name="info" size={11} class="mr-1" />Minimum: {platform.minOsVersion}
            </Badge>
          )}
        </div>
      </div>
    </Container>
  </Section>

  {(platform.limitations || platform.commonIssues) && (
    <Section>
      <Container>
        <Heading level={2}>Platform Notes</Heading>
        <div class="mt-4 grid gap-6 lg:grid-cols-2">
          {platform.limitations && platform.limitations.length > 0 && (
            <Card variant="raised" padding="lg" class="border-t-4 border-warning">
              <Heading level={3}>
                <span class="flex items-center gap-2 text-warning">
                  <Icon name="alert-triangle" size={18} /> Limitations
                </span>
              </Heading>
              <ul class="mt-3 space-y-2">
                {platform.limitations.map((l) => (
                  <li class="flex items-start gap-2 text-sm text-foreground">
                    <Icon name="x" size={14} class="mt-0.5 shrink-0 text-warning" />
                    <span>{l}</span>
                  </li>
                ))}
              </ul>
            </Card>
          )}
          {platform.commonIssues && platform.commonIssues.length > 0 && (
            <Card variant="raised" padding="lg" class="border-t-4 border-info">
              <Heading level={3}>
                <span class="flex items-center gap-2 text-info">
                  <Icon name="help-circle" size={18} /> Common Issues
                </span>
              </Heading>
              <ul class="mt-3 space-y-2">
                {platform.commonIssues.map((i) => (
                  <li class="flex items-start gap-2 text-sm text-foreground">
                    <Icon name="circle" size={14} class="mt-0.5 shrink-0 text-info" />
                    <span>{i}</span>
                  </li>
                ))}
              </ul>
            </Card>
          )}
        </div>
      </Container>
    </Section>
  )}

  <Section background>
    <Container>
      <Heading level={2}>
        VPNs for {platform.name}
        <Text element="span" tone="muted" size="sm" class="ml-2">({matches.length})</Text>
      </Heading>
      {matches.length === 0 && (
        <div class="mt-6 flex flex-col items-center justify-center rounded-lg border border-dashed border-border bg-surface-sunken/40 px-6 py-12 text-center">
          <Text tone="muted">No VPN providers currently offer {platform.name} support.</Text>
        </div>
      )}
      <Grid cols={1} colsMd={2} colsLg={3} gap={4} class="mt-6">
        {matches.map(({ provider }) => (
          <Card variant="raised" class="flex flex-col">
            <Heading level={3} size="lg">{provider.name}</Heading>
            <Text size="sm" tone="muted" class="mt-1">{provider.tagline}</Text>
            <div class="mt-2 flex flex-wrap gap-1.5">
              <Badge tone="neutral" size="sm">{provider.serverNetwork.serverCount.toLocaleString()} servers</Badge>
              <Badge tone="info" size="sm">{provider.jurisdiction} jurisdiction</Badge>
            </div>
            <div class="mt-auto pt-4">
              <Button variant="outline" size="sm" href={`/vpn/${provider.slug}/`}>View Details</Button>
            </div>
          </Card>
        ))}
      </Grid>
    </Container>
  </Section>

  {relatedGuides.length > 0 && (
    <Section>
      <Container>
        <Heading level={2}>Related Guides</Heading>
        <Grid cols={1} colsMd={2} colsLg={3} gap={4} class="mt-6">
          {relatedGuides.map((g) => (
            <Card>
              <Heading level={3} size="lg">{g.data.title}</Heading>
              <Text size="sm" tone="muted" class="mt-1">{g.data.summary}</Text>
              <Badge tone="neutral" size="sm" class="mt-2">{g.data.difficulty}</Badge>
              <div class="mt-4">
                <Button variant="outline" size="sm" href={`/guides/${g.id}/`}>Read Guide</Button>
              </div>
            </Card>
          ))}
        </Grid>
      </Container>
    </Section>
  )}

  <Section background padding="tight">
    <Container>
      <Heading level={2} class="text-center">Explore by Other Dimensions</Heading>
      <div class="mt-4 flex flex-wrap justify-center gap-3">
        <Button variant="outline" size="sm" href="/features/">Browse Features</Button>
        <Button variant="outline" size="sm" href="/protocols/">Browse Protocols</Button>
        <Button variant="outline" size="sm" href="/countries/">Browse Countries</Button>
        <Button variant="outline" size="sm" href="/streaming/">Browse Streaming</Button>
      </div>
    </Container>
  </Section>
</SeoLayout>

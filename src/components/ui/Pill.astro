---
/**
 * Pill — rounded-full soft label, used for compact counts or status chips.
 * @prop tone - "neutral" | "primary" | "success" | "warning" | "danger" | "info".
 */
import { cx } from "@/lib/utils/string";

interface Props {
  tone?: "neutral" | "primary" | "success" | "warning" | "danger" | "info";
  class?: string;
}

const { tone = "neutral", class: className } = Astro.props;

const toneClass: Record<string, string> = {
  neutral: "bg-surface-sunken text-muted-foreground border-border",
  primary: "bg-primary/10 text-primary border-primary/20",
  success: "bg-success/10 text-success border-success/20",
  warning: "bg-warning/10 text-warning border-warning/20",
  danger: "bg-danger/10 text-danger border-danger/20",
  info: "bg-info/10 text-info border-info/20",
};

const classes = cx(
  "inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-widest whitespace-nowrap shadow-sm",
  toneClass[tone],
  className,
);
---

<span class={classes}>
  <slot />
</span>

---
import { getCollection } from "astro:content";
import ToolLayout from "@/layouts/ToolLayout.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";
import Badge from "@/components/ui/Badge.astro";
import { buildTitle, normalizeSeoMeta, canonicalUrl } from "@/lib/seo/meta";
import VpnFinder from "@/components/tools/VpnFinder.astro";
import type { Breadcrumb } from "@/types/site";

const allProviders = await getCollection("providers");
const allReviews = await getCollection("reviews");
const allFeatures = await getCollection("features");
const allProtocols = await getCollection("protocols");
const allPlatforms = await getCollection("platforms");
const allStreamingSvcs = await getCollection("streaming-services");
const allCountries = await getCollection("countries");

const featureNameMap = new Map(allFeatures.map((f) => [f.data.id, f.data.name]));
const protocolNameMap = new Map(allProtocols.map((p) => [p.data.id, p.data.name]));
const platformNameMap = new Map(allPlatforms.map((p) => [p.data.id, p.data.name]));
const streamingNameMap = new Map(allStreamingSvcs.map((s) => [s.data.id, s.data.name]));
const countryNameMap = new Map(allCountries.map((c) => [c.data.code, c.data.name]));

const providers = allProviders.map((e) => e.data);
const reviews = allReviews.map((e) => ({
  providerId: e.data.provider.id,
  scores: e.data.scores,
  verdict: e.data.verdict,
}));

const seo = normalizeSeoMeta({
  title: buildTitle("VPN Finder — Find the Right VPN for Your Needs"),
  description: "Answer a few questions and get a personalized VPN recommendation based on your privacy needs, streaming preferences, budget, and platform requirements.",
  canonical: canonicalUrl("/tools/finder/"),
});

const breadcrumbs: Breadcrumb[] = [
  { label: "VPN Finder", href: "/tools/finder/" },
];
---

<ToolLayout seo={seo} breadcrumbs={breadcrumbs}>
  <div slot="intro">
    <div class="mx-auto max-w-3xl text-center">
      <Badge tone="primary" class="mb-6">Personalized Recommendation</Badge>
      <Heading level={1} class="text-4xl font-black tracking-tight md:text-6xl">
        Find Your <span class="text-primary">VPN</span>
      </Heading>
      <Text size="xl" tone="muted" class="mt-6 leading-relaxed">
        Answer a few questions and we'll recommend the best VPN for your needs. Every recommendation is explained — no black boxes.
      </Text>
    </div>
  </div>
  <VpnFinder
    providers={providers}
    reviews={reviews}
    featureNames={Object.fromEntries(featureNameMap)}
    protocolNames={Object.fromEntries(protocolNameMap)}
    platformNames={Object.fromEntries(platformNameMap)}
    streamingNames={Object.fromEntries(streamingNameMap)}
    countryNames={Object.fromEntries(countryNameMap)}
  />
</ToolLayout>

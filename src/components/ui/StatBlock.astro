---
import { cx } from "@/lib/utils/string";
import Icon from "./Icon.astro";

interface Props {
  label: string;
  value: string;
  icon?: string;
  /** "default" (for cards) | "sm" (for compact rows) */
  size?: "default" | "sm";
  className?: string;
}
const { label, value, icon, size = "default", className } = Astro.props;

const isSm = size === "sm";
---

<div class={cx("flex items-start gap-4", className)}>
  {icon && (
    <div class:list={[
      "flex shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary",
      isSm ? "h-8 w-8" : "h-10 w-10",
    ]}>
      <Icon name={icon} size={isSm ? 16 : 20} />
    </div>
  )}
  <div class="min-w-0">
    <div class:list={[
      "font-bold text-foreground leading-none",
      isSm ? "text-sm" : "text-base",
    ]}>{value}</div>
    <div class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground mt-1">{label}</div>
  </div>
</div>

